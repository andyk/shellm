#!/usr/bin/env bash
set -euo pipefail

# shellm — Recursive LM in Bash
# An LLM that operates inside a bash shell, generating and executing code
# to process context and solve tasks recursively.

# Load .env if present (check cwd, then script's own directory)
_shellm_load_env() {
    local envfile="$1"
    if [[ -f "$envfile" ]]; then
        set -a
        # shellcheck disable=SC1090
        source "$envfile"
        set +a
        return 0
    fi
    return 1
}
_SHELLM_SCRIPT_PATH=$(realpath "${BASH_SOURCE[0]:-$0}" 2>/dev/null || printf '%s\n' "${BASH_SOURCE[0]:-$0}")
_SHELLM_SCRIPT_DIR=$(cd "$(dirname "$_SHELLM_SCRIPT_PATH")" && pwd -P)
_shellm_load_env ".env" || _shellm_load_env "$_SHELLM_SCRIPT_DIR/.env" || true

# ---------------------------------------------------------------------------
# Config & defaults
# ---------------------------------------------------------------------------

SHELLM_MODEL="${SHELLM_MODEL:-claude-opus-4-7}"
SHELLM_MAX_ITERATIONS="${SHELLM_MAX_ITERATIONS:-}"
SHELLM_TRUNCATE="${SHELLM_TRUNCATE:-2000}"
SHELLM_API_URL="${SHELLM_API_URL:-https://api.anthropic.com/v1/messages}"
export LLM_API_URL="$SHELLM_API_URL"
SHELLM_MAX_TOKENS="${SHELLM_MAX_TOKENS:-}"
SHELLM_EFFORT="${SHELLM_EFFORT:-high}"
SHELLM_DOCKER_IMAGE="${SHELLM_DOCKER_IMAGE:-ubuntu:latest}"
SHELLM_DOCKER_ACCESS="${SHELLM_DOCKER_ACCESS:-none}"
SHELLM_DOCKER_BROKER_TRANSPORT="${SHELLM_DOCKER_BROKER_TRANSPORT:-auto}"
SHELLM_DOCKER_SOCKET="${SHELLM_DOCKER_SOCKET:-/var/run/docker.sock}"
SHELLM_ALLOW_NESTED_DOCKER="${SHELLM_ALLOW_NESTED_DOCKER:-0}"
SHELLM_TEMP_DOCKER="${SHELLM_TEMP_DOCKER:-0}"
SHELLM_INACTIVITY_TIMEOUT="${SHELLM_INACTIVITY_TIMEOUT:-30}"
VERBOSE=0
QUIET=0

# Internal state (not user-configurable)
_SHELLM_DOCKER_MODE=0
_SHELLM_CONTAINER=""
_SHELLM_WORKDIR_USER=""
_SHELLM_DOCKER_BROKER_DIR=""
_SHELLM_DOCKER_BROKER_TRANSPORT=""
_SHELLM_TOOL_MOUNTS_VERSION=1
_SHELLM_EXTRA_VARS=()
_SHELLM_EXTRA_BINS=()

# Load .env if present
if [[ -f ".env" ]]; then
    set -a
    # shellcheck disable=SC1091
    source .env
    set +a
fi

# ---------------------------------------------------------------------------
# Utility functions
# ---------------------------------------------------------------------------

die() { echo "shellm: error: $*" >&2; exit 1; }

banner() {
    [[ "$QUIET" -eq 1 ]] && return
    [[ "${SHELLM_NO_BANNER:-0}" -eq 1 ]] && return
    cat <<'BANNER' >&2
