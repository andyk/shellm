}

# Dim gray for debug, bold for status, colors for code/output
progress() { [[ "$QUIET" -eq 1 ]] && return; echo -e "\033[1;34m▶ $*\033[0m" >&2; }
progress_dim() { [[ "$QUIET" -eq 1 ]] && return; echo -e "\033[90m  $*\033[0m" >&2; }

debug() {
    if [[ "$VERBOSE" -eq 1 ]]; then
        echo -e "\033[90m[shellm debug] $*\033[0m" >&2
    fi
}

make_workspace_name() {
    local context="$1"
    local timestamp
    timestamp=$(date +%Y-%m-%d-%H-%M-%S)
    local rand
    rand=$(head -c4 /dev/urandom | od -An -tx1 | tr -d ' \n')
    # Sanitize context: lowercase, spaces→hyphens, strip non-alnum/hyphens, collapse hyphens, truncate to 70 chars
    local slug
    slug=$(printf '%s' "$context" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-' | sed 's/--*/-/g; s/^-//; s/-$//' | cut -c1-70)
    if [[ -z "$slug" ]]; then
        slug="unnamed"
    fi
    echo "${timestamp}_${rand}_${slug}"
}

usage_text() {
    cat <<'EOF'
