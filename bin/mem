#!/usr/bin/env bash
set -euo pipefail

# mem — CLI memory store
# Stores memories as individual markdown files with YAML frontmatter.
# Uses shellm for semantic search. No databases — just files.

# ---------------------------------------------------------------------------
# Config & defaults
# ---------------------------------------------------------------------------

MEM_VERSION="0.1.0"
MEM_DIR="${MEM_DIR:-./.memories}"
VERBOSE=0
MEM_TYPE="memory"

# Terminal colors (disabled when not a tty)
if [[ -t 1 ]]; then
    _c_id=$'\033[1;33m'     # bold yellow for hex id
    _c_type=$'\033[36m'     # cyan for type tag
    _c_dim=$'\033[2m'       # dim for path
    _c_reset=$'\033[0m'
else
    _c_id="" _c_type="" _c_dim="" _c_reset=""
fi

# Source per-repo rc file (flags > env vars > rc file)
if [[ -f ".memrc" ]]; then
    _pre_env=$(env | grep '^MEM_') || true
    source .memrc
    while IFS='=' read -r k v; do
        [[ -n "$k" ]] && export "$k=$v"
    done <<< "$_pre_env"
fi

# ---------------------------------------------------------------------------
# Utility functions
# ---------------------------------------------------------------------------

die() { echo "mem: error: $*" >&2; exit 1; }

debug() {
    if [[ "$VERBOSE" -eq 1 ]]; then
        printf '[mem debug] %s\n' "$*" >&2
    fi
}

ensure_dir() {
    mkdir -p "$MEM_DIR"
}

slugify() {
    local text="$1"
    printf '%s' "$text" \
        | tr '[:upper:]' '[:lower:]' \
        | tr -cs 'a-z0-9' '-' \
        | sed 's/^-//; s/-$//' \
        | cut -c1-80
}

# Extract a field from YAML frontmatter.
# Usage: frontmatter_field <file> <field>
frontmatter_field() {
    local file="$1" field="$2"
    sed -n '/^---$/,/^---$/p' "$file" \
        | grep "^${field}:" \
        | head -1 \
        | sed "s/^${field}:[[:space:]]*//" \
        | sed "s/^[\"']\(.*\)[\"']$/\1/"
}

# Resolve a name/prefix/id to a memory file path.
# Matches hex id, exact filename, then prefix/substring on slug portion.
find_memory() {
    local id="$1"

    # Hex id match (4-8 char hex prefix in filename)
    if [[ "$id" =~ ^[0-9a-f]{4,8}$ ]]; then
        local id_match
        id_match=$(ls -1 "$MEM_DIR"/*.md 2>/dev/null | xargs -I{} basename {} .md | grep "_${id}" | head -2) || true
        local id_count
        id_count=$(printf '%s' "$id_match" | grep -c . 2>/dev/null) || id_count=0
        [[ "$id_count" -eq 1 ]] && { echo "$MEM_DIR/${id_match}.md"; return; }
        [[ "$id_count" -gt 1 ]] && die "Ambiguous: '$id' matches multiple memories"
    fi

    # Exact filename match
    [[ -f "$MEM_DIR/${id}.md" ]] && { echo "$MEM_DIR/${id}.md"; return; }

    die "Memory not found: $id (use hex ID prefix from 'mem list')"
}

# Parse filename into components: timestamp, hex id, slug
# Filename format: YYYY-MM-DD-HH-MM-SS_HEXID_slug
parse_filename() {
    local base="$1"
    # Check for new format with hex id
    if [[ "$base" =~ ^([0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{2}-[0-9]{2}-[0-9]{2})_([0-9a-f]{8})_(.+)$ ]]; then
        _pf_ts="${BASH_REMATCH[1]}"
        _pf_id="${BASH_REMATCH[2]}"
        _pf_slug="${BASH_REMATCH[3]}"
    else
        # Legacy format: YYYY-MM-DD-HH-MM-SS_slug (no hex id)
        _pf_ts="${base%%_*}"
        _pf_id=""
        _pf_slug="${base#*_}"
    fi
}

# ---------------------------------------------------------------------------
# Actions
# ---------------------------------------------------------------------------

action_add() {
    local text="$*"

    # Read from stdin if no text arg
    if [[ -z "$text" ]]; then
        text=$(cat)
        [[ -z "$text" ]] && die "No text provided"
    fi

    ensure_dir

    local timestamp hex slug filename summary created
    timestamp=$(date +%Y-%m-%d-%H-%M-%S)
    hex=$(head -c4 /dev/urandom | od -An -tx1 | tr -d ' \n')
    slug=$(slugify "$text")
    filename="${timestamp}_${hex}_${slug}"
    summary=$(printf '%s' "$text" | head -1 | cut -c1-80)
    created=$(date +"%Y-%m-%d %H:%M:%S")

    cat > "$MEM_DIR/${filename}.md" << EOF
---
id: $hex
summary: $summary
type: $MEM_TYPE
created: $created
---

$text
EOF

    debug "Created: $MEM_DIR/${filename}.md"
    printf '%s\n' "$filename"
}

action_search() {
    local query="$1"

    local count
    count=$(ls -1 "$MEM_DIR"/*.md 2>/dev/null | wc -l | tr -d ' ')
    [[ "$count" -eq 0 ]] && { echo "No memories stored." >&2; return 0; }

    # Concatenate all memories with filenames as headers
    local memories=""
    local f
    for f in "$MEM_DIR"/*.md; do
        memories+="=== $(basename "$f") ===
$(cat "$f")

"
    done

    llm -s "You are a semantic search engine for memory files. Each memory has a filename header (=== filename ===), YAML frontmatter (summary, type), and a body. Return ONLY the filenames and summaries of semantically matching memories, one per line. If nothing matches, say 'No matches found.'" \
        "Search these memories for: ${query}

${memories}"
}

action_list() {
    local limit=0 short=0 filter_type="" filter_before="" filter_after=""

    # Parse list-specific flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -s|--short)  short=1; shift ;;
            --type)      filter_type="${2:?--type requires a value}"; shift 2 ;;
            --before)    filter_before="${2:?--before requires a date (YYYY-MM-DD)}"; shift 2 ;;
            --after)     filter_after="${2:?--after requires a date (YYYY-MM-DD)}"; shift 2 ;;
            [0-9]*)      limit="$1"; shift ;;
            *)           die "Unknown list option: $1" ;;
        esac
    done

    local count
    count=$(ls -1 "$MEM_DIR"/*.md 2>/dev/null | wc -l | tr -d ' ') || count=0
    [[ "$count" -eq 0 ]] && { echo "No memories stored." >&2; return 0; }

    local files
    files=$(ls -1 "$MEM_DIR"/*.md)
    if [[ "$limit" -gt 0 ]]; then
        files=$(printf '%s' "$files" | tail -n "$limit")
    fi

    local f base
    while IFS= read -r f; do
        base=$(basename "$f" .md)
        parse_filename "$base"

        # Read type from frontmatter
        local mtype
        mtype=$(frontmatter_field "$f" "type") || true
        [[ -z "$mtype" ]] && mtype="memory"

        # Apply filters
        if [[ -n "$filter_type" && "$mtype" != "$filter_type" ]]; then continue; fi

        local file_date="${_pf_ts:0:10}"  # YYYY-MM-DD
        if [[ -n "$filter_before" && "$file_date" > "$filter_before" && "$file_date" != "$filter_before" ]]; then continue; fi
        if [[ -n "$filter_after" && "$file_date" < "$filter_after" && "$file_date" != "$filter_after" ]]; then continue; fi

        # Format timestamp: YYYY-MM-DD HH:MM
        local display_ts="${_pf_ts:0:10} ${_pf_ts:11:2}:${_pf_ts:14:2}"

        if [[ "$short" -eq 1 ]]; then
            # Concise: one line per memory
            local short_id="${_pf_id:---------}"
            local summary
            summary=$(frontmatter_field "$f" "summary") || true
            [[ -z "$summary" ]] && summary="$_pf_slug"
            printf '%s  %s  %-12s %s\n' "$display_ts" "$short_id" "[$mtype]" "$summary"
        else
            # Verbose (default): multi-line with id, slug, summary, path
            local id_display
            if [[ -n "$_pf_id" ]]; then
                id_display="${_c_id}${_pf_id}${_c_reset}"
            else
                id_display="${_c_dim}--------${_c_reset}"
            fi

            printf '%b  %s  %b[%s]%b\n' "$id_display" "$display_ts" "$_c_type" "$mtype" "$_c_reset"

            local summary
            summary=$(frontmatter_field "$f" "summary") || true
            if [[ -n "$summary" ]]; then
                printf '    %s\n' "$summary"
            fi

            printf '    %b%s%b\n' "$_c_dim" "$f" "$_c_reset"
        fi
    done <<< "$files"
}

action_types() {
    ls -1 "$MEM_DIR"/*.md 2>/dev/null | while IFS= read -r f; do
        frontmatter_field "$f" "type"
    done | sort | uniq -c | sort -rn | while read -r count type; do
        printf '%4d  %s\n' "$count" "$type"
    done
}

action_show() {
    local name="$1"
    local file
    file=$(find_memory "$name")
    cat "$file"
}

action_forget() {
    local name="$1"
    local file
    file=$(find_memory "$name")

    debug "Deleting: $file"
    rm "$file"
    echo "Forgotten: $(basename "$file" .md)" >&2
}

action_edit() {
    local name="$1"; shift
    local file
    file=$(find_memory "$name")

    local slug=""
    # Parse --slug flag
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --slug) slug="${2:?--slug requires TEXT}"; shift 2 ;;
            *) break ;;
        esac
    done

    local text="$*"
    if [[ -z "$text" ]]; then
        text=$(cat)
        [[ -z "$text" ]] && die "No text provided"
    fi

    local now
    now=$(date +"%Y-%m-%d %H:%M:%S")

    # Extract frontmatter fields
    local summary type created id
    summary=$(printf '%s' "$text" | head -1 | head -c 80)
    type=$(frontmatter_field "$file" "type")
    created=$(frontmatter_field "$file" "created")
    id=$(frontmatter_field "$file" "id")

    # Build updated: field — collect existing entries and append new one
    local updated_block=""
    local existing_updated
    existing_updated=$(sed -n '/^---$/,/^---$/p' "$file" | grep "^updated:" | sed 's/^updated:[[:space:]]*//' || true)
    local existing_list
    existing_list=$(sed -n '/^---$/,/^---$/p' "$file" | grep "^  - " || true)

    if [[ -n "$existing_list" ]]; then
        # Already a list — append
        updated_block=$(printf 'updated:\n%s\n  - %s' "$existing_list" "$now")
    elif [[ -n "$existing_updated" ]]; then
        # Single value — convert to list
        updated_block=$(printf 'updated:\n  - %s\n  - %s' "$existing_updated" "$now")
    else
        # No updated field yet
        updated_block=$(printf 'updated: %s' "$now")
    fi

    # Reconstruct the file (preserve id if present)
    local id_line=""
    [[ -n "$id" ]] && id_line="id: $id
"

    cat > "$file" << EOF
---
${id_line}summary: $summary
type: $type
created: $created
$updated_block
---

$text
EOF

    # Auto-update slug in filename
    local base
    base=$(basename "$file" .md)
    parse_filename "$base"
    local new_slug
    if [[ -n "$slug" ]]; then
        new_slug="$slug"
    else
        # Generate slug from first 80 chars of new text
        new_slug=$(printf '%s' "$text" | head -c 80 | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9._-]/-/g; s/--*/-/g; s/^-//; s/-$//')
    fi
    if [[ -n "$new_slug" && "$new_slug" != "$_pf_slug" ]]; then
        local new_file="$MEM_DIR/${_pf_ts}_${_pf_id}_${new_slug}.md"
        mv "$file" "$new_file"
        file="$new_file"
    fi

    debug "Updated: $file"
    echo "Updated: $(basename "$file" .md)" >&2
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
    cat <<'EOF'
mem — CLI memory store

Usage:
  mem add [--type TYPE] <text>   Add a memory (or pipe text via stdin)
  mem search <query>             Semantic search via shellm
  mem list [options] [N]         List memories (last N if given)
  mem types                      List memory types with counts
  mem show <id>                  Show a memory's full contents
  mem forget <id>                Delete a memory by hex ID
  mem edit <id> [--slug SLUG] <text>  Update body (or pipe via stdin)

List options:
  -s, --short        Concise one-line-per-memory view
  --type TYPE        Filter by type (e.g. --type fact)
  --before DATE      Show memories on or before DATE (YYYY-MM-DD)
  --after DATE       Show memories on or after DATE (YYYY-MM-DD)

Types:
  todo, objective, value, belief, fact, preference, note (default: memory)

Options:
  --dir DIR          Override memory directory (default: ./.memories)
  -v, --verbose      Verbose/debug mode
  -h, --help         Show help
  --version          Show version

Environment:
  MEM_DIR   Override memory directory (default: ./.memories)
EOF
    exit 0
}

# ---------------------------------------------------------------------------
# Argument parsing & dispatch
# ---------------------------------------------------------------------------

main() {
    # Parse global flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                usage
                ;;
            --version)
                echo "mem $MEM_VERSION"
                exit 0
                ;;
            -v|--verbose)
                VERBOSE=1
                shift
                ;;
            --dir)
                MEM_DIR="${2:?--dir requires a path}"
                shift 2
                ;;
            -*)
                # Could be --type inside add, so break and let subcommand handle
                break
                ;;
            *)
                break
                ;;
        esac
    done

    local cmd="${1:-}"
    [[ -n "$cmd" ]] && shift

    case "$cmd" in
        add)
            # Parse --type flag
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --type)
                        MEM_TYPE="${2:?--type requires a value}"
                        shift 2
                        ;;
                    *)
                        break
                        ;;
                esac
            done
            action_add "$@"
            ;;
        search)
            [[ $# -lt 1 ]] && die "Usage: mem search <query>"
            action_search "$*"
            ;;
        list)
            action_list "$@"
            ;;
        types)
            action_types
            ;;
        show)
            [[ $# -lt 1 ]] && die "Usage: mem show <id>"
            action_show "$1"
            ;;
        forget)
            [[ $# -lt 1 ]] && die "Usage: mem forget <id>"
            action_forget "$1"
            ;;
        edit)
            [[ $# -lt 1 ]] && die "Usage: mem edit <id> [--slug SLUG] [text]"
            local name="$1"; shift
            action_edit "$name" "$@"
            ;;
        "")
            usage
            ;;
        *)
            die "Unknown command: $cmd (try mem --help)"
            ;;
    esac
}

main "$@"
