#!/usr/bin/env bash
set -euo pipefail

# shellm-explore — Explore and visualize shellm run trees
#
# Usage: shellm-explore <RUN_ID> [--report] [--model MODEL]

# ---------------------------------------------------------------------------
# Utility
# ---------------------------------------------------------------------------

die() { echo "shellm-explore: error: $*" >&2; exit 1; }

# Colors (disabled if stdout is not a tty)
if [[ -t 1 ]]; then
    _c_tree=$'\033[36m'    # cyan for tree bars
    _c_hi=$'\033[1;33m'    # bold yellow for >>> target highlight
    _c_reset=$'\033[0m'
else
    _c_tree="" _c_hi="" _c_reset=""
fi

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

TRAJ_DIR="${TRAJ_DIR:-$HOME/.shellm/.trajectories}"
RUN_ID=""
REPORT=0
LIST_MODE=0
REPORT_MODEL="${SHELLM_MODEL:-claude-opus-4-7}"
LIST_LIMIT=20
SUMMARY_WIDTH=85

while [[ $# -gt 0 ]]; do
    case "$1" in
        --list|-l) LIST_MODE=1; shift ;;
        --report) REPORT=1; shift ;;
        --traj-dir) TRAJ_DIR="${2:?--traj-dir requires a path}"; shift 2 ;;
        --model)  REPORT_MODEL="${2:?--model requires a value}"; shift 2 ;;
        -n)       LIST_LIMIT="${2:?-n requires a number}"; shift 2 ;;
        -w)       SUMMARY_WIDTH="${2:?-w requires a number}"; shift 2 ;;
        --help|-h)
            cat <<'EOF'
Usage: shellm-explore [RUN_ID] [options]

Explore and visualize shellm run trees. With no arguments, lists recent runs.

Arguments:
  RUN_ID              Trajectory filename, hex ID portion, or slug

Options:
  -l, --list          List recent runs (default when no RUN_ID given)
  --traj-dir DIR      Trajectories directory (default: $TRAJ_DIR or ~/.shellm/.trajectories)
  -n N                Number of runs to list (default: 20, 0 for all)
  -w N                Truncate summaries to N characters (default: 85, 0 for no limit)
  --report            Generate an LLM-powered analysis of the run tree
  --model MODEL       Model for report generation (default: $SHELLM_MODEL or claude-opus-4-7)
  -h, --help          Show this help

Environment variables:
  TRAJ_DIR            Same as --traj-dir

Examples:
  shellm-explore                           # list recent runs
  shellm-explore -n 5                      # list 5 most recent runs
  shellm-explore a1b2c3d4                  # show tree for a run
  shellm-explore a1b2c3d4 -w 60           # tree with short summaries
  shellm-explore a1b2c3d4 --report         # generate analysis report
EOF
            exit 0
            ;;
        -*)       die "Unknown option: $1" ;;
        *)        RUN_ID="$1"; shift ;;
    esac
done

# ---------------------------------------------------------------------------
# Get summary line for a trajectory file
# ---------------------------------------------------------------------------

get_summary() {
    local traj_file="$1"
    local raw=""

    # Try to find a run-summary step
    local summary_line
    summary_line=$(jq -c 'select(.type == "run-summary")' "$traj_file" 2>/dev/null | head -1)
    if [[ -n "$summary_line" ]]; then
        raw=$(printf '%s' "$summary_line" | jq -r '.tldr // empty')
    fi

    # Fallback: try the prompt step
    if [[ -z "$raw" ]]; then
        local prompt_line
        prompt_line=$(jq -c 'select(.type == "prompt")' "$traj_file" 2>/dev/null | head -1)
        if [[ -n "$prompt_line" ]]; then
            raw=$(printf '%s' "$prompt_line" | jq -r '.content // empty' | head -c 200)
        fi
    fi

    # Fallback: try the shellm-run command
    if [[ -z "$raw" ]]; then
        local run_line
        run_line=$(head -1 "$traj_file")
        raw=$(printf '%s' "$run_line" | jq -r '.command // empty' 2>/dev/null | head -c 200)
    fi

    [[ -z "$raw" ]] && raw="(no summary)"

    if [[ "$SUMMARY_WIDTH" -gt 0 && ${#raw} -gt "$SUMMARY_WIDTH" ]]; then
        raw="${raw:0:$(( SUMMARY_WIDTH - 3 ))}..."
    fi
    printf '%s' "$raw"
}

# ---------------------------------------------------------------------------
# List runs (no RUN_ID given)
# ---------------------------------------------------------------------------

list_runs() {
    local limit="$1"
    [[ -d "$TRAJ_DIR" ]] || die "No trajectories directory: $TRAJ_DIR"

    # Find all trajectory files (both root.jsonl and legacy .jsonl), sorted newest first
    local -a traj_files=()
    while IFS= read -r f; do
        [[ -f "$f" ]] || continue
        # Only show root trajectories with shellm-run as first step
        local first_type
        first_type=$(head -1 "$f" | jq -r '.type // empty' 2>/dev/null)
        [[ "$first_type" == "shellm-run" ]] || continue
        traj_files+=("$f")
    done < <(find "$TRAJ_DIR" -name '*.jsonl' -not -path '*/blobs/*' 2>/dev/null | sort -r)

    [[ ${#traj_files[@]} -gt 0 ]] || { echo "No runs found."; return; }

    local count=0
    for traj_file in "${traj_files[@]}"; do
        if [[ "$limit" -gt 0 && "$count" -ge "$limit" ]]; then break; fi

        # Parse hex and timestamp from either directory-based or legacy format
        local hex="" ts=""
        local bn
        bn=$(basename "$traj_file")

        if [[ "$bn" == "root.jsonl" ]]; then
            # Directory-based: parent dir is <hex8>-<slug>
            local dir_name
            dir_name=$(basename "$(dirname "$traj_file")")
            if [[ "$dir_name" =~ ^([0-9a-f]{8})-(.+)$ ]]; then
                hex="${BASH_REMATCH[1]}"
            else
                hex="$dir_name"
            fi
            # Get timestamp from the first step
            local first_ts
            first_ts=$(head -1 "$traj_file" | jq -r '.ts // empty' 2>/dev/null)
            if [[ "$first_ts" =~ ^([0-9]{4}-[0-9]{2}-[0-9]{2})T([0-9]{2}):([0-9]{2}) ]]; then
                ts="${BASH_REMATCH[1]} ${BASH_REMATCH[2]}:${BASH_REMATCH[3]}"
            fi
        else
            # Legacy flat file: YYYY-MM-DD-HH-MM-SS_HEXID_slug.jsonl
            local basename_noext
            basename_noext="${bn%.jsonl}"
            if [[ "$basename_noext" =~ ^([0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{2}-[0-9]{2}-[0-9]{2})_([0-9a-f]{8})_(.+)$ ]]; then
                ts="${BASH_REMATCH[1]}"
                hex="${BASH_REMATCH[2]}"
                ts="${ts:0:10} ${ts:11:2}:${ts:14:2}"
            else
                hex="$basename_noext"
            fi
        fi

        # Count sub-runs (fork steps in this trajectory)
        local sub_count
        sub_count=$(jq -c 'select(.type == "fork")' "$traj_file" 2>/dev/null | wc -l | tr -d ' ')

        local summary
        summary="$(get_summary "$traj_file")"

        local tree_indicator=""
        if [[ "$sub_count" -gt 0 ]]; then
            tree_indicator=" ${_c_tree}[${sub_count} sub]${_c_reset}"
        fi

        printf "${_c_hi}%s${_c_reset}  %s%s\n" "$hex" "$ts" "$tree_indicator"
        printf "    %s\n" "$summary"

        count=$(( count + 1 ))
    done

    local total=${#traj_files[@]}
    if [[ "$limit" -gt 0 && "$total" -gt "$limit" ]]; then
        printf "\n(%d of %d runs shown, use -n 0 for all)\n" "$limit" "$total"
    fi
}

# ---------------------------------------------------------------------------
# Resolve & explore a specific run
# ---------------------------------------------------------------------------

# Resolve RUN_ID: match against trajectory filenames (hex ID or slug)
resolve_run_id() {
    local input="$1"
    [[ -d "$TRAJ_DIR" ]] || return 1

    local -a matches=()
    local f
    while IFS= read -r f; do
        [[ -f "$f" ]] || continue

        # Check if first step is shellm-run (it's a run, not a consciousness stream)
        local first_type
        first_type=$(head -1 "$f" | jq -r '.type // empty' 2>/dev/null)
        [[ "$first_type" == "shellm-run" ]] || continue

        local bn
        bn=$(basename "$f")

        if [[ "$bn" == "root.jsonl" ]]; then
            # Directory-based: match against parent directory name (<hex8>-<slug>)
            local dir_name
            dir_name=$(basename "$(dirname "$f")")
            if [[ "$dir_name" == "${input}-"* || "$dir_name" == *"-${input}" || "$dir_name" == "$input" ]]; then
                matches+=("$f")
            elif [[ "$dir_name" == "${input}"* ]]; then
                matches+=("$f")
            fi
        else
            # Legacy flat file
            local basename_noext
            basename_noext="${bn%.jsonl}"
            if [[ "$basename_noext" == *"_${input}_"* || "$basename_noext" == *"_${input}" ]]; then
                matches+=("$f")
            elif [[ "$basename_noext" == "$input"* ]]; then
                matches+=("$f")
            fi
        fi
    done < <(find "$TRAJ_DIR" -name '*.jsonl' -not -path '*/blobs/*' 2>/dev/null | sort)

    if [[ ${#matches[@]} -eq 1 ]]; then
        echo "${matches[0]}"
        return
    elif [[ ${#matches[@]} -gt 1 ]]; then
        echo "Ambiguous run ID '$input' matches ${#matches[@]} runs:" >&2
        for m in "${matches[@]}"; do
            local mbn
            mbn=$(basename "$m")
            if [[ "$mbn" == "root.jsonl" ]]; then
                echo "  $(basename "$(dirname "$m")")" >&2
            else
                echo "  ${mbn%.jsonl}" >&2
            fi
        done
        return 1
    fi

    return 1
}

# If no RUN_ID or explicit --list/-l, list runs and exit
if [[ -z "$RUN_ID" || "$LIST_MODE" -eq 1 ]]; then
    list_runs "$LIST_LIMIT"
    exit 0
fi

_run_input="$RUN_ID"
RUN_TRAJ="$(resolve_run_id "$RUN_ID")" || die "No matching run found: $_run_input"

# ---------------------------------------------------------------------------
# Find root of the run tree by following trajectory parent references
# ---------------------------------------------------------------------------

find_root() {
    local traj_file="$1"

    # Check if the first step is trajectory with parent (meaning this is a child/sub-run)
    local first_line
    first_line=$(head -1 "$traj_file")
    local first_type
    first_type=$(printf '%s' "$first_line" | jq -r '.type // empty')

    if [[ "$first_type" == "trajectory" ]]; then
        # Get the parent UUID and resolve it
        local parent_id
        parent_id=$(printf '%s' "$first_line" | jq -r '.parent // empty')
        if [[ -n "$parent_id" ]]; then
            # Use traj's resolution logic: try directory-based, then legacy
            local parent_file=""
            local hex_prefix="$parent_id"
            if [[ "$parent_id" == *-*-*-*-* ]]; then
                hex_prefix="${parent_id%%-*}"
            fi

            # Try directory glob first
            local match
            match=$(find "$TRAJ_DIR" -type d -name "${hex_prefix}-*" 2>/dev/null | head -1)
            if [[ -n "$match" && -f "$match/root.jsonl" ]]; then
                parent_file="$match/root.jsonl"
            fi

            # Try legacy flat file
            if [[ -z "$parent_file" ]]; then
                match=$(find "$TRAJ_DIR" -name "*_${hex_prefix}_*.jsonl" -not -path '*/blobs/*' 2>/dev/null | head -1)
                [[ -n "$match" ]] && parent_file="$match"
            fi

            # Try direct path (legacy: parent stored as filename)
            if [[ -z "$parent_file" && -f "$TRAJ_DIR/$parent_id" ]]; then
                parent_file="$TRAJ_DIR/$parent_id"
            fi

            if [[ -n "$parent_file" && -f "$parent_file" ]]; then
                find_root "$parent_file"
                return
            fi
        fi
    fi

    echo "$traj_file"
}

ROOT_TRAJ="$(find_root "$RUN_TRAJ")"

# ---------------------------------------------------------------------------
# Tree visualization
# ---------------------------------------------------------------------------

print_tree() {
    local root_traj="$1"
    local target_traj="$2"

    # Build tree by walking fork references starting from root
    local -a depths=() files=() names=() sums=()

    _collect_tree() {
        local traj_file="$1"
        local depth="$2"

        [[ -f "$traj_file" ]] || return

        # Parse hex ID from either directory-based or legacy format
        local bn hex=""
        bn=$(basename "$traj_file")
        if [[ "$bn" == "root.jsonl" ]]; then
            local dir_name
            dir_name=$(basename "$(dirname "$traj_file")")
            if [[ "$dir_name" =~ ^([0-9a-f]{8})- ]]; then
                hex="${BASH_REMATCH[1]}"
            else
                hex="$dir_name"
            fi
        elif [[ "${bn%.jsonl}" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{2}-[0-9]{2}-[0-9]{2}_([0-9a-f]{8})_ ]]; then
            hex="${BASH_REMATCH[1]}"
        else
            hex="${bn%.jsonl}"
        fi

        depths+=("$depth")
        files+=("$traj_file")
        names+=("$hex")
        sums+=("$(get_summary "$traj_file")")

        # Find fork steps in this trajectory → child branches
        local fork_lines
        fork_lines=$(jq -c 'select(.type == "fork")' "$traj_file" 2>/dev/null || true)
        [[ -z "$fork_lines" ]] && return

        while IFS= read -r fork_line; do
            local child_ref
            child_ref=$(printf '%s' "$fork_line" | jq -r '.child // empty')
            [[ -n "$child_ref" ]] || continue

            # Resolve child file: try UUID-based resolution, then legacy path
            local child_file=""
            local hex_prefix="$child_ref"
            if [[ "$child_ref" == *-*-*-*-* ]]; then
                hex_prefix="${child_ref%%-*}"
            fi

            # Try directory glob (both under current traj dir and TRAJ_DIR)
            local match
            match=$(find "$TRAJ_DIR" -type d -name "${hex_prefix}-*" 2>/dev/null | head -1)
            if [[ -n "$match" && -f "$match/root.jsonl" ]]; then
                child_file="$match/root.jsonl"
            fi

            # Try legacy flat file
            if [[ -z "$child_file" ]]; then
                match=$(find "$TRAJ_DIR" -name "*_${hex_prefix}_*.jsonl" -not -path '*/blobs/*' 2>/dev/null | head -1)
                [[ -n "$match" ]] && child_file="$match"
            fi

            # Try direct path (legacy)
            if [[ -z "$child_file" ]]; then
                local child_path="$child_ref"
                [[ "$child_path" == *.jsonl ]] || child_path="${child_path}.jsonl"
                [[ -f "$TRAJ_DIR/$child_path" ]] && child_file="$TRAJ_DIR/$child_path"
            fi

            [[ -n "$child_file" && -f "$child_file" ]] && _collect_tree "$child_file" $((depth + 1))
        done <<< "$fork_lines"
    }

    _collect_tree "$root_traj" 0

    local count=${#depths[@]}
    [[ "$count" -gt 0 ]] || { echo "(empty tree)"; return; }

    # Determine which nodes are the last child at their depth.
    local -a is_last=()
    local i j
    for (( i=0; i<count; i++ )); do
        local d=${depths[$i]} last=1
        for (( j=i+1; j<count; j++ )); do
            if [[ ${depths[$j]} -le $d ]]; then
                [[ ${depths[$j]} -eq $d ]] && last=0
                break
            fi
        done
        is_last+=("$last")
    done

    # Print with ASCII tree connectors.
    local -a has_more=()
    for (( i=0; i<count; i++ )); do
        local d=${depths[$i]}
        local prefix=""

        if [[ $d -gt 0 ]]; then
            prefix+="  "  # 2-space left margin
            local lvl
            for (( lvl=1; lvl<d; lvl++ )); do
                if [[ "${has_more[$lvl]:-0}" -eq 1 ]]; then
                    prefix+="${_c_tree}│${_c_reset}     "
                else
                    prefix+="      "
                fi
            done
            if [[ ${is_last[$i]} -eq 1 ]]; then
                prefix+="${_c_tree}└────${_c_reset} "
            else
                prefix+="${_c_tree}├────${_c_reset} "
            fi
        fi

        if [[ ${is_last[$i]} -eq 1 ]]; then
            has_more[$d]=0
        else
            has_more[$d]=1
        fi

        if [[ "${files[$i]}" == "$target_traj" ]]; then
            echo "${_c_hi}>>>${_c_reset} ${prefix}${_c_hi}${names[$i]}${_c_reset}: ${sums[$i]}"
        else
            echo "    ${prefix}${_c_hi}${names[$i]}${_c_reset}: ${sums[$i]}"
        fi
    done
}

# ---------------------------------------------------------------------------
# Report mode
# ---------------------------------------------------------------------------

generate_report() {
    local root_traj="$1"
    local target_traj="$2"

    # Build the tree visualization
    local tree_output
    tree_output="$(print_tree "$root_traj" "$target_traj")"

    # Collect context for every run in the tree
    local all_contexts=""

    _collect_contexts() {
        local traj_file="$1"
        [[ -f "$traj_file" ]] || return

        # Display name: directory name for root.jsonl, basename for legacy
        local display_name
        local bn
        bn=$(basename "$traj_file")
        if [[ "$bn" == "root.jsonl" ]]; then
            display_name=$(basename "$(dirname "$traj_file")")
        else
            display_name="${bn%.jsonl}"
        fi
        all_contexts+="
## ${display_name}
"
        # Get summary
        local summary
        summary=$(get_summary "$traj_file")
        all_contexts+="Summary: $summary"

        # Get command from shellm-run step
        local first_line
        first_line=$(head -1 "$traj_file")
        local first_type
        first_type=$(printf '%s' "$first_line" | jq -r '.type // empty')
        if [[ "$first_type" == "shellm-run" ]]; then
            local cmd
            cmd=$(printf '%s' "$first_line" | jq -r '.command // empty')
            all_contexts+=$'\n'"Command: $cmd"
        fi
        all_contexts+=$'\n'

        # Recurse into fork children
        local fork_lines
        fork_lines=$(jq -c 'select(.type == "fork")' "$traj_file" 2>/dev/null || true)
        [[ -z "$fork_lines" ]] && return

        while IFS= read -r fork_line; do
            local child_ref
            child_ref=$(printf '%s' "$fork_line" | jq -r '.child // empty')
            [[ -n "$child_ref" ]] || continue

            # Resolve child file using UUID-based resolution
            local child_file=""
            local hex_prefix="$child_ref"
            if [[ "$child_ref" == *-*-*-*-* ]]; then
                hex_prefix="${child_ref%%-*}"
            fi

            local match
            match=$(find "$TRAJ_DIR" -type d -name "${hex_prefix}-*" 2>/dev/null | head -1)
            if [[ -n "$match" && -f "$match/root.jsonl" ]]; then
                child_file="$match/root.jsonl"
            fi

            if [[ -z "$child_file" ]]; then
                match=$(find "$TRAJ_DIR" -name "*_${hex_prefix}_*.jsonl" -not -path '*/blobs/*' 2>/dev/null | head -1)
                [[ -n "$match" ]] && child_file="$match"
            fi

            if [[ -z "$child_file" ]]; then
                local child_path="$child_ref"
                [[ "$child_path" == *.jsonl ]] || child_path="${child_path}.jsonl"
                [[ -f "$TRAJ_DIR/$child_path" ]] && child_file="$TRAJ_DIR/$child_path"
            fi

            [[ -n "$child_file" && -f "$child_file" ]] && _collect_contexts "$child_file"
        done <<< "$fork_lines"
    }

    _collect_contexts "$root_traj"

    # Build the prompt
    local user_prompt="Here is a shellm run tree visualization:

\`\`\`
${tree_output}
\`\`\`

The target run being analyzed is: $(basename "$target_traj" .jsonl)

Below is the detailed context for every run in the tree:
${all_contexts}

Please provide a detailed report explaining:
1. What the overall run tree is trying to accomplish
2. Why the target run (marked with >>>) exists in the context of the bigger picture
3. How the target run relates to its parent and sibling runs
4. What the target run's specific role and contribution is"

    local system_prompt="You are an analyst examining shellm run trees. A shellm run tree represents a hierarchy of LLM-powered bash execution sessions, where parent runs spawn child sub-runs to break down tasks. Provide clear, insightful analysis."

    local msg_json
    msg_json=$(jq -n --arg p "$user_prompt" '[{"role":"user","content":$p}]')

    local text
    text=$(llm -m "$REPORT_MODEL" -t 4096 -s "$system_prompt" -M "$msg_json") \
        || die "API request failed"

    if [[ -z "$text" ]]; then
        die "No text in API response"
    fi

    printf '%s\n' "$text"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

if [[ "$REPORT" -eq 1 ]]; then
    generate_report "$ROOT_TRAJ" "$RUN_TRAJ"
else
    print_tree "$ROOT_TRAJ" "$RUN_TRAJ"
fi
