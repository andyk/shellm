#!/usr/bin/env bash
set -euo pipefail

# shellm-explore — Explore and visualize shellm run trees
#
# Usage: shellm-explore <RUN_ID> [--report] [--model MODEL]

# ---------------------------------------------------------------------------
# Utility
# ---------------------------------------------------------------------------

die() { echo "shellm-explore: error: $*" >&2; exit 1; }

# Colors (disabled if stdout is not a tty)
if [[ -t 1 ]]; then
    _c_tree=$'\033[36m'    # cyan for tree bars
    _c_hi=$'\033[1;33m'    # bold yellow for >>> target highlight
    _c_reset=$'\033[0m'
else
    _c_tree="" _c_hi="" _c_reset=""
fi

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

RUNS_DIR="${SHELLM_RUNS_DIR:-$HOME/.shellm/runs}"
RUN_ID=""
REPORT=0
LIST_MODE=0
REPORT_MODEL="${SHELLM_MODEL:-claude-opus-4-7}"
LIST_LIMIT=20
SUMMARY_WIDTH=85

while [[ $# -gt 0 ]]; do
    case "$1" in
        --list|-l) LIST_MODE=1; shift ;;
        --report) REPORT=1; shift ;;
        --runs-dir) RUNS_DIR="${2:?--runs-dir requires a path}"; shift 2 ;;
        --model)  REPORT_MODEL="${2:?--model requires a value}"; shift 2 ;;
        -n)       LIST_LIMIT="${2:?-n requires a number}"; shift 2 ;;
        -w)       SUMMARY_WIDTH="${2:?-w requires a number}"; shift 2 ;;
        --help|-h)
            cat <<'EOF'
Usage: shellm-explore [RUN_ID] [options]

Explore and visualize shellm run trees. With no arguments, lists recent runs.

Arguments:
  RUN_ID              Run directory path, name prefix, or hex ID portion

Options:
  -l, --list          List recent runs (default when no RUN_ID given)
  --runs-dir DIR      Runs directory (default: $SHELLM_RUNS_DIR or ~/.shellm/runs)
  -n N                Number of runs to list (default: 20, 0 for all)
  -w N                Truncate summaries to N characters (default: 70, 0 for no limit)
  --report            Generate an LLM-powered analysis of the run tree
  --model MODEL       Model for report generation (default: $SHELLM_MODEL or claude-opus-4-7)
  -h, --help          Show this help

Environment variables:
  SHELLM_RUNS_DIR     Same as --runs-dir

Examples:
  shellm-explore                           # list recent runs
  shellm-explore -n 5                      # list 5 most recent runs
  shellm-explore 8cdb3d26                  # show tree for a run
  shellm-explore 8cdb3d26 -w 60           # tree with short summaries
  shellm-explore 8cdb3d26 --report         # generate analysis report
EOF
            exit 0
            ;;
        -*)       die "Unknown option: $1" ;;
        *)        RUN_ID="$1"; shift ;;
    esac
done

# ---------------------------------------------------------------------------
# Get summary line for a run directory
# ---------------------------------------------------------------------------

get_summary() {
    local dir="$1"
    local raw
    if [[ -f "$dir/.shellm/context.md" ]]; then
        raw=$(sed -n '2p' "$dir/.shellm/context.md")
    elif [[ -f "$dir/.shellm/command" ]]; then
        raw=$(cut -c1-200 "$dir/.shellm/command")
    else
        raw="(no summary)"
    fi
    if [[ "$SUMMARY_WIDTH" -gt 0 && ${#raw} -gt "$SUMMARY_WIDTH" ]]; then
        raw="${raw:0:$(( SUMMARY_WIDTH - 3 ))}..."
    fi
    printf '%s' "$raw"
}

# ---------------------------------------------------------------------------
# List runs (no RUN_ID given)
# ---------------------------------------------------------------------------

list_runs() {
    local limit="$1"
    [[ -d "$RUNS_DIR" ]] || die "No runs directory: $RUNS_DIR"

    # Top-level runs only (direct children of runs_dir), newest first
    local dirs
    dirs=$(find "$RUNS_DIR" -mindepth 1 -maxdepth 1 -type d | sort -r)
    [[ -z "$dirs" ]] && { echo "No runs found."; return; }

    local count=0
    while IFS= read -r run_dir; do
        [[ -f "$run_dir/.shellm/command" ]] || continue
        if [[ "$limit" -gt 0 && "$count" -ge "$limit" ]]; then break; fi

        local name
        name="$(basename "$run_dir")"

        # Parse timestamp and hex from name: YYYY-MM-DD-HH-MM-SS_HEXID_slug
        local ts hex slug
        ts="${name:0:19}"                          # 2026-04-23-23-15-50
        hex="${name:20:8}"                         # 8cdb3d26
        slug="${name:29}"                          # the-rest-of-the-name
        # Format timestamp for display: YYYY-MM-DD HH:MM
        ts="${ts:0:10} ${ts:11:2}:${ts:14:2}"

        # Count sub-runs and measure max depth
        local sub_count max_depth
        sub_count=$(find "$run_dir" -mindepth 3 -name command -path '*/.shellm/command' 2>/dev/null | wc -l | tr -d ' ')
        if [[ "$sub_count" -gt 0 ]]; then
            local root_components
            root_components=$(echo "$run_dir" | tr '/' '\n' | wc -l | tr -d ' ')
            max_depth=$(find "$run_dir" -mindepth 3 -name command -path '*/.shellm/command' 2>/dev/null \
                | while IFS= read -r f; do
                    d=$(dirname "$(dirname "$f")")
                    echo "$d" | tr '/' '\n' | wc -l | tr -d ' '
                done | sort -rn | head -1)
            max_depth=$(( max_depth - root_components ))
        fi

        local summary
        summary="$(get_summary "$run_dir")"

        local tree_indicator=""
        if [[ "$sub_count" -gt 0 ]]; then
            if [[ "$max_depth" -gt 1 ]]; then
                tree_indicator=" ${_c_tree}[${sub_count} sub, depth ${max_depth}]${_c_reset}"
            else
                tree_indicator=" ${_c_tree}[${sub_count} sub]${_c_reset}"
            fi
        fi

        printf "${_c_hi}%s${_c_reset}  %s%s\n" "$hex" "$ts" "$tree_indicator"
        printf "    %s\n" "$summary"

        count=$(( count + 1 ))
    done <<< "$dirs"

    local total
    total=$(echo "$dirs" | grep -c . || true)
    if [[ "$limit" -gt 0 && "$total" -gt "$limit" ]]; then
        printf "\n(%d of %d runs shown, use -n 0 for all)\n" "$limit" "$total"
    fi
}

# ---------------------------------------------------------------------------
# Resolve & explore a specific run
# ---------------------------------------------------------------------------

# Resolve RUN_ID: absolute/relative path, name prefix match, or hex portion match
resolve_run_id() {
    local input="$1"
    local runs_dir="$RUNS_DIR"

    # 1. Direct path (absolute or relative)
    if [[ -d "$input" && -f "$input/.shellm/command" ]]; then
        (cd "$input" && pwd)
        return
    fi

    # 2. Search all run records (including sub-runs) for matches
    [[ -d "$runs_dir" ]] || return 1
    local all_runs
    all_runs=$(find "$runs_dir" -name command -path '*/.shellm/command' 2>/dev/null | sort)
    [[ -z "$all_runs" ]] && return 1

    local matches=()
    while IFS= read -r cmd_file; do
        local run_dir
        run_dir="$(dirname "$(dirname "$cmd_file")")"
        local name
        name="$(basename "$run_dir")"

        # Match by name prefix or hex portion (the 8-char hex after the timestamp)
        if [[ "$name" == "$input"* ]] || [[ "$name" == *"_${input}_"* || "$name" == *"_${input}" ]]; then
            matches+=("$run_dir")
        fi
    done <<< "$all_runs"

    if [[ ${#matches[@]} -eq 1 ]]; then
        echo "${matches[0]}"
        return
    elif [[ ${#matches[@]} -gt 1 ]]; then
        echo "Ambiguous run ID '$input' matches ${#matches[@]} runs:" >&2
        for m in "${matches[@]}"; do
            echo "  $(basename "$m")" >&2
        done
        return 1
    fi

    return 1
}

# If no RUN_ID or explicit --list/-l, list runs and exit
if [[ -z "$RUN_ID" || "$LIST_MODE" -eq 1 ]]; then
    list_runs "$LIST_LIMIT"
    exit 0
fi

_run_input="$RUN_ID"
RUN_ID="$(resolve_run_id "$RUN_ID")" || die "No matching run found: $_run_input"

# ---------------------------------------------------------------------------
# Find root of the run tree
# ---------------------------------------------------------------------------

find_root() {
    local dir="$1"
    while [[ -f "$(dirname "$dir")/.shellm/command" ]]; do
        dir="$(dirname "$dir")"
    done
    echo "$dir"
}

ROOT="$(find_root "$RUN_ID")"

# ---------------------------------------------------------------------------
# Tree visualization
# ---------------------------------------------------------------------------

print_tree() {
    local root="$1"
    local target="$2"

    # Find all run records under root (directories containing .shellm/command)
    local runs
    runs=$(find "$root" -name command -path '*/.shellm/command' | sort)

    local root_depth
    root_depth=$(echo "$root" | tr '/' '\n' | wc -l | tr -d ' ')

    # Collect all entries into parallel arrays
    local -a depths=() dirs=() names=() sums=()
    while IFS= read -r cmd_file; do
        local run_dir
        run_dir="$(dirname "$(dirname "$cmd_file")")"
        local run_depth
        run_depth=$(echo "$run_dir" | tr '/' '\n' | wc -l | tr -d ' ')

        local bn
        bn="$(basename "$run_dir")"
        # Extract hex ID from name: YYYY-MM-DD-HH-MM-SS_HEXID_slug
        local hex="${bn:20:8}"

        depths+=("$(( run_depth - root_depth ))")
        dirs+=("$run_dir")
        names+=("$hex")
        sums+=("$(get_summary "$run_dir")")
    done <<< "$runs"

    local count=${#depths[@]}

    # Determine which nodes are the last child at their depth.
    # A node at depth d is "last" if the next node at depth <= d has depth < d (or doesn't exist).
    local -a is_last=()
    local i j
    for (( i=0; i<count; i++ )); do
        local d=${depths[$i]} last=1
        for (( j=i+1; j<count; j++ )); do
            if [[ ${depths[$j]} -le $d ]]; then
                [[ ${depths[$j]} -eq $d ]] && last=0
                break
            fi
        done
        is_last+=("$last")
    done

    # Print with ASCII tree connectors.
    # has_more[lvl]=1 means there are still siblings coming at that depth level.
    local -a has_more=()
    for (( i=0; i<count; i++ )); do
        local d=${depths[$i]}
        local prefix=""

        if [[ $d -gt 0 ]]; then
            prefix+="  "  # 2-space left margin
            # Vertical bars for ancestor levels
            local lvl
            for (( lvl=1; lvl<d; lvl++ )); do
                if [[ "${has_more[$lvl]:-0}" -eq 1 ]]; then
                    prefix+="${_c_tree}│${_c_reset}     "
                else
                    prefix+="      "
                fi
            done
            # Connector for this node
            if [[ ${is_last[$i]} -eq 1 ]]; then
                prefix+="${_c_tree}└────${_c_reset} "
            else
                prefix+="${_c_tree}├────${_c_reset} "
            fi
        fi

        # Update sibling tracking for this depth
        if [[ ${is_last[$i]} -eq 1 ]]; then
            has_more[$d]=0
        else
            has_more[$d]=1
        fi

        if [[ "${dirs[$i]}" == "$target" ]]; then
            echo "${_c_hi}>>>${_c_reset} ${prefix}${_c_hi}${names[$i]}${_c_reset}: ${sums[$i]}"
        else
            echo "    ${prefix}${_c_hi}${names[$i]}${_c_reset}: ${sums[$i]}"
        fi
    done
}

# ---------------------------------------------------------------------------
# Report mode
# ---------------------------------------------------------------------------

generate_report() {
    local root="$1"
    local target="$2"

    # Build the tree visualization
    local tree_output
    tree_output="$(print_tree "$root" "$target")"

    # Collect context for every run in the tree
    local all_contexts=""
    local runs
    runs=$(find "$root" -name command -path '*/.shellm/command' | sort)

    while IFS= read -r cmd_file; do
        local run_dir
        run_dir="$(dirname "$(dirname "$cmd_file")")"
        local run_basename
        run_basename="$(basename "$run_dir")"

        all_contexts+="
## ${run_basename}
"
        if [[ -f "$run_dir/.shellm/context.md" ]]; then
            all_contexts+="$(cat "$run_dir/.shellm/context.md")"
        else
            all_contexts+="Command: $(cat "$run_dir/.shellm/command")"
        fi
        all_contexts+="
"
    done <<< "$runs"

    # Build the prompt
    local user_prompt="Here is a shellm run tree visualization:

\`\`\`
${tree_output}
\`\`\`

The target run being analyzed is: $(basename "$target")
Full path: ${target}

Below is the detailed context for every run in the tree:
${all_contexts}

Please provide a detailed report explaining:
1. What the overall run tree is trying to accomplish
2. Why the target run (marked with >>>) exists in the context of the bigger picture
3. How the target run relates to its parent and sibling runs
4. What the target run's specific role and contribution is"

    local system_prompt="You are an analyst examining shellm run trees. A shellm run tree represents a hierarchy of LLM-powered bash execution sessions, where parent runs spawn child sub-runs to break down tasks. Provide clear, insightful analysis."

    local msg_json
    msg_json=$(jq -n --arg p "$user_prompt" '[{"role":"user","content":$p}]')

    local text
    text=$(llm -m "$REPORT_MODEL" -t 4096 -s "$system_prompt" -M "$msg_json") \
        || die "API request failed"

    if [[ -z "$text" ]]; then
        die "No text in API response"
    fi

    printf '%s\n' "$text"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

if [[ "$REPORT" -eq 1 ]]; then
    generate_report "$ROOT" "$RUN_ID"
else
    print_tree "$ROOT" "$RUN_ID"
fi
