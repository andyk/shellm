#!/usr/bin/env bash
set -euo pipefail

# thinkers — Modular reactive thought process manager
# Manages thinker lifecycle: start/stop dispatcher, list thinkers, scaffold new ones.

# ---------------------------------------------------------------------------
# Config from environment
# ---------------------------------------------------------------------------

IDENTITY_DIR="${IDENTITY_DIR:-}"
IDENTITY_NAME="${IDENTITY_NAME:-}"
MEM_DIR="${MEM_DIR:-}"
SKILLS_DIR="${SKILLS_DIR:-}"
SKILLS_KERNEL_DIR="${SKILLS_KERNEL_DIR:-}"
TRAJ_DIR="${TRAJ_DIR:-}"
TRAJ_ID="${TRAJ_ID:-}"
THINKERS_DIR="${THINKERS_DIR:-}"
SHELLM_HOME="${SHELLM_HOME:-}"
THINK_MODEL="${THINK_MODEL:-${SHELLM_MODEL:-claude-opus-4-7}}"
THINK_CONTEXT_TAIL="${THINK_CONTEXT_TAIL:-30}"
THINKERS_MAX_CONCURRENT="${THINKERS_MAX_CONCURRENT:-20}"
VERBOSE=0

# ---------------------------------------------------------------------------
# Utility functions
# ---------------------------------------------------------------------------

die() { printf 'thinkers: error: %s\n' "$*" >&2; exit 1; }

# Kill a process and all its descendants (depth-first).
_kill_tree() {
    local pid="$1" sig="${2:-TERM}"
    local child
    for child in $(pgrep -P "$pid" 2>/dev/null); do
        _kill_tree "$child" "$sig"
    done
    kill -"$sig" "$pid" 2>/dev/null || true
}

debug() {
    if [[ "$VERBOSE" -eq 1 ]]; then
        printf '[thinkers debug] %s\n' "$*" >&2
    fi
}

_require_env() {
    [[ -n "$IDENTITY_DIR" ]] || die "IDENTITY_DIR not set. Run: identity shell <name>"
    [[ -n "$TRAJ_DIR" ]] || die "TRAJ_DIR not set. Run: identity shell <name>"
    [[ -n "$TRAJ_ID" ]] || die "TRAJ_ID not set. Run: identity shell <name>"

    # Resolve identity name if not set
    if [[ -z "$IDENTITY_NAME" ]]; then
        IDENTITY_NAME=$(grep '^name=' "$IDENTITY_DIR/info.txt" 2>/dev/null | cut -d= -f2-) || true
        [[ -z "$IDENTITY_NAME" ]] && IDENTITY_NAME=$(basename "$IDENTITY_DIR")
    fi

    # Default THINKERS_DIR
    if [[ -z "$THINKERS_DIR" ]]; then THINKERS_DIR="$IDENTITY_DIR/thinkers"; fi
    [[ -d "$THINKERS_DIR" ]] || die "Thinkers directory not found: $THINKERS_DIR"

    if [[ -z "$MEM_DIR" ]]; then MEM_DIR="$IDENTITY_DIR/memories"; fi
    if [[ -z "$SKILLS_DIR" ]]; then SKILLS_DIR="$IDENTITY_DIR/skills"; fi
    if [[ -z "$SKILLS_KERNEL_DIR" ]]; then SKILLS_KERNEL_DIR="$IDENTITY_DIR/kernel"; fi
    if [[ -z "$SHELLM_HOME" ]]; then SHELLM_HOME="$IDENTITY_DIR/.shellm"; fi
}

# ---------------------------------------------------------------------------
# Trajectory file resolution (mirrors traj's _resolve_traj_id)
# ---------------------------------------------------------------------------

_resolve_traj_file() {
    local traj_dir="$1" traj_id="$2"

    # 1. Exact path
    if [[ -f "$traj_dir/$traj_id" ]]; then
        printf '%s' "$traj_dir/$traj_id"; return
    fi

    # 2. Directory-based: $traj_dir/$traj_id/trajectory.jsonl
    if [[ -f "$traj_dir/$traj_id/trajectory.jsonl" ]]; then
        printf '%s' "$traj_dir/$traj_id/trajectory.jsonl"; return
    fi

    # 3. UUID handling: extract hex prefix and try directory glob FIRST
    #    (directory-based takes priority over legacy flat files)
    local hex_prefix="$traj_id"
    if [[ "$traj_id" == *-*-*-*-* ]]; then
        hex_prefix="${traj_id%%-*}"
    fi

    local match
    match=$(find "$traj_dir" -type d -name "${hex_prefix}-*" 2>/dev/null | head -1)
    if [[ -n "$match" && -f "$match/trajectory.jsonl" ]]; then
        printf '%s' "$match/trajectory.jsonl"; return
    fi

    # 4. Legacy .jsonl suffix
    if [[ "$traj_id" != *.jsonl && -f "$traj_dir/${traj_id}.jsonl" ]]; then
        printf '%s' "$traj_dir/${traj_id}.jsonl"; return
    fi

    # 5. Legacy flat file glob
    match=$(find "$traj_dir" -maxdepth 1 -name "*_${hex_prefix}_*.jsonl" -not -path '*/blobs/*' 2>/dev/null | head -1)
    if [[ -n "$match" ]]; then
        printf '%s' "$match"; return
    fi

    return 1
}

# ---------------------------------------------------------------------------
# Thinker discovery
# ---------------------------------------------------------------------------

# List thinker directories (skip _lib and other non-thinker dirs)
_list_thinker_dirs() {
    local dir
    for dir in "$THINKERS_DIR"/*/; do
        [[ -d "$dir" ]] || continue
        local name
        name=$(basename "$dir")
        # Skip internal directories
        [[ "$name" == _* ]] && continue
        # Must have step and subscriptions.jsonl
        [[ -f "$dir/step" && -f "$dir/subscriptions.jsonl" ]] || continue
        printf '%s\n' "$dir"
    done
}

# ---------------------------------------------------------------------------
# Dispatcher
# ---------------------------------------------------------------------------

_start_dispatcher() {
    local run_dir="$IDENTITY_DIR/run"
    mkdir -p "$run_dir/logs" "$run_dir/thinkers"

    local fifo="$run_dir/dispatch.fifo"
    local pid_file="$run_dir/dispatcher.pid"
    local tail_pids_file="$run_dir/tail_pids"

    # Check if dispatcher already running
    if [[ -f "$pid_file" ]]; then
        local old_pid
        old_pid=$(cat "$pid_file" 2>/dev/null) || true
        if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null; then
            die "Dispatcher already running (PID $old_pid). Use \`thinkers stop\` first."
        fi
        rm -f "$pid_file"
    fi

    # Create FIFO
    rm -f "$fifo"
    mkfifo "$fifo"

    # Build subscription map: thinker_name -> [traj_file, types_pattern, trigger_self]
    # We store this as lines: THINKER_NAME\tTRAJ_FILE\tTYPES_REGEX\tTRIGGER_SELF
    local sub_map=""
    local traj_files=""
    local thinker_dir
    while IFS= read -r thinker_dir; do
        local thinker_name
        thinker_name=$(basename "$thinker_dir")
        local sub_file="$thinker_dir/subscriptions.jsonl"

        while IFS= read -r sub_line; do
            [[ -z "$sub_line" ]] && continue

            # Parse subscription JSON
            local sub_traj_id sub_types sub_trigger_self
            sub_traj_id=$(printf '%s' "$sub_line" | jq -r '.traj_id // empty' 2>/dev/null) || true
            sub_types=$(printf '%s' "$sub_line" | jq -r '(.types // []) | join("|")' 2>/dev/null) || true
            sub_trigger_self=$(printf '%s' "$sub_line" | jq -r '.trigger_self // false' 2>/dev/null) || true

            # Default traj_id to $TRAJ_ID
            if [[ -z "$sub_traj_id" ]]; then sub_traj_id="$TRAJ_ID"; fi

            # Resolve traj file path (handles UUID → directory/flat file)
            local traj_file
            traj_file=$(_resolve_traj_file "$TRAJ_DIR" "$sub_traj_id") || {
                debug "Traj file not found for $thinker_name: $TRAJ_DIR/$sub_traj_id (skipping subscription)"
                continue
            }

            # Track unique traj files for tail processes (newline-separated)
            case "$traj_files" in
                *"$traj_file"*) ;;
                *) traj_files="${traj_files}${traj_files:+
}${traj_file}" ;;
            esac

            sub_map="${sub_map}${thinker_name}	${traj_file}	${sub_types}	${sub_trigger_self}
"
        done < "$sub_file"
    done < <(_list_thinker_dirs)

    if [[ -z "$sub_map" ]]; then
        rm -f "$fifo"
        die "No valid subscriptions found"
    fi

    # Write subscription map and traj files list for the dispatcher
    printf '%s' "$sub_map" > "$run_dir/sub_map"
    printf '%s\n' "$traj_files" > "$run_dir/traj_files"

    # Export env for dispatcher subprocess
    export IDENTITY_DIR IDENTITY_NAME MEM_DIR SKILLS_DIR SKILLS_KERNEL_DIR
    export TRAJ_DIR TRAJ_ID THINKERS_DIR SHELLM_HOME THINK_MODEL THINK_CONTEXT_TAIL
    export THINKERS_MAX_CONCURRENT

    # Start dispatcher in background
    (
        trap '_cleanup_dispatcher' EXIT
        trap '_cleanup_dispatcher; exit 130' INT TERM

        # Start tail -F for each unique traj file, tagged with traj path
        printf '' > "$tail_pids_file"
        local _traj_file
        while IFS= read -r _traj_file; do
            [[ -z "$_traj_file" ]] && continue
            [[ -f "$_traj_file" ]] || continue

            # Tag each line with the traj file path
            tail -n 0 -F "$_traj_file" 2>/dev/null | while IFS= read -r line; do
                printf '%s\t%s\n' "$_traj_file" "$line"
            done > "$fifo" &
            printf '%s\n' "$!" >> "$tail_pids_file"
        done < "$run_dir/traj_files"

        # Track thinker step PIDs as "name:pid" pairs (space-separated, bash 3.2 compat)
        _step_entries=""

        # Reap finished entries; print count of still-active ones
        _count_active_steps() {
            local _count=0 _entry
            local _new=""
            for _entry in $_step_entries; do
                local _pid="${_entry#*:}"
                if kill -0 "$_pid" 2>/dev/null; then
                    _count=$((_count + 1))
                    _new="${_new}${_new:+ }${_entry}"
                fi
            done
            _step_entries="$_new"
            printf '%d' "$_count"
        }

        # Check if a thinker already has a running step
        _thinker_busy() {
            local _check_name="$1" _entry
            for _entry in $_step_entries; do
                local _ename="${_entry%%:*}" _epid="${_entry#*:}"
                if [[ "$_ename" == "$_check_name" ]] && kill -0 "$_epid" 2>/dev/null; then
                    return 0
                fi
            done
            return 1
        }

        # Main dispatch loop: read from FIFO
        while IFS=$'\t' read -r _traj_file _step_json; do
            if [[ -z "$_step_json" ]]; then continue; fi

            # Parse step
            _step_type=$(printf '%s' "$_step_json" | jq -r '.type // empty' 2>/dev/null) || continue
            _step_source=$(printf '%s' "$_step_json" | jq -r '.source // empty' 2>/dev/null) || true

            if [[ -z "$_step_type" ]]; then continue; fi

            printf '[dispatcher] step: type=%s source=%s\n' "$_step_type" "$_step_source" >&2

            # Find matching thinkers by scanning sub_map
            while IFS=$'\t' read -r _name _straj _stypes _sself; do
                if [[ -z "$_name" ]]; then continue; fi

                # Check traj match
                if [[ "$_straj" != "$_traj_file" ]]; then continue; fi

                # Check type match (empty means all types)
                if [[ -n "$_stypes" ]]; then
                    _matched=0
                    _old_ifs="$IFS"
                    IFS='|'
                    for _t in $_stypes; do
                        if [[ "$_t" == "$_step_type" ]]; then _matched=1; break; fi
                    done
                    IFS="$_old_ifs"
                    if [[ "$_matched" -eq 0 ]]; then continue; fi
                fi

                # Self-trigger check
                if [[ "$_step_source" == "$_name" && "$_sself" != "true" ]]; then
                    printf '[dispatcher]   skip %s (self-trigger)\n' "$_name" >&2
                    continue
                fi

                # Check if thinker is active
                if ! grep -qx "$_name" "$run_dir/active_thinkers" 2>/dev/null; then
                    continue
                fi

                # Per-thinker concurrency: skip if this thinker already has a step running
                if _thinker_busy "$_name"; then
                    printf '[dispatcher]   skip %s (already running)\n' "$_name" >&2
                    continue
                fi

                # Global concurrency limit
                while true; do
                    _active=$(_count_active_steps)
                    if [[ "$_active" -lt "$THINKERS_MAX_CONCURRENT" ]]; then
                        break
                    fi
                    sleep 0.5
                done

                # Run thinker step in background
                _step_script="$THINKERS_DIR/$_name/step"
                _log_file="$run_dir/logs/$_name.log"
                printf '[dispatcher]   dispatch -> %s (active=%s)\n' "$_name" "$_active" >&2
                (
                    printf '%s' "$_step_json" | "$_step_script"
                ) >> "$_log_file" 2>&1 &
                _step_entries="${_step_entries}${_step_entries:+ }${_name}:$!"
                printf '%s %s\n' "$!" "$_name" >> "$run_dir/step_pids"
            done < "$run_dir/sub_map"
        done < "$fifo"
    ) >> "$run_dir/logs/dispatcher.log" 2>&1 &

    local dispatcher_pid=$!
    printf '%s' "$dispatcher_pid" > "$pid_file"
    debug "Dispatcher started (PID $dispatcher_pid)"
    printf '%s' "$dispatcher_pid"
}

_cleanup_dispatcher() {
    local run_dir="$IDENTITY_DIR/run"
    local tail_pids_file="$run_dir/tail_pids"
    local fifo="$run_dir/dispatch.fifo"

    # Kill tail processes
    if [[ -f "$tail_pids_file" ]]; then
        while IFS= read -r pid; do
            [[ -n "$pid" ]] && kill "$pid" 2>/dev/null || true
        done < "$tail_pids_file"
        rm -f "$tail_pids_file"
    fi

    # Remove FIFO
    rm -f "$fifo"

    # Clean up sub_map and traj_files
    rm -f "$run_dir/sub_map" "$run_dir/traj_files"
}

_stop_dispatcher() {
    local run_dir="$IDENTITY_DIR/run"
    local pid_file="$run_dir/dispatcher.pid"

    # Stop dispatcher process
    if [[ -f "$pid_file" ]]; then
        local pid
        pid=$(cat "$pid_file" 2>/dev/null) || true
        if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
            printf 'Stopping dispatcher (PID %s)...\n' "$pid" >&2
            kill -TERM "$pid" 2>/dev/null || true
            local i
            for i in 1 2 3 4 5 6 7 8; do
                kill -0 "$pid" 2>/dev/null || break
                sleep 0.25
            done
            if kill -0 "$pid" 2>/dev/null; then
                kill -KILL "$pid" 2>/dev/null || true
            fi
            printf 'Dispatcher stopped.\n' >&2
        else
            printf 'Dispatcher not running (cleaned up stale PID).\n' >&2
        fi
        rm -f "$pid_file"
    else
        printf 'No dispatcher running.\n' >&2
    fi

    # Kill tail processes
    local tail_pids_file="$run_dir/tail_pids"
    if [[ -f "$tail_pids_file" ]]; then
        local tail_pid
        while IFS= read -r tail_pid; do
            [[ -n "$tail_pid" ]] && kill "$tail_pid" 2>/dev/null || true
        done < "$tail_pids_file"
        rm -f "$tail_pids_file"
    fi

    # Clean up FIFO, sub_map, traj_files
    rm -f "$run_dir/dispatch.fifo" "$run_dir/sub_map" "$run_dir/traj_files"
}

# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

cmd_start() {
    _require_env

    local name="${1:-}"
    local run_dir="$IDENTITY_DIR/run"
    mkdir -p "$run_dir"

    if [[ -n "$name" ]]; then
        # --- Start individual thinker ---
        local thinker_dir="$THINKERS_DIR/$name"
        [[ -d "$thinker_dir" ]] || die "Thinker not found: $name"
        [[ -f "$thinker_dir/step" && -f "$thinker_dir/subscriptions.jsonl" ]] || \
            die "Thinker '$name' missing step or subscriptions.jsonl"

        # Add to active_thinkers if not already there
        if ! grep -qx "$name" "$run_dir/active_thinkers" 2>/dev/null; then
            printf '%s\n' "$name" >> "$run_dir/active_thinkers"
        fi

        # Run start script if present
        if [[ -x "$thinker_dir/start" ]]; then
            "$thinker_dir/start" || printf 'Warning: %s start script failed\n' "$name" >&2
            if [[ -f "$thinker_dir/pid" ]]; then
                mkdir -p "$run_dir/thinkers"
                cp "$thinker_dir/pid" "$run_dir/thinkers/$name.pid"
            fi
        fi

        # Start dispatcher if not running
        local pid_file="$run_dir/dispatcher.pid"
        local need_dispatcher=1
        if [[ -f "$pid_file" ]]; then
            local old_pid
            old_pid=$(cat "$pid_file" 2>/dev/null) || true
            if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null; then
                need_dispatcher=0
            fi
        fi

        if [[ "$need_dispatcher" -eq 1 ]]; then
            printf 'Starting dispatcher...\n' >&2
            local dispatcher_pid
            dispatcher_pid=$(_start_dispatcher)
            printf 'Dispatcher started (PID %s)\n' "$dispatcher_pid" >&2
        fi

        # Kick the thinker once to start the loop (dispatcher only sees new steps)
        local trigger_json
        trigger_json=$(jq -nc --arg ts "$(date -u +%Y-%m-%dT%H:%M:%S%z)" \
            '{type:"manual-trigger", source:"thinkers-cli", ts:$ts}')
        (printf '%s' "$trigger_json" | "$thinker_dir/step") \
            >> "$run_dir/logs/$name.log" 2>&1 &

        printf 'Started thinker: %s\n' "$name" >&2
    else
        # --- Start all thinkers ---

        # Write all thinker names to active_thinkers and call start scripts
        : > "$run_dir/active_thinkers"
        local thinker_dir
        while IFS= read -r thinker_dir; do
            local name_all
            name_all=$(basename "$thinker_dir")
            printf '%s\n' "$name_all" >> "$run_dir/active_thinkers"
            if [[ -x "$thinker_dir/start" ]]; then
                printf 'Starting thinker: %s\n' "$name_all" >&2
                "$thinker_dir/start" || printf 'Warning: %s start script failed\n' "$name_all" >&2
                if [[ -f "$thinker_dir/pid" ]]; then
                    mkdir -p "$run_dir/thinkers"
                    cp "$thinker_dir/pid" "$run_dir/thinkers/$name_all.pid"
                fi
            fi
        done < <(_list_thinker_dirs)

        # Start dispatcher
        printf 'Starting dispatcher...\n' >&2
        local dispatcher_pid
        dispatcher_pid=$(_start_dispatcher)

        # Show status
        local thinker_count=0
        while IFS= read -r _; do
            thinker_count=$((thinker_count + 1))
        done < <(_list_thinker_dirs)

        printf '\n' >&2
        printf 'Identity:    %s\n' "$IDENTITY_NAME" >&2
        printf 'Dispatcher:  running (PID %s)\n' "$dispatcher_pid" >&2
        printf 'Thinkers:    %d\n' "$thinker_count" >&2
        printf 'Concurrency: %s\n' "$THINKERS_MAX_CONCURRENT" >&2
        printf 'Logs:        %s/run/logs/\n' "$IDENTITY_DIR" >&2
    fi
}

cmd_stop() {
    _require_env

    local name="${1:-}"
    local run_dir="$IDENTITY_DIR/run"

    if [[ -n "$name" ]]; then
        # --- Stop individual thinker ---
        local thinker_dir="$THINKERS_DIR/$name"
        [[ -d "$thinker_dir" ]] || die "Thinker not found: $name"

        # Remove from active_thinkers
        if [[ -f "$run_dir/active_thinkers" ]]; then
            grep -vx "$name" "$run_dir/active_thinkers" > "$run_dir/active_thinkers.tmp" 2>/dev/null || true
            mv "$run_dir/active_thinkers.tmp" "$run_dir/active_thinkers"
        fi

        # Kill running steps for this thinker
        local step_pids_file="$run_dir/step_pids"
        if [[ -f "$step_pids_file" ]]; then
            local step_pid _step_name
            while read -r step_pid _step_name; do
                if [[ "$_step_name" == "$name" && -n "$step_pid" ]] && kill -0 "$step_pid" 2>/dev/null; then
                    _kill_tree "$step_pid" TERM
                fi
            done < "$step_pids_file"
        fi

        # Run stop script if present
        if [[ -x "$thinker_dir/stop" ]]; then
            "$thinker_dir/stop" || true
        fi
        rm -f "$run_dir/thinkers/$name.pid"

        # If no active thinkers left, stop dispatcher entirely
        local remaining
        remaining=$(grep -c . "$run_dir/active_thinkers" 2>/dev/null) || remaining=0
        if [[ "$remaining" -eq 0 ]]; then
            printf 'No active thinkers remain — stopping dispatcher.\n' >&2
            _stop_dispatcher
        fi

        printf 'Stopped thinker: %s\n' "$name" >&2
        return
    fi

    # --- Stop all (no name given) ---
    _stop_dispatcher

    # Kill in-flight step processes (and their entire process trees)
    local step_pids_file="$run_dir/step_pids"
    if [[ -f "$step_pids_file" ]]; then
        local step_pid _step_name
        local killed=0
        while read -r step_pid _step_name; do
            if [[ -n "$step_pid" ]] && kill -0 "$step_pid" 2>/dev/null; then
                _kill_tree "$step_pid" TERM
                killed=$((killed + 1))
            fi
        done < "$step_pids_file"
        if [[ "$killed" -gt 0 ]]; then
            printf 'Killed %d in-flight step process(es).\n' "$killed" >&2
            # Give them a moment, then force-kill survivors
            sleep 1
            while read -r step_pid _step_name; do
                if [[ -n "$step_pid" ]] && kill -0 "$step_pid" 2>/dev/null; then
                    _kill_tree "$step_pid" KILL
                fi
            done < "$step_pids_file"
        fi
        rm -f "$step_pids_file"
    fi

    # Call stop scripts on thinkers that have them
    local thinker_dir
    while IFS= read -r thinker_dir; do
        local name_all
        name_all=$(basename "$thinker_dir")
        if [[ -x "$thinker_dir/stop" ]]; then
            printf 'Stopping thinker: %s\n' "$name_all" >&2
            "$thinker_dir/stop" || true
        fi
        # Clean up thinker PIDs
        rm -f "$run_dir/thinkers/$name_all.pid"
    done < <(_list_thinker_dirs)

    rm -f "$run_dir/active_thinkers"
    printf 'All thinkers stopped.\n' >&2
}

cmd_status() {
    _require_env

    local run_dir="$IDENTITY_DIR/run"
    local pid_file="$run_dir/dispatcher.pid"

    printf 'Identity:   %s\n' "$IDENTITY_NAME"

    # Dispatcher status
    local dispatcher_state="stopped"
    if [[ -f "$pid_file" ]]; then
        local pid
        pid=$(cat "$pid_file" 2>/dev/null) || true
        if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
            dispatcher_state="running (PID $pid)"
        fi
    fi
    printf 'Dispatcher: %s\n' "$dispatcher_state"
    if [[ "$dispatcher_state" != "stopped" ]]; then
        printf 'Concurrency: %s max\n' "$THINKERS_MAX_CONCURRENT"
    fi
    printf '\n'

    # Determine if dispatcher is alive for thinker status labels
    local dispatcher_running=0
    if [[ "$dispatcher_state" != "stopped" ]]; then
        dispatcher_running=1
    fi

    # Build map of active step processes per thinker
    local step_pids_file="$run_dir/step_pids"
    # Associative-style tracking using name matching (bash 3.2 compat)
    local _active_steps=""
    if [[ -f "$step_pids_file" ]]; then
        local _sp _sn
        while read -r _sp _sn; do
            if [[ -n "$_sp" ]] && kill -0 "$_sp" 2>/dev/null; then
                _active_steps="${_active_steps}${_active_steps:+ }${_sn}"
            fi
        done < "$step_pids_file"
    fi

    # Per-thinker status
    printf 'Thinkers:\n'
    local thinker_dir
    while IFS= read -r thinker_dir; do
        local name
        name=$(basename "$thinker_dir")
        local status
        if [[ "$dispatcher_running" -eq 0 ]] || ! grep -qx "$name" "$run_dir/active_thinkers" 2>/dev/null; then
            status="stopped"
        else
            # Count active step processes for this thinker
            local _step_count=0
            local _w
            for _w in $_active_steps; do
                if [[ "$_w" == "$name" ]]; then
                    _step_count=$((_step_count + 1))
                fi
            done
            if [[ "$_step_count" -gt 0 ]]; then
                status="active (${_step_count} step(s))"
            else
                status="idle"
            fi
        fi

        # Check if thinker has a running start process
        local thinker_pid_file="$run_dir/thinkers/$name.pid"
        if [[ -f "$thinker_pid_file" ]]; then
            local tpid
            tpid=$(cat "$thinker_pid_file" 2>/dev/null) || true
            if [[ -n "$tpid" ]] && kill -0 "$tpid" 2>/dev/null; then
                status="running (PID $tpid)"
            fi
        fi

        # Read subscription types
        local types="all"
        if [[ -f "$thinker_dir/subscriptions.jsonl" ]]; then
            types=$(head -1 "$thinker_dir/subscriptions.jsonl" | jq -r '(.types // ["all"]) | join(", ")' 2>/dev/null) || types="all"
        fi

        # Log size
        local log_info=""
        local log_file="$run_dir/logs/$name.log"
        if [[ -f "$log_file" ]]; then
            local log_lines
            log_lines=$(wc -l < "$log_file" 2>/dev/null | tr -d ' ') || log_lines=0
            log_info=" (${log_lines} log lines)"
        fi

        printf '  %-30s %s  [%s]%s\n' "$name" "$status" "$types" "$log_info"
    done < <(_list_thinker_dirs)
}

cmd_list() {
    _require_env

    local thinker_dir
    while IFS= read -r thinker_dir; do
        [[ -z "$thinker_dir" ]] && continue
        local name
        name=$(basename "$thinker_dir")

        # Read subscription info
        local types="all"
        local trigger_self="false"
        if [[ -f "$thinker_dir/subscriptions.jsonl" ]]; then
            types=$(head -1 "$thinker_dir/subscriptions.jsonl" | jq -r '(.types // ["all"]) | join(", ")' 2>/dev/null) || types="all"
            trigger_self=$(head -1 "$thinker_dir/subscriptions.jsonl" | jq -r '.trigger_self // false' 2>/dev/null) || trigger_self="false"
        fi

        # Check for optional files
        local extras=""
        [[ -f "$thinker_dir/prompt.md" ]] && extras="${extras} prompt.md"
        [[ -x "$thinker_dir/start" ]] && extras="${extras} start"
        [[ -x "$thinker_dir/stop" ]] && extras="${extras} stop"

        printf '%-30s types=[%s]' "$name" "$types"
        [[ "$trigger_self" == "true" ]] && printf '  trigger_self=true'
        [[ -n "$extras" ]] && printf '  files:%s' "$extras"
        printf '\n'
    done < <(_list_thinker_dirs)
}

cmd_new() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: thinkers new <name>"

    _require_env

    # Validate name
    if [[ ! "$name" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
        die "Invalid thinker name: '$name' (use lowercase alphanumeric + hyphens)"
    fi

    local thinker_dir="$THINKERS_DIR/$name"
    [[ -d "$thinker_dir" ]] && die "Thinker '$name' already exists at $thinker_dir"

    mkdir -p "$thinker_dir"

    # Create step script
    cat > "$thinker_dir/step" <<STEP
#!/usr/bin/env bash
set -euo pipefail

# ${name}/step — Custom thinker
# Receives step JSON on stdin. Identity env vars are set.

THINKER_NAME="$name"
SCRIPT_DIR="\$(cd "\$(dirname "\$(realpath "\$0")")" && pwd)"

# shellcheck disable=SC1091
source "\$SCRIPT_DIR/../_lib/common.sh"

_require_env

THINK_MODEL="\${THINK_MODEL:-\${SHELLM_MODEL:-claude-opus-4-7}}"

# Read the triggering step from stdin
step_json=\$(cat)

# TODO: Implement your thinker logic here
# Example: load prompt, get context, call shellm
#
# prompt_file="\$SCRIPT_DIR/prompt.md"
# goals=\$(get_goals "\$MEM_DIR")
# tp_prompt=\$(load_prompt "\$prompt_file" "\$IDENTITY_NAME" "\$goals")
# ...

printf '[%s] step received (type=%s)\n' "\$THINKER_NAME" \\
    "\$(printf '%s' "\$step_json" | jq -r '.type // "unknown"' 2>/dev/null)" >&2
STEP
    chmod +x "$thinker_dir/step"

    # Create subscriptions
    cat > "$thinker_dir/subscriptions.jsonl" <<'SUBS'
{"types":["thought","action","observation"]}
SUBS

    # Create prompt template
    cat > "$thinker_dir/prompt.md" <<PROMPT
You are the "$name" process for {{identity_name}}. Your job is to [describe what this thinker does].

## Triage

First, check recent thoughts:
\`\`\`bash
traj tail -n 10
\`\`\`

If there is nothing for you to do, output an empty FINAL and stop.

## If you should run

[Describe what the thinker does when it should run]

Write a tp-thought:
\`\`\`bash
printf '{"type":"tp-thought","content":%s,"source":"$name"}' \\
  "\$(printf '%s' "Your thought here" | jq -Rsa .)" \\
  | traj append
\`\`\`

Your FINAL output should summarize what you did, or empty if you triaged out.
PROMPT

    printf 'Created thinker: %s\n' "$name" >&2
    printf 'Directory: %s\n' "$thinker_dir" >&2
    printf 'Files:\n' >&2
    printf '  step                  (executable — implement your logic)\n' >&2
    printf '  subscriptions.jsonl   (edit to change which step types trigger this thinker)\n' >&2
    printf '  prompt.md             (prompt template — edit for your use case)\n' >&2
}

# ---------------------------------------------------------------------------
# run — manually trigger a thinker's step script
# ---------------------------------------------------------------------------

cmd_step() {
    _require_env

    local name="${1:-}"
    [[ -n "$name" ]] || die "run requires <thinker-name>"

    local thinker_dir="$THINKERS_DIR/$name"
    [[ -d "$thinker_dir" ]] || die "Thinker not found: $name"
    [[ -x "$thinker_dir/step" ]] || die "No executable step script in $thinker_dir"

    local run_dir="$IDENTITY_DIR/run"
    mkdir -p "$run_dir/logs"
    local log_file="$run_dir/logs/$name.log"

    # Build a synthetic trigger step
    local trigger_json
    trigger_json=$(jq -nc --arg ts "$(date -u +%Y-%m-%dT%H:%M:%S%z)" \
        '{type:"manual-trigger", source:"thinkers-cli", ts:$ts}')

    printf 'Running %s/step ...\n' "$name" >&2
    printf '%s' "$trigger_json" | "$thinker_dir/step" 2>&1 | tee -a "$log_file"
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
    cat <<'EOF'
thinkers — Modular reactive thought process manager

Usage:
  thinkers start [name]        Start all thinkers (or one by name)
  thinkers stop [name]         Stop all thinkers (or one by name)
  thinkers status              Show dispatcher and per-thinker status
  thinkers list                List installed thinkers with subscriptions
  thinkers step <name>          Manually trigger a thinker's step
  thinkers new <name>          Scaffold a new thinker

Options:
  -v, --verbose   Verbose/debug mode
  -h, --help      Show this help

Environment (set by `identity shell`):
  IDENTITY_DIR, IDENTITY_NAME, MEM_DIR, SKILLS_DIR,
  SKILLS_KERNEL_DIR, TRAJ_DIR, TRAJ_ID, THINKERS_DIR,
  SHELLM_HOME, THINK_MODEL, THINK_CONTEXT_TAIL,
  THINKERS_MAX_CONCURRENT (default: 4)
EOF
    exit 0
}

# ---------------------------------------------------------------------------
# Argument parsing & dispatch
# ---------------------------------------------------------------------------

# Parse global flags
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage ;;
        -v|--verbose) VERBOSE=1; shift ;;
        -*) break ;;
        *) break ;;
    esac
done

cmd="${1:-}"
[[ -n "$cmd" ]] && shift

case "$cmd" in
    start)    cmd_start "$@" ;;
    stop)     cmd_stop "$@" ;;
    status)   cmd_status ;;
    list)     cmd_list ;;
    step)     cmd_step "$@" ;;
    new)      cmd_new "$@" ;;
    help)     usage ;;
    "")       usage ;;
    *)        die "Unknown command: $cmd (try thinkers --help)" ;;
esac
