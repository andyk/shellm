#!/usr/bin/env bash
set -euo pipefail

# context — Policy layer that reads a trajectory and outputs a JSON messages
# array with role assignment driven by flags.  The caller passes the output
# to `llm -M` and provides its own system prompt via `llm -s`.
#
# Rendering is a single jq pass over the trajectory (plus one prepass to
# discover blob refs), so cost stays flat as trajectories grow.

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------

CTX_HEAD="${CTX_HEAD:-1}"
CTX_TAIL="${CTX_TAIL:-50}"
CTX_PROMPT_LIMIT="${SHELLM_STDOUT_PROMPT_LIMIT:-2048}"
CTX_MAX_BYTES=""
CTX_ELISION_STYLE="count"  # none|count
CTX_PINS=()

CTX_ASSISTANT_TYPES=""
CTX_USER_TYPES=""
CTX_EXCLUDE_TYPES=""
CTX_TRAJ_DIR_OPT=""
CTX_TRAJ_ID_OPT=""

die() { printf 'context: error: %s\n' "$*" >&2; exit 1; }
usage() {
    cat <<'EOF'
Usage: context [options]

Reads a trajectory and outputs a JSON messages array to stdout.

Trajectory targeting:
  --traj_dir DIR        Trajectory directory.
  <ID>                  Trajectory ID (UUID or hex prefix, positional).
                        Falls back to $TRAJ_DIR + $TRAJ_ID env vars.

Role assignment:
  --assistant-types LIST  Step types that become {"role":"assistant"}.
  --user-types LIST       Step types that become {"role":"user"}.
  --exclude-types LIST    Step types to drop entirely.
  Unrecognized types (not in any list) default to "user" role.

Step selection:
  --head N              Keep first N steps. Default: 1.
  --tail N              Keep last N steps. Default: 50.
  --pin <step_id>       Always include this step. Repeatable.

Per-step content:
  --prompt-limit BYTES  Per-step field truncation for large values. Default: 2048.

Elision:
  --elision-style S     none|count. Default: count.

Budget:
  --max-bytes BYTES     Cap total output. Default: unset.

Output:
  A JSON array: [{"role":"user","content":"..."},{"role":"assistant","content":"..."},...]
  Consecutive messages with the same role are merged (Anthropic API requires alternation).

Environment:
  TRAJ_DIR + TRAJ_ID    Default trajectory if no flags given.

EOF
    exit "${1:-0}"
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

while [[ $# -gt 0 ]]; do
    case "$1" in
        --head)             CTX_HEAD="${2:?--head requires N}"; shift 2 ;;
        --tail)             CTX_TAIL="${2:?--tail requires N}"; shift 2 ;;
        --pin)              CTX_PINS+=("${2:?--pin requires step_id}"); shift 2 ;;
        --prompt-limit)     CTX_PROMPT_LIMIT="${2:?--prompt-limit requires BYTES}"; shift 2 ;;
        --elision-style)    CTX_ELISION_STYLE="${2:?--elision-style requires a value}"; shift 2 ;;
        --max-bytes)        CTX_MAX_BYTES="${2:?--max-bytes requires BYTES}"; shift 2 ;;
        --assistant-types)  CTX_ASSISTANT_TYPES="${2:?--assistant-types requires LIST}"; shift 2 ;;
        --user-types)       CTX_USER_TYPES="${2:?--user-types requires LIST}"; shift 2 ;;
        --exclude-types)    CTX_EXCLUDE_TYPES="${2:?--exclude-types requires LIST}"; shift 2 ;;
        --traj_dir)         CTX_TRAJ_DIR_OPT="${2:?--traj_dir requires DIR}"; shift 2 ;;
        -h|--help)          usage 0 ;;
        -*)                 die "unknown option: $1" ;;
        *)
            if [[ -z "$CTX_TRAJ_ID_OPT" ]]; then
                CTX_TRAJ_ID_OPT="$1"
            else
                die "unexpected argument: $1"
            fi
            shift; continue
            ;;
    esac
done

# ---------------------------------------------------------------------------
# Resolve trajectory file
# ---------------------------------------------------------------------------

# Priority: --traj_dir + positional ID > $TRAJ_DIR + $TRAJ_ID env vars
RESOLVED_TRAJ_FILE=""
RESOLVED_TRAJ_DIR=""

# Resolve traj_id within traj_dir (inline version matching traj's _resolve_traj_id)
_ctx_resolve_traj_id() {
    local traj_dir="$1" traj_id="$2"

    # 1. Exact path
    if [[ -f "$traj_dir/$traj_id" ]]; then
        printf '%s\n' "$traj_dir/$traj_id"; return
    fi

    # 2. Directory-based: $traj_dir/$traj_id/trajectory.jsonl
    if [[ -f "$traj_dir/$traj_id/trajectory.jsonl" ]]; then
        printf '%s\n' "$traj_dir/$traj_id/trajectory.jsonl"; return
    fi

    # 3. Legacy .jsonl suffix
    if [[ "$traj_id" != *.jsonl && -f "$traj_dir/${traj_id}.jsonl" ]]; then
        printf '%s\n' "$traj_dir/${traj_id}.jsonl"; return
    fi

    # 4. UUID handling: extract hex prefix
    local hex_prefix="$traj_id"
    if [[ "$traj_id" == *-*-*-*-* ]]; then
        hex_prefix="${traj_id%%-*}"
    fi

    # 5. Directory glob: find directories named <hex_prefix>-*
    local match
    match=$(find "$traj_dir" -type d -name "${hex_prefix}-*" 2>/dev/null | head -1)
    if [[ -n "$match" && -f "$match/trajectory.jsonl" ]]; then
        printf '%s\n' "$match/trajectory.jsonl"; return
    fi

    # 6. Legacy flat file glob: *_<hex_prefix>_*.jsonl
    match=$(find "$traj_dir" -name "*_${hex_prefix}_*.jsonl" -not -path '*/blobs/*' 2>/dev/null | head -1)
    if [[ -n "$match" ]]; then
        printf '%s\n' "$match"; return
    fi
    return 1
}

if [[ -n "$CTX_TRAJ_DIR_OPT" && -n "$CTX_TRAJ_ID_OPT" ]]; then
    RESOLVED_TRAJ_DIR="$CTX_TRAJ_DIR_OPT"
    RESOLVED_TRAJ_FILE=$(_ctx_resolve_traj_id "$CTX_TRAJ_DIR_OPT" "$CTX_TRAJ_ID_OPT") \
        || die "cannot resolve traj ID '$CTX_TRAJ_ID_OPT' in '$CTX_TRAJ_DIR_OPT'"
elif [[ -n "${TRAJ_DIR:-}" && -n "${TRAJ_ID:-}" ]]; then
    RESOLVED_TRAJ_DIR="$TRAJ_DIR"
    RESOLVED_TRAJ_FILE=$(_ctx_resolve_traj_id "$TRAJ_DIR" "$TRAJ_ID") \
        || die "cannot resolve TRAJ_ID '$TRAJ_ID' in TRAJ_DIR '$TRAJ_DIR'"
else
    die "No trajectory specified. Use --traj_dir DIR <ID>, or set TRAJ_DIR + TRAJ_ID env vars."
fi

[[ -f "$RESOLVED_TRAJ_FILE" ]] || die "trajectory not found: $RESOLVED_TRAJ_FILE"

# ---------------------------------------------------------------------------
# Always exclude shellm-run and run-summary from context rendering
# ---------------------------------------------------------------------------

# Append to exclude types (don't override user's --exclude-types)
if [[ -n "$CTX_EXCLUDE_TYPES" ]]; then
    CTX_EXCLUDE_TYPES="${CTX_EXCLUDE_TYPES},shellm-run,run-summary"
else
    CTX_EXCLUDE_TYPES="shellm-run,run-summary"
fi

# ---------------------------------------------------------------------------
# The jq program
#
# Two modes:
#   refs   — print blob refs (stdout_ref/stderr_ref) of selected, non-excluded
#            steps, one per line, so bash can load the blob files.
#   render — print the row total, then the pretty-printed messages array.
#
# Semantics mirror the original bash implementation, including its
# command-substitution behavior (trailing newlines stripped from every
# rendered value).
# ---------------------------------------------------------------------------

JQ_PROG=$(cat <<'JQEOF'
def rtrim: sub("\n+$"; "");

def rep($s; $n): if $n <= 0 then "" else ($s * $n) end;

# Pretty-print a JSON value the way `jq -r` prints non-string values
# (default jq pretty format: 2-space indent).
def pp:
  def go($d):
    if type == "object" then
      if length == 0 then "{}"
      else "{\n"
        + ([to_entries[] | rep("  "; $d+1) + (.key | tojson) + ": " + (.value | go($d+1))] | join(",\n"))
        + "\n" + rep("  "; $d) + "}"
      end
    elif type == "array" then
      if length == 0 then "[]"
      else "[\n"
        + ([.[] | rep("  "; $d+1) + go($d+1)] | join(",\n"))
        + "\n" + rep("  "; $d) + "]"
      end
    else tojson end;
  go(0);

# Equivalent of val=$(printf row | jq -r '.key // empty'):
# null/false -> "", non-strings stringified, trailing newlines stripped by $().
def jqr_empty:
  if . == null or . == false then ""
  elif type == "string" then .
  elif type == "object" or type == "array" then pp
  else tostring
  end;

# Byte-aware truncation helpers (limit is in UTF-8 bytes).
def btrunc_head($n):
  if utf8bytelength <= $n then .
  else .[0:$n] | until(utf8bytelength <= $n; .[0:length-1])
  end;
def btrunc_tail($n):
  if utf8bytelength <= $n then .
  else (if length > $n then .[length-$n:] else . end) | until(utf8bytelength <= $n; .[1:])
  end;

def truncate_field($limit; $sid):
  utf8bytelength as $vb |
  if $vb <= $limit then .
  elif $limit <= 1 then "[... truncated: \($vb) bytes total. read with: traj show \($sid) --full]"
  else
    ([($limit / 2 | floor), 1] | max) as $half |
    ((btrunc_head($half) | rtrim)
     + "\n[... truncated: \($vb) bytes total. read with: traj show \($sid) --full]\n"
     + (btrunc_tail($half) | rtrim))
  end;

# Metadata keys skipped when rendering step content.
def is_meta($k):
  ($k == "step_id" or $k == "ts" or $k == "type" or $k == "fork_parent")
  or ($k | endswith("_ref"))
  or ($k | endswith("_bytes"))
  or ($k | endswith("_truncated"));

def role_for($t; $A; $U; $E):
  if ($E | index($t)) != null then "exclude"
  elif ($A | index($t)) != null then "assistant"
  elif ($U | index($t)) != null then "user"
  else "user"
  end;

def selected($i; $sid; $N; $head; $tail; $pins):
  ($i < $head) or ($i >= ($N - $tail)) or (($pins | index($sid)) != null);

# Render one step row into message text content.
def render_step($limit; $blobs):
  . as $row |
  ($row.step_id | tostring) as $sid |
  (($row.type // "") | tostring) as $t |
  if $t == "fork" then "[Forked child: \($row.child | jqr_empty)]"
  elif $t == "trajectory" then ""
  elif $t == "merge" then
    ($row.from_branch | jqr_empty) as $b |
    ($row.content | jqr_empty) as $c |
    if $c != "" then "[Merged from \($b): \($c)]" else "[Merged from \($b)]" end
  else
    # Load blob content for truncated stdout/stderr.
    (reduce ("stdout", "stderr") as $f ($row;
        (.[$f + "_ref"] // "") as $ref |
        if ($ref | type) == "string" and $ref != "" and ($blobs | has($ref)) then
            .[$f] = ($blobs[$ref] | rtrim) | del(.[$f + "_truncated"])
        else .
        end
    )) as $row2 |
    ($row2 | keys | map(select(is_meta(.) | not))) as $cks |
    ($cks | length) as $nc |
    reduce $cks[] as $k ("";
        . as $acc |
        ($row2[$k] | jqr_empty | rtrim) as $v0 |
        if $v0 == "" then $acc
        else
            ($v0 | if utf8bytelength > $limit then truncate_field($limit; $sid) else . end) as $v |
            if $nc == 1 then $v
            elif $k == "cmd" then $acc + "```bash\n" + $v + "\n```\n\n"
            elif $k == "thought" then $acc + $v + "\n\n"
            else $acc + "[" + $k + "]\n" + $v + "\n\n"
            end
        end
    )
  end;

def build_messages($rows; $limit; $blobs; $head; $tail; $pins; $A; $U; $E; $elision):
  ($rows | length) as $N |
  reduce range(0; $N) as $i ({msgs: [], el: 0};
      $rows[$i] as $r |
      (($r.type // "") | tostring) as $t |
      role_for($t; $A; $U; $E) as $role |
      if $role == "exclude" then .
      elif selected($i; ($r.step_id | tostring); $N; $head; $tail; $pins) then
          (if .el > 0 and $elision != "none" then
              {msgs: (.msgs + [{role: "user", content: "[\(.el) steps elided]"}]), el: 0}
           else . end) as $st |
          ($r | render_step($limit; $blobs) | rtrim) as $c |
          if $c == "" then $st
          else {msgs: ($st.msgs + [{role: $role, content: $c}]), el: 0}
          end
      else .el += 1
      end
  ) |
  (if .el > 0 and $elision != "none" then
      .msgs + [{role: "user", content: "[\(.el) steps elided]"}]
   else .msgs end);

# Merge consecutive same-role messages (Anthropic API requires alternation).
def merge_roles:
  reduce .[] as $msg ([];
      if (length > 0) and (.[-1].role == $msg.role) then
          .[-1].content += ("\n---\n" + $msg.content)
      else . + [$msg]
      end
  );

# --- main ---
($astr | if . == "" then [] else split(",") end) as $A |
($ustr | if . == "" then [] else split(",") end) as $U |
($estr | if . == "" then [] else split(",") end) as $E |
($blobsraw[0] // {}) as $blobs |
(split("\n")
 | map(fromjson? // null)
 | map(select(. != null))
 | map(select(((.step_id // "") | tostring) != ""))) as $rows |
($rows | length) as $N |
if $mode == "refs" then
    [ range(0; $N) as $i |
      $rows[$i] |
      select(role_for(((.type // "") | tostring); $A; $U; $E) != "exclude") |
      select(selected($i; (.step_id | tostring); $N; $head; $tail; $pins)) |
      ((.stdout_ref // empty), (.stderr_ref // empty)) |
      select((type == "string") and . != "")
    ] | unique | .[]
else
    $N,
    (build_messages($rows; $limit; $blobs; $head; $tail; $pins; $A; $U; $E; $elision) | merge_roles)
end
JQEOF
)

# ---------------------------------------------------------------------------
# Load trajectory rows once
# ---------------------------------------------------------------------------

RAW_ROWS=$(traj cat --raw --traj_dir "$RESOLVED_TRAJ_DIR" "${RESOLVED_TRAJ_FILE#$RESOLVED_TRAJ_DIR/}" 2>/dev/null) || RAW_ROWS=""

# Pins as a JSON array
PINS_JSON='[]'
if [[ ${#CTX_PINS[@]} -gt 0 ]]; then
    PINS_JSON=$(printf '%s\n' "${CTX_PINS[@]}" | jq -R . | jq -s -c .)
fi

_ctx_jq() {
    # _ctx_jq <mode> <prompt_limit> <blobs_file>
    printf '%s\n' "$RAW_ROWS" | jq -R -s -r \
        --arg mode "$1" \
        --argjson head "$CTX_HEAD" \
        --argjson tail "$CTX_TAIL" \
        --argjson limit "$2" \
        --argjson pins "$PINS_JSON" \
        --arg astr "$CTX_ASSISTANT_TYPES" \
        --arg ustr "$CTX_USER_TYPES" \
        --arg estr "$CTX_EXCLUDE_TYPES" \
        --arg elision "$CTX_ELISION_STYLE" \
        --slurpfile blobsraw "$3" \
        "$JQ_PROG"
}

# ---------------------------------------------------------------------------
# Blob prepass: load stdout/stderr blob files referenced by selected steps
# ---------------------------------------------------------------------------

BLOBS_FILE=/dev/null
_BLOBS_TMP=""
cleanup() { if [[ -n "$_BLOBS_TMP" ]]; then rm -f "$_BLOBS_TMP"; fi; }
trap cleanup EXIT

_blob_base="$(dirname "$RESOLVED_TRAJ_FILE")"
_refs=$(_ctx_jq refs "$CTX_PROMPT_LIMIT" /dev/null)
if [[ -n "$_refs" ]]; then
    _blobs_json='{}'
    while IFS= read -r _ref; do
        [[ -n "$_ref" && -f "$_blob_base/$_ref" ]] || continue
        _blobs_json=$(printf '%s' "$_blobs_json" \
            | jq --arg k "$_ref" --rawfile v "$_blob_base/$_ref" '. + {($k): $v}')
    done <<< "$_refs"
    if [[ "$_blobs_json" != '{}' ]]; then
        _BLOBS_TMP=$(mktemp)
        printf '%s' "$_blobs_json" > "$_BLOBS_TMP"
        BLOBS_FILE="$_BLOBS_TMP"
    fi
fi

# ---------------------------------------------------------------------------
# Render (with optional --max-bytes budget enforcement)
# ---------------------------------------------------------------------------

# render_at <prompt_limit>: sets RENDER_TOTAL and RENDER_MSGS
render_at() {
    local out
    out=$(_ctx_jq render "$1" "$BLOBS_FILE")
    RENDER_TOTAL="${out%%$'\n'*}"
    RENDER_MSGS="${out#*$'\n'}"
}

render_at "$CTX_PROMPT_LIMIT"

if [[ "$RENDER_TOTAL" -eq 0 ]]; then
    # Empty trajectory: output empty messages array.
    printf '[]\n'
    exit 0
fi

result="$RENDER_MSGS"

if [[ -z "$CTX_MAX_BYTES" ]]; then
    printf '%s' "$result"
    exit 0
fi

result_bytes=$(printf '%s' "$result" | LC_ALL=C wc -c | tr -d ' ')

if [[ "$result_bytes" -le "$CTX_MAX_BYTES" ]]; then
    printf '%s' "$result"
    exit 0
fi

# Binary search for the right prompt_limit to fit the budget.
lo=0
hi="$CTX_PROMPT_LIMIT"
best_result="$result"
best_bytes="$result_bytes"

while [[ "$lo" -le "$hi" ]]; do
    mid=$(( (lo + hi) / 2 ))
    render_at "$mid"
    try_result="$RENDER_MSGS"
    try_bytes=$(printf '%s' "$try_result" | LC_ALL=C wc -c | tr -d ' ')

    if [[ "$try_bytes" -le "$CTX_MAX_BYTES" ]]; then
        best_result="$try_result"
        best_bytes="$try_bytes"
        lo=$((mid + 1))
    else
        hi=$((mid - 1))
    fi
done

if [[ "$best_bytes" -gt "$CTX_MAX_BYTES" ]]; then
    printf '%s' "$best_result" | head -c "$CTX_MAX_BYTES"
    printf '[budget exceeded: trajectory too dense]' >&2
else
    printf '%s' "$best_result"
fi
