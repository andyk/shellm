#!/usr/bin/env bash
set -euo pipefail

# chat — Send messages to an activated identity's thought stream
# Reads TRAJ_DIR + TRAJ_ID from environment (set by `identity shell`).
# Always appends to the root trajectory (ROOT_TRAJ_ID), even when called
# from a forked sub-trajectory (e.g. inside an actor step).

die() { printf 'chat: error: %s\n' "$*" >&2; exit 1; }

# Append to the root trajectory, not the current (possibly forked) one
_chat_append() {
    traj append "${ROOT_TRAJ_ID:-$TRAJ_ID}" >/dev/null
}

# Handle --help before env var check
case "${1:-}" in -h|--help|help) ;; *)
    [[ -n "${TRAJ_DIR:-}" ]] || die "TRAJ_DIR not set. Run: identity shell <name>"
    [[ -n "${TRAJ_ID:-}" ]] || die "TRAJ_ID not set. Run: identity shell <name>"
    ;; esac

cmd_send() {
    local message="" from="human"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --from) from="${2:?--from requires a name}"; shift 2 ;;
            *) message="${message:+$message }$1"; shift ;;
        esac
    done

    # Read from stdin if no args and stdin is piped
    if [[ -z "$message" && ! -t 0 ]]; then
        message=$(cat)
    fi
    [[ -z "$message" ]] && die "No message provided. Usage: chat send <message>"

    # Append human-msg step to trajectory
    local step='{"type":"human-msg","content":'
    step+="$(printf '%s' "$message" | jq -Rsa .)"
    [[ "$from" != "human" ]] && step+=',"from":'"$(printf '%s' "$from" | jq -Rsa .)"
    step+='}'
    printf '%s' "$step" | _chat_append

    # Append observation for thinkers
    printf '{"type":"observation","content":%s,"source":"chat"}' \
        "$(printf '[chat] %s: %s' "$from" "$message" | jq -Rsa .)" \
        | _chat_append

    printf 'Message sent.\n' >&2
}

cmd_reply() {
    local message=""
    while [[ $# -gt 0 ]]; do
        message="${message:+$message }$1"; shift
    done
    if [[ -z "$message" && ! -t 0 ]]; then
        message=$(cat)
    fi
    [[ -z "$message" ]] && die "No message provided. Usage: chat reply <message>"

    printf '{"type":"agent-msg","content":%s}' \
        "$(printf '%s' "$message" | jq -Rsa .)" \
        | _chat_append

    # Append observation for thinkers
    printf '{"type":"observation","content":%s,"source":"chat"}' \
        "$(printf '[chat] me: %s' "$message" | jq -Rsa .)" \
        | _chat_append

    printf 'Reply sent.\n' >&2
}

cmd_send_file() {
    local from="human" filepath=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --from) from="${2:?--from requires a name}"; shift 2 ;;
            *) filepath="$1"; shift ;;
        esac
    done
    [[ -z "$filepath" ]] && die "Usage: chat send-file [--from <name>] <filename>"
    [[ -f "$filepath" ]] || die "File not found: $filepath"

    local filename
    filename=$(basename "$filepath")
    local content
    content=$(cat "$filepath")

    local step='{"type":"human-msg","filename":'
    step+="$(printf '%s' "$filename" | jq -Rsa .)"
    step+=',"content":'
    step+="$(printf '%s' "$content" | jq -Rsa .)"
    [[ "$from" != "human" ]] && step+=',"from":'"$(printf '%s' "$from" | jq -Rsa .)"
    step+='}'
    printf '%s' "$step" | _chat_append

    # Append observation for thinkers
    printf '{"type":"observation","content":%s,"source":"chat"}' \
        "$(printf '[chat] %s sent file %s: %s' "$from" "$filename" "$content" | jq -Rsa .)" \
        | _chat_append

    printf 'File sent: %s\n' "$filename" >&2
}

cmd_history() {
    local n=20
    [[ -n "${1:-}" ]] && n="$1"

    local identity_name="${IDENTITY_NAME:-agent}"

    traj cat "${ROOT_TRAJ_ID:-$TRAJ_ID}" --filter type=human-msg,agent-msg --raw 2>/dev/null \
    | tail -n "$n" \
    | while IFS= read -r line; do
        local step_type content from
        step_type=$(printf '%s' "$line" | jq -r '.type // empty' 2>/dev/null)
        content=$(printf '%s' "$line" | jq -r '.content // empty' 2>/dev/null)
        [[ -z "$content" ]] && continue
        case "$step_type" in
            human-msg)
                from=$(printf '%s' "$line" | jq -r '.from // empty' 2>/dev/null)
                printf '%s: %s\n' "${from:-you}" "$content"
                ;;
            agent-msg)
                printf '%s: %s\n' "$identity_name" "$content"
                ;;
        esac
    done
}

cmd_repl() {
    exec shellm-tui "$@"
}

usage() {
    cat <<'EOF'
chat — Messaging for an activated identity

Usage:
  chat send [--from <name>] <message>    Human sends a message to the agent
  chat send-file [--from <name>] <file> Send a file's contents as a message
  chat reply <message>     Agent sends a message to the human
  chat history [N]         Show last N messages (default 20)
  chat repl                Interactive chat (shows agent replies inline)

Environment:
  TRAJ_DIR + TRAJ_ID  Trajectory (set by `identity shell`)
  IDENTITY_NAME       Identity name (for display)
  IDENTITY_DIR        Identity directory (for repl history)
EOF
    exit 0
}

# Dispatch
case "${1:-}" in
    send)      shift; cmd_send "$@" ;;
    send-file) shift; cmd_send_file "$@" ;;
    reply)     shift; cmd_reply "$@" ;;
    history) shift; cmd_history "$@" ;;
    repl)    cmd_repl ;;
    -h|--help|help) usage ;;
    "")     usage ;;
    *)      die "Unknown command: $1 (try chat --help)" ;;
esac
