#!/usr/bin/env bash
set -euo pipefail

# chat — Send and receive messages on an activated identity's trajectory
# Reads TRAJ_DIR + TRAJ_ID from environment (set by `identity shell`).
# Always appends to the root trajectory (ROOT_TRAJ_ID), even when called
# from a forked sub-trajectory (e.g. inside an actor step).
#
# Config file: $CHATRC (default: ./.chatrc)
#   default_send_from=<name>   Default --from for `chat send`

die() { printf 'chat: error: %s\n' "$*" >&2; exit 1; }

# ---------------------------------------------------------------------------
# Config file (.chatrc)
# ---------------------------------------------------------------------------

CHATRC="${CHATRC:-./.chatrc}"

# Read a key from the chatrc file. Returns empty string if not found.
_chatrc_get() {
    local key="$1"
    [[ -f "$CHATRC" ]] || return 0
    grep "^${key}=" "$CHATRC" 2>/dev/null | head -1 | cut -d= -f2- || true
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# Append to the root trajectory, not the current (possibly forked) one
_chat_append() {
    traj append "${ROOT_TRAJ_ID:-$TRAJ_ID}" >/dev/null
}

# Handle --help before env var check
case "${1:-}" in -h|--help|help) ;; *)
    [[ -n "${TRAJ_DIR:-}" ]] || die "TRAJ_DIR not set. Run: identity shell <name>"
    [[ -n "${TRAJ_ID:-}" ]] || die "TRAJ_ID not set. Run: identity shell <name>"
    ;; esac

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_send() {
    local message="" from="" to="${IDENTITY_NAME:-}"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --from) from="${2:?--from requires a name}"; shift 2 ;;
            --to)   to="${2:?--to requires a name}"; shift 2 ;;
            *)      message="${message:+$message }$1"; shift ;;
        esac
    done

    # Read from stdin if no args and stdin is piped
    if [[ -z "$message" && ! -t 0 ]]; then
        message=$(cat)
    fi
    [[ -z "$message" ]] && die "No message provided. Usage: chat send [--from <name>] [--to <name>] <message>"

    # Resolve --from default from .chatrc
    if [[ -z "$from" ]]; then
        from=$(_chatrc_get "default_send_from")
        if [[ -z "$from" ]]; then
            die "No --from specified and no default_send_from in $CHATRC.
Create a .chatrc file with:
  mkdir -p \$(dirname $CHATRC) && echo 'default_send_from=your-name' > $CHATRC"
        fi
    fi

    # Default --to to IDENTITY_NAME
    [[ -z "$to" ]] && die "No --to specified and IDENTITY_NAME not set."

    # Append message step to trajectory
    printf '{"type":"message","content":%s,"from":%s,"to":%s,"source":"chat"}' \
        "$(printf '%s' "$message" | jq -Rsa .)" \
        "$(printf '%s' "$from" | jq -Rsa .)" \
        "$(printf '%s' "$to" | jq -Rsa .)" \
        | _chat_append

    printf 'Message sent.\n' >&2
}

cmd_reply() {
    local to_name="${1:-}"
    [[ -z "$to_name" ]] && die "Usage: chat reply <to_name> [message]"
    shift

    local message=""
    while [[ $# -gt 0 ]]; do
        message="${message:+$message }$1"; shift
    done
    if [[ -z "$message" && ! -t 0 ]]; then
        message=$(cat)
    fi
    [[ -z "$message" ]] && die "No message provided. Usage: chat reply <to_name> <message>"

    local from="${IDENTITY_NAME:-}"
    [[ -z "$from" ]] && die "IDENTITY_NAME not set. Run: identity shell <name>"

    printf '{"type":"message","content":%s,"from":%s,"to":%s,"source":"chat"}' \
        "$(printf '%s' "$message" | jq -Rsa .)" \
        "$(printf '%s' "$from" | jq -Rsa .)" \
        "$(printf '%s' "$to_name" | jq -Rsa .)" \
        | _chat_append

    printf 'Reply sent.\n' >&2
}

cmd_send_file() {
    local from="" to="${IDENTITY_NAME:-}" filepath=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --from) from="${2:?--from requires a name}"; shift 2 ;;
            --to)   to="${2:?--to requires a name}"; shift 2 ;;
            *)      filepath="$1"; shift ;;
        esac
    done
    [[ -z "$filepath" ]] && die "Usage: chat send-file [--from <name>] [--to <name>] <filename>"
    [[ -f "$filepath" ]] || die "File not found: $filepath"

    # Resolve --from default from .chatrc
    if [[ -z "$from" ]]; then
        from=$(_chatrc_get "default_send_from")
        if [[ -z "$from" ]]; then
            die "No --from specified and no default_send_from in $CHATRC.
Create a .chatrc file with:
  mkdir -p \$(dirname $CHATRC) && echo 'default_send_from=your-name' > $CHATRC"
        fi
    fi

    [[ -z "$to" ]] && die "No --to specified and IDENTITY_NAME not set."

    local filename
    filename=$(basename "$filepath")
    local content
    content=$(cat "$filepath")

    printf '{"type":"message","filename":%s,"content":%s,"from":%s,"to":%s,"source":"chat"}' \
        "$(printf '%s' "$filename" | jq -Rsa .)" \
        "$(printf '%s' "$content" | jq -Rsa .)" \
        "$(printf '%s' "$from" | jq -Rsa .)" \
        "$(printf '%s' "$to" | jq -Rsa .)" \
        | _chat_append

    printf 'File sent: %s\n' "$filename" >&2
}

cmd_history() {
    local n=20
    [[ -n "${1:-}" ]] && n="$1"

    local identity_name="${IDENTITY_NAME:-agent}"

    # Support both new "message" type and legacy "human-msg"/"agent-msg" types
    traj cat "${ROOT_TRAJ_ID:-$TRAJ_ID}" --filter type=message,human-msg,agent-msg --raw 2>/dev/null \
    | tail -n "$n" \
    | while IFS= read -r line; do
        local step_type content msg_from msg_to
        step_type=$(printf '%s' "$line" | jq -r '.type // empty' 2>/dev/null)
        content=$(printf '%s' "$line" | jq -r '.content // empty' 2>/dev/null)
        [[ -z "$content" ]] && continue
        case "$step_type" in
            message)
                msg_from=$(printf '%s' "$line" | jq -r '.from // "unknown"' 2>/dev/null)
                msg_to=$(printf '%s' "$line" | jq -r '.to // empty' 2>/dev/null)
                printf '%s → %s: %s\n' "$msg_from" "${msg_to:-?}" "$content"
                ;;
            human-msg)
                msg_from=$(printf '%s' "$line" | jq -r '.from // empty' 2>/dev/null)
                printf '%s: %s\n' "${msg_from:-you}" "$content"
                ;;
            agent-msg)
                printf '%s: %s\n' "$identity_name" "$content"
                ;;
        esac
    done
}

cmd_repl() {
    exec shellm-tui "$@"
}

usage() {
    cat <<'EOF'
chat — Messaging for an activated identity

Usage:
  chat send [--from <name>] [--to <name>] <message>
                             Send a message (from defaults to .chatrc
                             default_send_from, to defaults to $IDENTITY_NAME)
  chat send-file [--from <name>] [--to <name>] <file>
                             Send a file's contents as a message
  chat reply <to_name> <message>
                             Agent sends a reply (from is $IDENTITY_NAME)
  chat history [N]           Show last N messages (default 20)
  chat repl                  Interactive chat (shows agent replies inline)

Config file ($CHATRC, default ./.chatrc):
  default_send_from=<name>   Default --from for `chat send`

Environment:
  CHATRC          Path to config file (default: ./.chatrc)
  TRAJ_DIR        Trajectory directory (set by `identity shell`)
  TRAJ_ID         Trajectory ID (set by `identity shell`)
  IDENTITY_NAME   Identity name (for reply attribution and --to default)
  IDENTITY_DIR    Identity directory (for repl history)
EOF
    exit 0
}

# Dispatch
case "${1:-}" in
    send)      shift; cmd_send "$@" ;;
    send-file) shift; cmd_send_file "$@" ;;
    reply)     shift; cmd_reply "$@" ;;
    history) shift; cmd_history "$@" ;;
    repl)    shift; cmd_repl "$@" ;;
    -h|--help|help) usage ;;
    "")     usage ;;
    *)      die "Unknown command: $1 (try chat --help)" ;;
esac
