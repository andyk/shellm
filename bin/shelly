#!/usr/bin/env bash
set -euo pipefail

# shelly — Interactive conversational agent built on top of shellm
# A thin CLI wrapper around shellm, mem, and skills that provides
# multi-turn conversation with persona management.

# ---------------------------------------------------------------------------
# Config & defaults
# ---------------------------------------------------------------------------

SHELLY_DIR="${SHELLY_DIR:-.shelly}"
SHELLY_MODEL="${SHELLY_MODEL:-${SHELLM_MODEL:-claude-opus-4-6}}"
SHELLY_MEMORIES_DIR=""
SHELLY_SKILLS_DIR=""
SHELLY_KERNEL_DIR=""
SHELLY_TRAJ_DIR=""
VERBOSE=0

# Autonomous mode config
SHELLY_TICK_INTERVAL="${SHELLY_TICK_INTERVAL:-30}"
SHELLY_THINK_MODEL="${SHELLY_THINK_MODEL:-${SHELLM_MODEL:-claude-opus-4-7}}"
SHELLY_CONTEXT_TAIL="${SHELLY_CONTEXT_TAIL:-30}"

# Load .env if present (so skill-declared vars like OBSIDIAN_VAULT are available)
if [[ -f ".env" ]]; then
    set -a
    # shellcheck disable=SC1091
    source .env
    set +a
fi

# Source per-repo rc file (flags > env vars > rc file)
if [[ -f ".shellyrc" ]]; then
    _pre_env=$(env | grep '^SHELLY_') || true
    source .shellyrc
    while IFS='=' read -r k v; do
        [[ -n "$k" ]] && export "$k=$v"
    done <<< "$_pre_env"
fi

# ---------------------------------------------------------------------------
# Utility functions
# ---------------------------------------------------------------------------

die() { echo "shelly: error: $*" >&2; exit 1; }

debug() {
    if [[ "$VERBOSE" -eq 1 ]]; then
        printf '[shelly debug] %s\n' "$*" >&2
    fi
}

iso_timestamp() {
    date +%Y-%m-%dT%H:%M:%S
}

# Collect env vars declared by skills via metadata.shelllm.requires.env.
# Scans kernel skills and persona skills for requires.env arrays.
# Outputs deduplicated var names, one per line.
collect_skill_vars() {
    local persona_dir="$1"
    local -a var_names=()
    local -a dirs=("$SHELLY_KERNEL_DIR" "$persona_dir/skills")
    local base skill_dir
    for base in "${dirs[@]}"; do
        [[ -d "$base" ]] || continue
        for skill_dir in "$base"/*/; do
            [[ -f "${skill_dir}SKILL.md" ]] || continue
            local frontmatter
            frontmatter=$(awk 'NR==1 && /^---$/{f=1; next} f && /^---$/{exit} f{print}' "${skill_dir}SKILL.md")
            [[ -z "$frontmatter" ]] && continue
            # Extract env array from requires.env (JSON bracket notation)
            local env_val
            env_val=$(printf '%s\n' "$frontmatter" | awk '/^[[:space:]]+env:/{sub(/.*env:[[:space:]]*/, ""); print; exit}')
            [[ -z "$env_val" ]] && continue
            local v
            while IFS= read -r v; do
                [[ -n "$v" ]] && var_names+=("$v")
            done < <(printf '%s' "$env_val" | jq -r '.[]' 2>/dev/null)
        done
    done
    # Deduplicate and output
    if [[ ${#var_names[@]} -gt 0 ]]; then
        printf '%s\n' "${var_names[@]}" | sort -u
    fi
}

json_escape() {
    printf '%s' "$1" | jq -Rsa .
}

# Kill Docker containers managed by a persona's shellm envs.
_destroy_persona_containers() {
    local persona_dir="$1"
    local envs_dir="$persona_dir/.shellm/envs"
    [[ -d "$envs_dir" ]] || return 0
    local env_dir
    for env_dir in "$envs_dir"/*/; do
        [[ -f "$env_dir/container_id" ]] || continue
        local cid
        cid=$(cat "$env_dir/container_id" 2>/dev/null || true)
        [[ -n "$cid" ]] && docker rm -f "$cid" >/dev/null 2>&1 || true
    done
}

# ---------------------------------------------------------------------------
# Autonomous mode helpers
# ---------------------------------------------------------------------------

# Extract goals from persona's memories (looks for type: goal in frontmatter)
get_goals() {
    local mem_dir="${1:-$SHELLY_MEMORIES_DIR}"
    [[ -d "$mem_dir" ]] || return 0
    local goals=""
    local f
    for f in "$mem_dir"/*.md; do
        [[ -f "$f" ]] || continue
        # Check YAML frontmatter for type: goal
        local ftype
        ftype=$(awk 'NR==1 && /^---$/{f=1; next} f && /^---$/{exit} f && /^type:/{sub(/^type:[[:space:]]*/, ""); print}' "$f")
        case "$ftype" in
            goal|intention)
                # Extract the body (after frontmatter), strip leading blank lines
                local body
                body=$(awk 'NR==1 && /^---$/{f=1; next} f && /^---$/{f=0; next} !f{print}' "$f" | sed '/./,$!d' | head -3)
                [[ -n "$body" ]] && goals="${goals}- ${body}
"
                ;;
        esac
    done
    if [[ -z "$goals" ]]; then
        printf '%s' "(no goals set)"
    else
        printf '%s' "$goals"
    fi
}

# Load a prompt template, replacing {{goals}} and {{persona_name}}
load_prompt() {
    local prompt_file="$1"
    local persona_name="$2"
    local goals="$3"
    [[ -f "$prompt_file" ]] || return 1
    local content
    content=$(cat "$prompt_file")
    # Replace {{persona_name}} using sed
    content=$(printf '%s' "$content" | sed "s/{{persona_name}}/$persona_name/g")
    # Replace {{goals}} — write goals to temp file and use sed with read
    # (awk -v breaks on embedded newlines)
    local goals_file
    goals_file=$(mktemp)
    printf '%s' "$goals" > "$goals_file"
    # Use perl if available (handles multiline cleanly), else python, else simple sed
    if command -v perl >/dev/null 2>&1; then
        content=$(printf '%s' "$content" | perl -pe "
            BEGIN { open(F, '<', '$goals_file'); local \$/; \$g = <F>; close(F); chomp \$g; }
            s/\\{\\{goals\\}\\}/\$g/g;
        ")
    else
        # Fallback: split on {{goals}} and reassemble
        local before after
        before="${content%%\{\{goals\}\}*}"
        after="${content#*\{\{goals\}\}}"
        if [[ "$before" != "$content" ]]; then
            content="${before}${goals}${after}"
        fi
    fi
    rm -f "$goals_file"
    printf '%s' "$content"
}

# Ensure the think prompt exists for a persona (copy from bundled if missing)
ensure_think_prompt() {
    local persona_dir="$1"
    local prompts_dir="$persona_dir/prompts"
    mkdir -p "$prompts_dir"
    if [[ ! -f "$prompts_dir/think.md" ]]; then
        # Copy from bundled prompts (try repo-relative first, then installed location)
        local script_dir
        script_dir="$(cd "$(dirname "$(realpath "$0")")" && pwd)"
        local bundled="$script_dir/../prompts/think.md"
        if [[ ! -f "$bundled" ]]; then
            bundled="$HOME/.shelly-prompts/think.md"
        fi
        if [[ -f "$bundled" ]]; then
            cp "$bundled" "$prompts_dir/think.md"
        else
            die "think prompt not found (checked $script_dir/../prompts/ and ~/.shelly-prompts/)"
        fi
    fi
}

# mkdir-based POSIX lock (bash 3.2 compatible, no flock)
acquire_lock() {
    local lock_dir="$1"
    if mkdir "$lock_dir" 2>/dev/null; then
        printf '%s' "$$" > "$lock_dir/pid"
        return 0
    fi
    # Check for stale lock
    if [[ -f "$lock_dir/pid" ]]; then
        local old_pid
        old_pid=$(cat "$lock_dir/pid" 2>/dev/null) || old_pid=""
        if [[ -n "$old_pid" ]] && ! kill -0 "$old_pid" 2>/dev/null; then
            # Stale lock — remove and retry
            rm -rf "$lock_dir"
            if mkdir "$lock_dir" 2>/dev/null; then
                printf '%s' "$$" > "$lock_dir/pid"
                return 0
            fi
        fi
    fi
    return 1
}

release_lock() {
    local lock_dir="$1"
    rm -rf "$lock_dir"
}

# Discover thought processes: scan bundled + persona TP dirs, merge
discover_thought_processes() {
    local persona_dir="$1"
    local script_dir
    script_dir="$(cd "$(dirname "$(realpath "$0")")" && pwd)"
    local bundled_dir="$script_dir/../thought-processes"
    # Fallback to installed location if repo-relative doesn't exist
    if [[ ! -d "$bundled_dir" ]]; then
        bundled_dir="$HOME/.shelly-thought-processes"
    fi
    local persona_tp_dir="$persona_dir/thought-processes"

    # Use a delimited string for dedup (bash 3.2 compat)
    local _seen="" _results=""
    local f name

    # Persona TPs take precedence
    if [[ -d "$persona_tp_dir" ]]; then
        for f in "$persona_tp_dir"/*.md; do
            [[ -f "$f" ]] || continue
            name=$(basename "$f" .md)
            _seen="${_seen}|${name}|"
            _results="${_results}${name}=${f}
"
        done
    fi

    # Bundled TPs (skip if persona already has override)
    if [[ -d "$bundled_dir" ]]; then
        for f in "$bundled_dir"/*.md; do
            [[ -f "$f" ]] || continue
            name=$(basename "$f" .md)
            case "$_seen" in
                *"|${name}|"*) continue ;;
            esac
            _results="${_results}${name}=${f}
"
        done
    fi

    printf '%s' "$_results"
}

# ---------------------------------------------------------------------------
# Persona management
# ---------------------------------------------------------------------------

ensure_persona() {
    # Migrate legacy identities/ dir to personas/
    if [[ -d "$SHELLY_DIR/identities" && ! -d "$SHELLY_DIR/personas" ]]; then
        mv "$SHELLY_DIR/identities" "$SHELLY_DIR/personas"
    fi

    mkdir -p "$SHELLY_DIR/personas"
    if [[ ! -L "$SHELLY_DIR/personas/current" ]] || [[ ! -d "$SHELLY_DIR/personas/current" ]]; then
        cmd_new "shelly"
    fi
    # Always resolve memories/skills/kernel to current persona
    local persona_dir
    persona_dir=$(resolve_persona)
    SHELLY_MEMORIES_DIR="$persona_dir/memories"
    SHELLY_SKILLS_DIR="$persona_dir/skills"
    SHELLY_KERNEL_DIR="$persona_dir/kernel"
    SHELLY_TRAJ_DIR="$persona_dir/traj"
    mkdir -p "$SHELLY_MEMORIES_DIR" "$SHELLY_SKILLS_DIR" "$SHELLY_KERNEL_DIR" "$SHELLY_TRAJ_DIR"

    # Seed core-skills remote if not already configured
    local core_skills="$HOME/.skills/core-skills"
    if [[ -d "$core_skills" && ! -f "$SHELLY_SKILLS_DIR/.skillsrc" ]]; then
        printf 'SKILLS_REMOTES="%s"\n' "$core_skills" > "$SHELLY_SKILLS_DIR/.skillsrc"
    fi

    ensure_kernel
}

resolve_persona() {
    if [[ ! -L "$SHELLY_DIR/personas/current" ]]; then
        die "No active persona. Run: shelly new <name>"
    fi
    local target
    target=$(readlink "$SHELLY_DIR/personas/current")
    # Handle relative symlinks (current is inside personas/)
    if [[ "$target" != /* ]]; then
        target="$SHELLY_DIR/personas/$target"
    fi
    if [[ ! -d "$target" ]]; then
        die "Current persona directory missing: $target"
    fi
    # Return absolute path (needed for Docker workspace mounts)
    (cd "$target" && pwd)
}

ensure_kernel() {
    mkdir -p "$SHELLY_KERNEL_DIR/mem"
    if [[ ! -f "$SHELLY_KERNEL_DIR/mem/SKILL.md" ]]; then
        # Locate bundled mem skill relative to the real script location
        local script_dir bundled_skill
        script_dir="$(cd "$(dirname "$(realpath "$0")")" && pwd)"
        bundled_skill="$script_dir/../skills/mem/SKILL.md"
        if [[ -f "$bundled_skill" ]]; then
            cp "$bundled_skill" "$SHELLY_KERNEL_DIR/mem/SKILL.md"
        else
            debug "Warning: bundled mem skill not found at $bundled_skill; creating minimal bootstrap"
            cat > "$SHELLY_KERNEL_DIR/mem/SKILL.md" << 'MEMSKILL'
---
name: mem
description: Life context and memory system
---
# mem — Life context system
Commands: mem add --type TYPE <text> | mem search <query> | mem list | mem dump | mem forget <name> | mem edit <name> <text>
MEMSKILL
        fi
        debug "Bootstrapped mem kernel skill"
    fi
}

# ---------------------------------------------------------------------------
# Context assembly
# ---------------------------------------------------------------------------

build_shelly_system_prompt() {
    local persona_dir="$1"
    local context=""

    # Read persona name from info.txt, fall back to directory name
    local persona_name
    persona_name=$(grep '^name=' "$persona_dir/info.txt" 2>/dev/null | cut -d= -f2-) || true
    [[ -z "$persona_name" ]] && persona_name=$(basename "$persona_dir")

    # 1. Core persona — personality/self-description
    if [[ -f "$persona_dir/system_prompt.txt" ]]; then
        context=$(cat "$persona_dir/system_prompt.txt")
    else
        context='I am '"$persona_name"', I am an AI with a persona, life context (e.g., memory), and skills. I am concise, smart, ambitious, and empathetic.

## How I work
I am a bash script that wraps shellm, mem, and skills into a conversational agent. My source code is at '"$(realpath "$0")"'. I can read my own code to understand how I work. I run inside shellm, which executes my bash code blocks in a loop until I set FINAL with my answer.

IMPORTANT: When setting FINAL, I MUST use a heredoc to avoid bash interpreting backticks or special characters in my response:
```bash
FINAL=$(cat <<'"'"'ENDOFRESPONSE'"'"'
My response with `backticks` and $pecial characters safely here.
ENDOFRESPONSE
)
```'
    fi

    # 2. Skills CLI knowledge (the "kernel-kernel" — hardcoded, changes in lockstep with CLI)
    context="$context

## My skills system
My skills are learned abilities that let me do specific things well. They are how I grow and become more capable over time. Each skill is a set of instructions I can follow to accomplish a particular type of task — like a recipe or a playbook. I can install new skills from GitHub or create my own, and they persist as part of me just like my memories. Skills are managed via \`skills\` (SKILLS_DIR is pre-set in my environment).

Commands I can run:
  skills                                    List all my installed skills
  skills <query>                            Search installed + remote skills
  skills show <name>                        Print a skill's full SKILL.md
  skills install <name|owner/repo|url|path> Install a skill (by name from remotes, GitHub, or local path)
  skills remove <name>                      Remove an installed skill
  skills init [name]                        Scaffold a new skill
  skills list-json                          List skills as JSON
  skills promote <name>                     Promote a skill to my kernel (always loaded)
  skills demote <name>                      Demote a kernel skill back to on-demand
  skills kernel                             Show kernel skills with token counts
  skills remote                             List configured skill remotes
  skills remote add <url|path>              Add a skill remote
  skills remote remove <url|path>           Remove a skill remote

My kernel skills are always loaded into my context. Regular skills are on-demand — I load them with \`skills show <name>\` when needed.
When the user asks me to use a skill, I read it with \`skills show <name>\` and follow its instructions."

    # 3. Kernel skills — full content from each SKILL.md in kernel/
    local kernel_content=""
    if [[ -d "$SHELLY_KERNEL_DIR" ]]; then
        local skill_dir
        for skill_dir in "$SHELLY_KERNEL_DIR"/*/; do
            [[ -f "${skill_dir}SKILL.md" ]] || continue
            local skill_body
            # Strip YAML frontmatter (between --- markers)
            skill_body=$(sed '/^---$/,/^---$/d' "${skill_dir}SKILL.md")
            if [[ -n "$skill_body" ]]; then
                kernel_content="${kernel_content}
${skill_body}"
            fi
        done
    fi
    if [[ -n "$kernel_content" ]]; then
        context="$context
$kernel_content"
    fi

    # 4. Memories — mem dump output
    local memories=""
    if command -v mem >/dev/null 2>&1; then
        memories=$(MEM_DIR="$SHELLY_MEMORIES_DIR" mem dump 2>/dev/null) || true
    fi
    if [[ -n "$memories" && "$memories" != "No memories stored." ]]; then
        context="$context

## Memories
$memories"
    fi

    # 5. Available skills — summary list from persona's skills/ dir
    local skills_summary=""
    if [[ -d "$persona_dir/skills" ]]; then
        local skill_dir
        for skill_dir in "$persona_dir/skills"/*/; do
            [[ -f "${skill_dir}SKILL.md" ]] || continue
            local sname sdesc
            sname=$(sed -n '/^---$/,/^---$/p' "${skill_dir}SKILL.md" | grep '^name:' | sed 's/^name:[[:space:]]*//' | sed "s/^[\"']\(.*\)[\"']$/\1/")
            sdesc=$(sed -n '/^---$/,/^---$/p' "${skill_dir}SKILL.md" | grep '^description:' | sed 's/^description:[[:space:]]*//' | sed "s/^[\"']\(.*\)[\"']$/\1/")
            [[ -z "$sname" ]] && sname=$(basename "$skill_dir")
            skills_summary="${skills_summary}  - ${sname}: ${sdesc}
"
        done
    fi
    if [[ -n "$skills_summary" ]]; then
        context="$context

## Available skills (use \`skills show <name>\` to load)
$skills_summary"
    fi

    printf '%s' "$context"
}

# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

cmd_send() {
    local message=""
    local ticks=10
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ticks) ticks="${2:?--ticks requires a number}"; shift 2 ;;
            *) message="${message:+$message }$1"; shift ;;
        esac
    done

    # Read from stdin if no args and stdin is piped
    if [[ -z "$message" && ! -t 0 ]]; then
        message=$(cat)
    fi
    [[ -z "$message" ]] && die "No message provided. Usage: shelly send <message>"

    ensure_persona
    local persona_dir
    persona_dir=$(resolve_persona)
    local traj_dir="$persona_dir/traj"

    # Record user message to traj
    printf '{"type":"human-msg","content":%s}' "$(printf '%s' "$message" | jq -Rsa .)" \
        | traj append "$traj_dir" >/dev/null

    # Run ticks to process the message (headlong architecture)
    printf '[shelly] Message received. Running %d ticks...\n' "$ticks" >&2
    local i
    for i in $(seq 1 "$ticks"); do
        printf '[tick %d]\n' "$i" >&2
        cmd_think || true
    done
    printf '[shelly] %d ticks complete. Run `shelly start` to keep the agent going.\n' "$ticks" >&2
}

cmd_repl_plain() {
    ensure_persona

    local persona_dir
    persona_dir=$(resolve_persona)
    local persona_name
    persona_name=$(grep '^name=' "$persona_dir/info.txt" 2>/dev/null | cut -d= -f2-) || true
    [[ -z "$persona_name" ]] && persona_name=$(basename "$persona_dir")

    printf 'Loaded persona: %s (%s)\n' "$persona_name" "$persona_dir" >&2
    printf 'Ctrl+C to interrupt, Ctrl+D twice to exit\n' >&2

    # Readline history for up-arrow recall in the REPL
    local history_file="$persona_dir/repl_history"
    touch "$history_file"

    # Load readline history
    if [[ -f "$history_file" ]]; then
        history -r "$history_file" 2>/dev/null || true
    fi

    while true; do
        local input=""
        local _sigint=0

        # Trap SIGINT at the prompt: clear line, re-prompt
        trap '_sigint=1' INT
        local read_rc=0
        IFS= read -e -r -p "> " input || read_rc=$?
        trap - INT

        if [[ "$_sigint" -eq 1 ]]; then
            printf '\n' >&2
            continue
        fi

        if [[ "$read_rc" -ne 0 ]]; then
            # EOF (Ctrl-D)
            printf '\n' >&2
            break
        fi

        # Save to readline history
        history -s "$input" 2>/dev/null || true
        history -w "$history_file" 2>/dev/null || true

        # Skip empty input
        [[ -z "$input" ]] && continue

        # Handle slash commands
        case "$input" in
            /quit|/exit|/q)
                break
                ;;
            /start)
                cmd_start &
                printf 'Autonomous loop started in background (PID %d). Use /stop to halt.\n' "$!" >&2
                ;;
            /stop)
                cmd_stop
                ;;
            /think)
                cmd_think
                ;;
            /focus\ *)
                local focus_args="${input#/focus }"
                eval cmd_focus $focus_args
                ;;
            /focus)
                cmd_focus show
                ;;
            /log\ *)
                local log_n="${input#/log }"
                cmd_log "$log_n"
                ;;
            /log)
                cmd_log
                ;;
            /personas\ *)
                local personas_rest="${input#/personas }"
                personas_rest="${personas_rest## }"
                local personas_sub="${personas_rest%% *}"
                local personas_arg="${personas_rest#"$personas_sub"}"
                personas_arg="${personas_arg## }"
                case "$personas_sub" in
                    new)
                        if [[ -z "$personas_arg" ]]; then
                            printf 'Usage: /personas new <name>\n' >&2
                        else
                            cmd_new "$personas_arg"
                        fi
                        ;;
                    switch)
                        if [[ -z "$personas_arg" ]]; then
                            printf 'Usage: /personas switch <name>\n' >&2
                        else
                            cmd_switch "$personas_arg"
                        fi
                        ;;
                    delete)
                        if [[ -z "$personas_arg" ]]; then
                            printf 'Usage: /personas delete <name>\n' >&2
                        else
                            cmd_delete "$personas_arg"
                        fi
                        ;;
                    info)
                        cmd_persona_info
                        ;;
                    list)
                        cmd_personas $personas_arg
                        ;;
                    *)
                        printf 'Unknown: /personas %s (try: new, list, switch, delete, info)\n' "$personas_sub" >&2
                        ;;
                esac
                ;;
            /personas)
                cmd_personas
                ;;
            /history)
                cmd_history
                ;;
            /reset)
                cmd_reset
                ;;
            /context)
                cmd_context
                ;;
            /envs\ *)
                local envs_args="${input#/envs }"
                eval cmd_envs $envs_args
                ;;
            /envs)
                cmd_envs
                ;;
            /mem\ *)
                local mem_args="${input#/mem }"
                eval MEM_DIR=\"\$SHELLY_MEMORIES_DIR\" mem $mem_args
                ;;
            /mem)
                MEM_DIR="$SHELLY_MEMORIES_DIR" mem dump
                ;;
            /skills\ *)
                local skills_args="${input#/skills }"
                eval SKILLSRC=\"\$SHELLY_SKILLS_DIR/.skillsrc\" SKILLS_DIR=\"\$SHELLY_SKILLS_DIR\" SKILLS_KERNEL_DIR=\"\$SHELLY_KERNEL_DIR\" skills $skills_args
                ;;
            /skills)
                SKILLSRC="$SHELLY_SKILLS_DIR/.skillsrc" SKILLS_DIR="$SHELLY_SKILLS_DIR" SKILLS_KERNEL_DIR="$SHELLY_KERNEL_DIR" skills
                ;;
            /help)
                repl_help
                ;;
            /*)
                printf 'Unknown command: %s (type /help)\n' "$input" >&2
                ;;
            *)
                cmd_send "$input"
                ;;
        esac
    done
}

# ---------------------------------------------------------------------------
# TUI repl — alternate-screen with scroll region
# ---------------------------------------------------------------------------

# Global TUI state
_tui_rows=0
_tui_cols=0
_tui_tail_pid=""
_tui_loop_pid=""
_tui_active=0
_tui_stty_saved=""
_tui_persona_name=""
_tui_loop_running=0

tui_init() {
    _tui_stty_saved=$(stty -g 2>/dev/null) || true
    _tui_rows=$(tput lines)
    _tui_cols=$(tput cols)
    # Enter alternate screen
    printf '\033[?1049h' >/dev/tty
    # Clear screen
    printf '\033[2J' >/dev/tty
    # Set scroll region: rows 1 to (rows-2)
    local scroll_end=$((_tui_rows - 2))
    printf '\033[1;%dr' "$scroll_end" >/dev/tty
    # Draw status bar and input line
    tui_draw_status
    tui_draw_input_line
    _tui_active=1
}

tui_cleanup() {
    [[ "$_tui_active" -eq 0 ]] && return 0
    _tui_active=0
    # Kill background processes
    if [[ -n "$_tui_tail_pid" ]]; then
        kill "$_tui_tail_pid" 2>/dev/null || true
        wait "$_tui_tail_pid" 2>/dev/null || true
        _tui_tail_pid=""
    fi
    if [[ -n "$_tui_loop_pid" ]]; then
        kill "$_tui_loop_pid" 2>/dev/null || true
        wait "$_tui_loop_pid" 2>/dev/null || true
        _tui_loop_pid=""
    fi
    # Reset scroll region
    printf '\033[r' >/dev/tty
    # Exit alternate screen
    printf '\033[?1049l' >/dev/tty
    # Restore stty
    if [[ -n "$_tui_stty_saved" ]]; then
        stty "$_tui_stty_saved" 2>/dev/null || true
    fi
}

tui_draw_status() {
    local status_row=$((_tui_rows - 1))
    local state="idle"
    [[ "$_tui_loop_running" -eq 1 ]] && state="running"
    local tick_info=""
    if [[ -n "$_tui_persona_name" ]]; then
        tick_info="$_tui_persona_name | $state"
    else
        tick_info="headlong | $state"
    fi
    # Pad to full width
    local padded
    padded=$(printf "%-${_tui_cols}s" " $tick_info")
    # DEC save cursor, move to status row, reverse video, print, reset, DEC restore
    printf '\0337\033[%d;1H\033[7m%s\033[0m\0338' "$status_row" "$padded" >/dev/tty
}

tui_draw_input_line() {
    # Position cursor at the input row (last row)
    printf '\033[%d;1H\033[2K> ' "$_tui_rows" >/dev/tty
}

tui_scroll_print() {
    local text="$1"
    local scroll_end=$((_tui_rows - 2))
    # DEC save, move to last line of scroll region, newline scrolls region up,
    # clear line, print text, DEC restore
    printf '\0337\033[%d;1H\n\033[2K%s\0338' "$scroll_end" "$text" >/dev/tty
}

tui_stream_entry() {
    local json_line="$1"
    local entry_type content source
    entry_type=$(printf '%s' "$json_line" | jq -r '.type // "unknown"' 2>/dev/null) || return 0
    content=$(printf '%s' "$json_line" | jq -r '.content // ""' 2>/dev/null) || content=""
    source=$(printf '%s' "$json_line" | jq -r '.source // ""' 2>/dev/null) || source=""

    # Truncate content to first line, max (cols-20) chars
    content="${content%%$'\n'*}"
    local max_len=$((_tui_cols - 20))
    if [[ ${#content} -gt $max_len ]]; then
        content="${content:0:$max_len}..."
    fi

    # Color by type
    local color="\033[0m"  # default
    case "$entry_type" in
        thought)    color="\033[36m" ;;  # cyan
        action)     color="\033[33m" ;;  # yellow
        observation) color="\033[32m" ;; # green
        human-msg)  color="\033[1;37m" ;; # bold white
        agent-run)  color="\033[35m" ;;  # magenta
    esac
    # tp-thought types (tp:*)
    case "$entry_type" in
        tp:*|tp-thought) color="\033[34m" ;;  # blue
    esac

    local source_tag=""
    [[ -n "$source" ]] && source_tag="($source) "

    tui_scroll_print "$(printf '%b[%s]%b %s%s' "$color" "$entry_type" "\033[0m" "$source_tag" "$content")"
}

tui_start_watcher() {
    local traj_dir="$1"
    local traj_file="$traj_dir/root.jsonl"
    (
        # Wait for the traj file to exist
        while [[ ! -f "$traj_file" ]]; do
            sleep 0.5
        done
        # Tail new lines and stream them
        tail -n 0 -f "$traj_file" 2>/dev/null | while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            # Re-read dimensions in case of resize
            local r c entry_type content source color max_len source_tag
            r=$(tput lines 2>/dev/null) || r=$_tui_rows
            c=$(tput cols 2>/dev/null) || c=$_tui_cols
            local scroll_end=$((r - 2))

            entry_type=$(printf '%s' "$line" | jq -r '.type // "unknown"' 2>/dev/null) || continue
            content=$(printf '%s' "$line" | jq -r '.content // ""' 2>/dev/null) || content=""
            source=$(printf '%s' "$line" | jq -r '.source // ""' 2>/dev/null) || source=""

            # Truncate
            content="${content%%$'\n'*}"
            max_len=$((c - 20))
            if [[ ${#content} -gt $max_len && $max_len -gt 3 ]]; then
                content="${content:0:$max_len}..."
            fi

            color="\033[0m"
            case "$entry_type" in
                thought)     color="\033[36m" ;;
                action)      color="\033[33m" ;;
                observation) color="\033[32m" ;;
                human-msg)   color="\033[1;37m" ;;
                agent-run)   color="\033[35m" ;;
            esac
            case "$entry_type" in
                tp:*|tp-thought) color="\033[34m" ;;
            esac

            source_tag=""
            [[ -n "$source" ]] && source_tag="($source) "

            local formatted
            formatted=$(printf '%b[%s]%b %s%s' "$color" "$entry_type" "\033[0m" "$source_tag" "$content")
            # DEC save, scroll region print, DEC restore — write to /dev/tty
            printf '\0337\033[%d;1H\n\033[2K%s\0338' "$scroll_end" "$formatted" >/dev/tty
        done
    ) &
    _tui_tail_pid=$!
}

tui_show_recent() {
    local traj_dir="$1"
    local n="${2:-10}"
    local traj_file="$traj_dir/root.jsonl"
    [[ -f "$traj_file" ]] || return 0
    tail -n "$n" "$traj_file" | while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        tui_stream_entry "$line"
    done
}

_tui_handle_winch() {
    [[ "$_tui_active" -eq 0 ]] && return 0
    _tui_rows=$(tput lines 2>/dev/null) || true
    _tui_cols=$(tput cols 2>/dev/null) || true
    local scroll_end=$((_tui_rows - 2))
    # Reset and re-set scroll region
    printf '\033[1;%dr' "$scroll_end" >/dev/tty
    tui_draw_status
    tui_draw_input_line
}

# Simplified think loop for TUI — no lock, no traps, output suppressed.
# The TUI manages lifecycle via _tui_loop_running and stop flag.
_tui_run_loop() {
    local persona_dir="$1"
    local tick_interval="$SHELLY_TICK_INTERVAL"
    local stop_flag="$persona_dir/stop.flag"
    rm -f "$stop_flag"

    local tick_count=0
    while true; do
        if [[ -f "$stop_flag" ]]; then
            break
        fi
        tick_count=$((tick_count + 1))
        cmd_think 2>/dev/null || true
        if [[ -f "$stop_flag" ]]; then
            break
        fi
        sleep "$tick_interval" || break
    done
}

cmd_repl() {
    # Fall back to plain repl for dumb terminals
    if [[ -z "${TERM:-}" || "$TERM" == "dumb" ]] || ! test -t 1; then
        cmd_repl_plain
        return
    fi

    ensure_persona
    local persona_dir
    persona_dir=$(resolve_persona)
    local persona_name
    persona_name=$(grep '^name=' "$persona_dir/info.txt" 2>/dev/null | cut -d= -f2-) || true
    [[ -z "$persona_name" ]] && persona_name=$(basename "$persona_dir")
    _tui_persona_name="$persona_name"

    local traj_dir="$persona_dir/traj"
    local history_file="$persona_dir/repl_history"
    touch "$history_file"

    # Load readline history
    if [[ -f "$history_file" ]]; then
        history -r "$history_file" 2>/dev/null || true
    fi

    # Initialize TUI
    tui_init
    trap 'tui_cleanup' EXIT
    trap '_tui_handle_winch' WINCH

    # Show recent traj entries
    tui_show_recent "$traj_dir" 10

    # Start background traj watcher
    tui_start_watcher "$traj_dir"

    # Start autonomous loop in background (stdout suppressed — watcher handles display)
    _tui_loop_running=1
    tui_draw_status
    _tui_run_loop "$persona_dir" >/dev/null &
    _tui_loop_pid=$!

    # Main input loop
    while true; do
        local input=""
        local _sigint=0

        trap '_sigint=1' INT
        local read_rc=0
        # Position cursor at input row before reading
        printf '\033[%d;1H\033[2K' "$_tui_rows" >/dev/tty
        IFS= read -e -r -p "> " input || read_rc=$?
        trap - INT

        if [[ "$_sigint" -eq 1 ]]; then
            # Ctrl+C: redraw input line
            tui_draw_input_line
            continue
        fi

        if [[ "$read_rc" -ne 0 ]]; then
            # EOF (Ctrl-D)
            break
        fi

        # Save to readline history
        history -s "$input" 2>/dev/null || true
        history -w "$history_file" 2>/dev/null || true

        # Skip empty input
        [[ -z "$input" ]] && continue

        case "$input" in
            /quit|/exit|/q)
                break
                ;;
            /start)
                if [[ "$_tui_loop_running" -eq 1 ]]; then
                    tui_scroll_print "$(printf '\033[33m[tui]\033[0m Loop is already running')"
                else
                    _tui_loop_running=1
                    tui_draw_status
                    _tui_run_loop "$persona_dir" >/dev/null &
                    _tui_loop_pid=$!
                    tui_scroll_print "$(printf '\033[33m[tui]\033[0m Autonomous loop started')"
                fi
                ;;
            /stop)
                if [[ "$_tui_loop_running" -eq 0 ]]; then
                    tui_scroll_print "$(printf '\033[33m[tui]\033[0m Loop is not running')"
                else
                    touch "$persona_dir/stop.flag"
                    if [[ -n "$_tui_loop_pid" ]]; then
                        wait "$_tui_loop_pid" 2>/dev/null || true
                        _tui_loop_pid=""
                    fi
                    _tui_loop_running=0
                    tui_draw_status
                    tui_scroll_print "$(printf '\033[33m[tui]\033[0m Loop stopped')"
                fi
                ;;
            /think)
                tui_scroll_print "$(printf '\033[33m[tui]\033[0m Running one think cycle...')"
                cmd_think >/dev/null 2>&1 || true
                ;;
            /focus\ *)
                local focus_args="${input#/focus }"
                eval cmd_focus $focus_args 2>&1 | while IFS= read -r line; do
                    tui_scroll_print "$line"
                done
                ;;
            /focus)
                cmd_focus show 2>&1 | while IFS= read -r line; do
                    tui_scroll_print "$line"
                done
                ;;
            /log\ *)
                local log_n="${input#/log }"
                cmd_log "$log_n" 2>&1 | while IFS= read -r line; do
                    tui_scroll_print "$line"
                done
                ;;
            /log)
                cmd_log 2>&1 | while IFS= read -r line; do
                    tui_scroll_print "$line"
                done
                ;;
            /help)
                repl_help 2>&1 | while IFS= read -r line; do
                    tui_scroll_print "$line"
                done
                ;;
            /*)
                tui_scroll_print "$(printf '\033[31mUnknown command: %s (type /help)\033[0m' "$input")"
                ;;
            *)
                # Inject as human message (non-blocking)
                cmd_append "$input"
                tui_scroll_print "$(printf '\033[1;37m[human-msg]\033[0m %s' "$input")"
                ;;
        esac
    done

    # Cleanup: stop loop, kill watcher
    if [[ "$_tui_loop_running" -eq 1 ]]; then
        touch "$persona_dir/stop.flag"
        [[ -n "$_tui_loop_pid" ]] && { kill "$_tui_loop_pid" 2>/dev/null || true; wait "$_tui_loop_pid" 2>/dev/null || true; }
    fi
    tui_cleanup
    trap - EXIT WINCH
}

repl_help() {
    cat >&2 <<'EOF'
TUI repl — autonomous loop runs in background, thoughts stream above.
Type text and press Enter to inject a message into the thought stream.

Slash commands:
  /start              Start autonomous loop (auto-started on launch)
  /stop               Stop autonomous loop
  /think              Run one think cycle manually
  /focus set <goal>   Set a goal
  /focus show         Show current goals
  /focus done <query> Mark goal as done
  /log [N]            Show last N steps from thought stream
  /help               Show this help
  /quit               Exit the repl (Ctrl+D also works)
EOF
}

cmd_new() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: shelly new <name>"

    # Validate name: lowercase alphanumeric + hyphens
    if [[ ! "$name" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
        die "Invalid persona name: '$name' (use lowercase alphanumeric + hyphens)"
    fi

    local persona_dir="$SHELLY_DIR/personas/$name"
    if [[ -d "$persona_dir" ]]; then
        die "Persona '$name' already exists"
    fi

    mkdir -p "$persona_dir"

    # Create info.txt
    local cwd
    cwd=$(pwd)
    printf 'name=%s\ncwd=%s\ncreated=%s\n' "$name" "$cwd" "$(iso_timestamp)" > "$persona_dir/info.txt"

    # Create per-persona dirs (traj replaces history.jsonl)
    mkdir -p "$persona_dir/memories" "$persona_dir/skills" "$persona_dir/kernel" "$persona_dir/traj"

    # Seed core-skills remote if installed
    local core_skills="$HOME/.skills/core-skills"
    if [[ -d "$core_skills" ]]; then
        printf 'SKILLS_REMOTES="%s"\n' "$core_skills" > "$persona_dir/skills/.skillsrc"
    fi

    # Bootstrap kernel (mem SKILL.md)
    SHELLY_KERNEL_DIR="$persona_dir/kernel"
    ensure_kernel

    # Update current symlink
    ln -sfn "$name" "$SHELLY_DIR/personas/current"

    # Re-resolve dirs for the new persona
    SHELLY_MEMORIES_DIR="$persona_dir/memories"
    SHELLY_SKILLS_DIR="$persona_dir/skills"

    debug "Created persona: $name"
    printf 'Created and switched to new persona: %s\n' "$name" >&2
}

cmd_personas() {
    local show_dir=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -a|--all) show_dir=1; shift ;;
            *) break ;;
        esac
    done

    local personas_dir="$SHELLY_DIR/personas"
    if [[ ! -d "$personas_dir" ]]; then
        echo "No personas." >&2
        return
    fi

    local dirs
    dirs=$(ls -1 "$personas_dir" 2>/dev/null | grep -v '^current$') || true
    if [[ -z "$dirs" ]]; then
        echo "No personas." >&2
        return
    fi

    # Find current persona for marking
    local current_name=""
    if [[ -L "$SHELLY_DIR/personas/current" ]]; then
        local cur_target
        cur_target=$(readlink "$SHELLY_DIR/personas/current")
        current_name=$(basename "$cur_target")
    fi

    local d
    while IFS= read -r d; do
        local marker=" "
        [[ "$d" == "$current_name" ]] && marker="*"

        # Get created date from info.txt (fall back to started= for legacy files)
        local created=""
        local info="$personas_dir/$d/info.txt"
        if [[ -f "$info" ]]; then
            created=$(grep '^created=' "$info" 2>/dev/null | cut -d= -f2-) || true
            [[ -z "$created" ]] && created=$(grep '^started=' "$info" 2>/dev/null | cut -d= -f2-) || true
        fi

        if [[ "$show_dir" -eq 1 ]]; then
            local abs_dir
            abs_dir=$(cd "$personas_dir/$d" 2>/dev/null && pwd) || abs_dir="$personas_dir/$d"
            printf '%s %-20s %s  %s\n' "$marker" "$d" "$created" "$abs_dir"
        else
            printf '%s %-20s %s\n' "$marker" "$d" "$created"
        fi
    done <<< "$dirs"
}

cmd_persona_info() {
    ensure_persona
    local persona_dir
    persona_dir=$(resolve_persona)

    local persona_name
    persona_name=$(grep '^name=' "$persona_dir/info.txt" 2>/dev/null | cut -d= -f2-) || true
    [[ -z "$persona_name" ]] && persona_name=$(basename "$persona_dir")

    local created
    created=$(grep '^created=' "$persona_dir/info.txt" 2>/dev/null | cut -d= -f2-) || true
    [[ -z "$created" ]] && created=$(grep '^started=' "$persona_dir/info.txt" 2>/dev/null | cut -d= -f2-) || true

    local cwd
    cwd=$(grep '^cwd=' "$persona_dir/info.txt" 2>/dev/null | cut -d= -f2-) || true

    printf 'Name:     %s\n' "$persona_name"
    printf 'Created:  %s\n' "${created:-(unknown)}"
    printf 'Dir:      %s\n' "$persona_dir"
    [[ -n "$cwd" ]] && printf 'Cwd:      %s\n' "$cwd"

    # Kernel skills
    local kernel_count=0
    local kernel_names=""
    if [[ -d "$persona_dir/kernel" ]]; then
        local skill_dir
        for skill_dir in "$persona_dir/kernel"/*/; do
            [[ -f "${skill_dir}SKILL.md" ]] || continue
            kernel_count=$((kernel_count + 1))
            local sname
            sname=$(basename "$skill_dir")
            kernel_names="${kernel_names}${kernel_names:+, }${sname}"
        done
    fi
    printf 'Kernel:   %d (%s)\n' "$kernel_count" "${kernel_names:--}"

    # Installed skills
    local skills_count=0
    local skills_names=""
    if [[ -d "$persona_dir/skills" ]]; then
        local skill_dir
        for skill_dir in "$persona_dir/skills"/*/; do
            [[ -f "${skill_dir}SKILL.md" ]] || continue
            skills_count=$((skills_count + 1))
            local sname
            sname=$(basename "$skill_dir")
            skills_names="${skills_names}${skills_names:+, }${sname}"
        done
    fi
    printf 'Skills:   %d (%s)\n' "$skills_count" "${skills_names:--}"

    # Memory count
    local mem_count=0
    if [[ -d "$persona_dir/memories" ]]; then
        mem_count=$(find "$persona_dir/memories" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')
    fi
    printf 'Memories: %d\n' "$mem_count"

    # Traj turns
    local traj_count=0
    if [[ -f "$persona_dir/traj/root.jsonl" ]]; then
        traj_count=$(wc -l < "$persona_dir/traj/root.jsonl" | tr -d ' ')
    fi
    printf 'History:  %d turns\n' "$traj_count"
}

cmd_switch() {
    local target="$1"
    [[ -z "$target" ]] && die "Usage: shelly switch <name>"

    local personas_dir="$SHELLY_DIR/personas"
    [[ ! -d "$personas_dir" ]] && die "No personas found"

    # Try exact match first
    if [[ -d "$personas_dir/$target" ]]; then
        ln -sfn "$target" "$SHELLY_DIR/personas/current"
        ensure_persona
        printf 'Switched to: %s\n' "$target" >&2
        return
    fi

    # Prefix/substring match
    local matches
    matches=$(ls -1 "$personas_dir" 2>/dev/null | grep -v '^current$' | grep "$target" || true)
    local count
    count=$(printf '%s' "$matches" | grep -c . 2>/dev/null) || count=0

    if [[ "$count" -eq 1 ]]; then
        ln -sfn "$matches" "$SHELLY_DIR/personas/current"
        ensure_persona
        printf 'Switched to: %s\n' "$matches" >&2
    elif [[ "$count" -gt 1 ]]; then
        die "Ambiguous: '$target' matches multiple personas:
$matches"
    else
        die "No persona matching: $target"
    fi
}

cmd_delete() {
    local target="$1"
    [[ -z "$target" ]] && die "Usage: shelly personas delete <name>"

    local personas_dir="$SHELLY_DIR/personas"
    [[ ! -d "$personas_dir/$target" ]] && die "No persona named: $target"

    # Don't allow deleting the current persona
    local current_name=""
    if [[ -L "$SHELLY_DIR/personas/current" ]]; then
        current_name=$(basename "$(readlink "$SHELLY_DIR/personas/current")")
    fi
    if [[ "$target" == "$current_name" ]]; then
        die "Cannot delete the active persona. Switch to another first."
    fi

    # Destroy Docker containers for this persona
    _destroy_persona_containers "$personas_dir/$target"

    rm -rf "$personas_dir/$target"
    printf 'Deleted persona: %s\n' "$target" >&2
}

cmd_history() {
    ensure_persona
    local persona_dir
    persona_dir=$(resolve_persona)
    local traj_dir="$persona_dir/traj"

    # Try traj first, fall back to legacy history.jsonl
    local traj_file
    traj_file=$(traj_resolve_file "$traj_dir")

    if [[ -z "$traj_file" ]]; then
        echo "(empty history)" >&2
        return
    fi

    while IFS= read -r line; do
        local step_type content role
        step_type=$(printf '%s' "$line" | jq -r '.type // empty' 2>/dev/null)

        if [[ -n "$step_type" ]]; then
            # New traj format
            content=$(printf '%s' "$line" | jq -r '.content // empty')
            case "$step_type" in
                human-msg)  printf '> %s\n\n' "$content" ;;
                agent-msg)  printf '%s\n\n' "$content" ;;
            esac
        else
            # Legacy history.jsonl format
            role=$(printf '%s' "$line" | jq -r '.role // ""')
            content=$(printf '%s' "$line" | jq -r '.content // ""')
            if [[ "$role" == "user" ]]; then
                printf '> %s\n\n' "$content"
            elif [[ "$role" == "assistant" ]]; then
                printf '%s\n\n' "$content"
            fi
        fi
    done < "$traj_file"
}

# Resolve the file to read history from: traj root.jsonl, legacy trajectory.jsonl,
# or legacy history.jsonl. Returns empty string if no history exists.
traj_resolve_file() {
    local traj_dir="$1"
    local persona_dir
    persona_dir=$(dirname "$traj_dir")

    if [[ -f "$traj_dir/root.jsonl" ]] && [[ -s "$traj_dir/root.jsonl" ]]; then
        printf '%s' "$traj_dir/root.jsonl"
    elif [[ -f "$traj_dir/trajectory.jsonl" ]] && [[ -s "$traj_dir/trajectory.jsonl" ]]; then
        printf '%s' "$traj_dir/trajectory.jsonl"
    elif [[ -f "$persona_dir/history.jsonl" ]] && [[ -s "$persona_dir/history.jsonl" ]]; then
        printf '%s' "$persona_dir/history.jsonl"
    fi
}

cmd_reset() {
    ensure_persona
    local persona_dir
    persona_dir=$(resolve_persona)
    local persona_name
    persona_name=$(basename "$persona_dir")

    # Destroy Docker containers and shellm state for this persona
    _destroy_persona_containers "$persona_dir"
    rm -rf "$persona_dir/.shellm"

    # Clear traj directory
    rm -rf "$persona_dir/traj"
    mkdir -p "$persona_dir/traj"

    # Also clear legacy history if present
    rm -f "$persona_dir/history.jsonl"

    # Remove shellm workdir
    rm -rf "$persona_dir/workdir"

    debug "Cleared persona: $persona_dir"
    printf 'Persona reset: %s\n' "$persona_name" >&2
}

cmd_envs() {
    ensure_persona
    local persona_dir
    persona_dir=$(resolve_persona)
    local envs_dir="$persona_dir/.shellm/envs"
    local sub="${1:-list}"
    [[ -n "${1:-}" ]] && shift

    case "$sub" in
        list)
            if [[ ! -d "$envs_dir" ]] || [[ -z "$(ls -A "$envs_dir" 2>/dev/null)" ]]; then
                printf 'No envs for this persona.\n' >&2
                return
            fi
            local env_dir
            for env_dir in "$envs_dir"/*/; do
                [[ -d "$env_dir" ]] || continue
                local name created status
                name=$(basename "$env_dir")
                created=""
                [[ -f "$env_dir/created" ]] && created=$(cat "$env_dir/created" 2>/dev/null || true)
                status="gone"
                if [[ -f "$env_dir/container_id" ]]; then
                    local cid
                    cid=$(cat "$env_dir/container_id" 2>/dev/null || true)
                    if [[ -n "$cid" ]]; then
                        local state
                        state=$(docker inspect -f '{{.State.Status}}' "$cid" 2>/dev/null || true)
                        if [[ "$state" == "running" ]]; then
                            status="running"
                        elif [[ -n "$state" ]]; then
                            status="stopped"
                        fi
                    fi
                fi
                printf '%-30s  %-10s  %s\n' "$name" "$status" "$created"
            done
            ;;
        rm)
            local name="${1:-}"
            [[ -z "$name" ]] && die "Usage: shelly envs rm <name>"
            local target_dir="$envs_dir/$name"
            [[ -d "$target_dir" ]] || die "No env named: $name"
            if [[ -f "$target_dir/container_id" ]]; then
                local cid
                cid=$(cat "$target_dir/container_id" 2>/dev/null || true)
                [[ -n "$cid" ]] && docker rm -f "$cid" >/dev/null 2>&1 || true
            fi
            rm -rf "$target_dir"
            printf 'Removed env: %s\n' "$name" >&2
            ;;
        *)
            die "Unknown envs subcommand: $sub (try: list, rm)"
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Autonomous mode commands
# ---------------------------------------------------------------------------

cmd_think() {
    local dry_run=0
    local model="$SHELLY_THINK_MODEL"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run) dry_run=1; shift ;;
            --model)   model="${2:?--model requires a value}"; shift 2 ;;
            *) break ;;
        esac
    done

    ensure_persona
    local persona_dir
    persona_dir=$(resolve_persona)
    local traj_dir="$persona_dir/traj"
    local persona_name
    persona_name=$(grep '^name=' "$persona_dir/info.txt" 2>/dev/null | cut -d= -f2-) || true
    [[ -z "$persona_name" ]] && persona_name=$(basename "$persona_dir")

    # Ensure think prompt exists
    ensure_think_prompt "$persona_dir"

    # Build goals and load think prompt
    local goals
    goals=$(get_goals "$SHELLY_MEMORIES_DIR")
    local think_prompt
    think_prompt=$(load_prompt "$persona_dir/prompts/think.md" "$persona_name" "$goals")

    # Build recent context for the think prompt input
    local recent_context=""
    if [[ -f "$traj_dir/root.jsonl" ]]; then
        recent_context=$(traj tail "$traj_dir" -n "$SHELLY_CONTEXT_TAIL" 2>/dev/null) || recent_context=""
    fi

    local full_message="<context>
$think_prompt
</context>

Recent stream (last $SHELLY_CONTEXT_TAIL steps):
$recent_context"

    if [[ "$dry_run" -eq 1 ]]; then
        printf '[think dry-run] Would call shellm with think prompt (%d bytes)\n' "${#think_prompt}" >&2
        printf '[think dry-run] Goals:\n%s\n' "$goals" >&2
        printf '[think dry-run] Recent context: %d bytes\n' "${#recent_context}" >&2
        return 0
    fi

    # Resolve paths
    local abs_mem_dir abs_skills_dir abs_kernel_dir abs_traj_dir run_dir
    abs_mem_dir=$(cd "$SHELLY_MEMORIES_DIR" 2>/dev/null && pwd) || abs_mem_dir="$SHELLY_MEMORIES_DIR"
    abs_skills_dir=$(cd "$SHELLY_SKILLS_DIR" 2>/dev/null && pwd) || abs_skills_dir="$SHELLY_SKILLS_DIR"
    abs_kernel_dir=$(cd "$SHELLY_KERNEL_DIR" 2>/dev/null && pwd) || abs_kernel_dir="$SHELLY_KERNEL_DIR"
    abs_traj_dir=$(cd "$traj_dir" 2>/dev/null && pwd) || abs_traj_dir="$traj_dir"
    run_dir="$persona_dir/workdir"
    mkdir -p "$run_dir"

    # Collect --var flags from skill-declared vars
    local skill_var_flags=()
    while IFS= read -r vname; do
        [[ -z "$vname" ]] && continue
        local vval="${!vname:-}"
        [[ -n "$vval" ]] && skill_var_flags+=(--var "$vname=$vval")
    done < <(collect_skill_vars "$persona_dir")

    export SHELLM_HOME="$persona_dir/.shellm"

    # Call shellm with think prompt
    local response shellm_stderr_file
    shellm_stderr_file=$(mktemp)
    response=$(SHELLM_NO_BANNER=1 SHELLM_MODEL="$model" \
        shellm --env "$persona_name" --workdir "$run_dir" \
        --var "MEM_DIR=$abs_mem_dir" \
        --var "SKILLS_DIR=$abs_skills_dir" \
        --var "SKILLS_KERNEL_DIR=$abs_kernel_dir" \
        --var "TRAJ_DIR=$abs_traj_dir" \
        ${skill_var_flags[@]+"${skill_var_flags[@]}"} \
        --bin "$(command -v mem)" \
        --bin "$(command -v traj)" \
        --bin "$(command -v skills)" \
        --bin "$(command -v context)" \
        --bin "$(command -v llm)" \
        --bin "$(command -v shellm)" \
        "$full_message" 2>"$shellm_stderr_file") || true
    if [[ "$VERBOSE" -eq 1 && -s "$shellm_stderr_file" ]]; then
        debug "shellm stderr: $(cat "$shellm_stderr_file")"
    fi
    rm -f "$shellm_stderr_file"

    [[ -z "$response" ]] && { debug "think: empty response from shellm"; return 1; }

    # Determine step type: action if starts with "action: "
    local step_type="thought"
    case "$response" in
        "action: "*|"action:"*)
            step_type="action"
            ;;
    esac

    # Write thought to traj (unless shellm already did via the prompt instructions)
    # Check if the traj's last entry already contains this thought (shellm may have written it in stage 5)
    local last_content=""
    if [[ -f "$traj_dir/root.jsonl" ]]; then
        last_content=$(tail -1 "$traj_dir/root.jsonl" 2>/dev/null | jq -r '.content // empty' 2>/dev/null) || true
    fi

    if [[ "$last_content" != "$response" ]]; then
        printf '{"type":"%s","content":%s,"source":"think"}' \
            "$step_type" "$(printf '%s' "$response" | jq -Rsa .)" \
            | traj append "$traj_dir" >/dev/null
    fi

    # Print the thought
    printf '[%s] %s\n' "$step_type" "$response"

    # If action, execute it
    if [[ "$step_type" == "action" ]]; then
        local action_body="${response#action: }"
        [[ "$action_body" == "$response" ]] && action_body="${response#action:}"
        _do_act "$action_body" "$persona_dir" "$traj_dir" "$persona_name" "$model"
    fi

    # Dispatch thought processes
    _dispatch_thought_processes "$persona_dir" "$traj_dir" "$persona_name" "$model"
}

_do_act() {
    local action_body="$1"
    local persona_dir="$2"
    local traj_dir="$3"
    local persona_name="$4"
    local model="$5"

    [[ -z "$action_body" ]] && return 0

    debug "act: executing action: $action_body"

    # Record agent-run step (metadata)
    local run_id
    run_id=$(printf '%s' "act-$(date +%s)-$$")
    printf '{"type":"agent-run","content":%s,"run_id":"%s"}' \
        "$(printf '%s' "$action_body" | jq -Rsa .)" "$run_id" \
        | traj append "$traj_dir" >/dev/null

    # Build the full system prompt (same as cmd_send uses)
    local system_prompt
    system_prompt=$(build_shelly_system_prompt "$persona_dir")

    local abs_mem_dir abs_skills_dir abs_kernel_dir abs_traj_dir run_dir
    abs_mem_dir=$(cd "$SHELLY_MEMORIES_DIR" 2>/dev/null && pwd) || abs_mem_dir="$SHELLY_MEMORIES_DIR"
    abs_skills_dir=$(cd "$SHELLY_SKILLS_DIR" 2>/dev/null && pwd) || abs_skills_dir="$SHELLY_SKILLS_DIR"
    abs_kernel_dir=$(cd "$SHELLY_KERNEL_DIR" 2>/dev/null && pwd) || abs_kernel_dir="$SHELLY_KERNEL_DIR"
    abs_traj_dir=$(cd "$traj_dir" 2>/dev/null && pwd) || abs_traj_dir="$traj_dir"
    run_dir="$persona_dir/workdir"

    # Collect skill vars
    local skill_var_flags=()
    while IFS= read -r vname; do
        [[ -z "$vname" ]] && continue
        local vval="${!vname:-}"
        [[ -n "$vval" ]] && skill_var_flags+=(--var "$vname=$vval")
    done < <(collect_skill_vars "$persona_dir")

    local act_prompt="<context>
$system_prompt
</context>

You are executing an action from your thought stream. Do the work described below.
When you are done, if there is a meaningful observation or result to record, write it to your trajectory:
  printf '{\"type\":\"observation\",\"content\":<json-escaped result>}' | traj append \$TRAJ_DIR
Then set FINAL to signal completion (FINAL content is not important, only traj matters).
If there is nothing meaningful to observe, just set FINAL.

ACTION: $action_body"

    export SHELLM_HOME="$persona_dir/.shellm"

    local act_response
    act_response=$(SHELLM_NO_BANNER=1 SHELLM_MODEL="$model" \
        shellm --env "$persona_name" --workdir "$run_dir" \
        --var "MEM_DIR=$abs_mem_dir" \
        --var "SKILLS_DIR=$abs_skills_dir" \
        --var "SKILLS_KERNEL_DIR=$abs_kernel_dir" \
        --var "TRAJ_DIR=$abs_traj_dir" \
        ${skill_var_flags[@]+"${skill_var_flags[@]}"} \
        --bin "$(command -v mem)" \
        --bin "$(command -v skills)" \
        --bin "$(command -v traj)" \
        --bin "$(command -v context)" \
        --bin "$(command -v llm)" \
        --bin "$(command -v shellm)" \
        "$act_prompt" 2>/dev/null) || true

    if [[ -n "$act_response" ]]; then
        debug "act: completed (response: ${#act_response} bytes)"
        printf '  [observation] %s\n' "$(printf '%s' "$act_response" | head -1)"
    fi
}

_dispatch_thought_processes() {
    local persona_dir="$1"
    local traj_dir="$2"
    local persona_name="$3"
    local model="$4"

    local tp_list
    tp_list=$(discover_thought_processes "$persona_dir")
    [[ -z "$tp_list" ]] && return 0

    # Build recent thoughts for injection
    local recent_thoughts=""
    if [[ -f "$traj_dir/root.jsonl" ]]; then
        recent_thoughts=$(traj tail "$traj_dir" -n 15 2>/dev/null) || recent_thoughts=""
    fi

    local goals
    goals=$(get_goals "$SHELLY_MEMORIES_DIR")

    local abs_mem_dir abs_traj_dir run_dir persona_tp_dir
    abs_mem_dir=$(cd "$SHELLY_MEMORIES_DIR" 2>/dev/null && pwd) || abs_mem_dir="$SHELLY_MEMORIES_DIR"
    abs_traj_dir=$(cd "$traj_dir" 2>/dev/null && pwd) || abs_traj_dir="$traj_dir"
    run_dir="$persona_dir/workdir"
    persona_tp_dir="$persona_dir/thought-processes"
    mkdir -p "$persona_tp_dir"

    export SHELLM_HOME="$persona_dir/.shellm"

    local line
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        local tp_name="${line%%=*}"
        local tp_file="${line#*=}"
        [[ -f "$tp_file" ]] || continue

        debug "tp: triaging $tp_name"

        # Load and prepare TP prompt
        local tp_prompt
        tp_prompt=$(load_prompt "$tp_file" "$persona_name" "$goals")

        local tp_message="<context>
$tp_prompt
</context>

Recent thoughts from the stream:
$recent_thoughts"

        # Call shellm for this TP
        local tp_response
        tp_response=$(SHELLM_NO_BANNER=1 SHELLM_MODEL="$model" \
            shellm --env "$persona_name" --workdir "$run_dir" \
            --var "MEM_DIR=$abs_mem_dir" \
            --var "TRAJ_DIR=$abs_traj_dir" \
            --var "PERSONA_TP_DIR=$persona_tp_dir" \
            --bin "$(command -v mem)" \
            --bin "$(command -v traj)" \
            --bin "$(command -v llm)" \
            "$tp_message" 2>/dev/null) || true

        if [[ -n "$tp_response" ]]; then
            debug "tp: $tp_name ran (response: ${#tp_response} bytes)"
            printf '  [tp:%s] %s\n' "$tp_name" "$(printf '%s' "$tp_response" | head -1)"
        fi
    done <<< "$tp_list"
}

cmd_start() {
    local tick_interval="$SHELLY_TICK_INTERVAL"
    local max_ticks=0
    local model="$SHELLY_THINK_MODEL"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --tick-interval) tick_interval="${2:?--tick-interval requires seconds}"; shift 2 ;;
            --max-ticks)     max_ticks="${2:?--max-ticks requires a number}"; shift 2 ;;
            --model)         model="${2:?--model requires a value}"; shift 2 ;;
            *) break ;;
        esac
    done

    ensure_persona
    local persona_dir
    persona_dir=$(resolve_persona)
    local lock_dir="$persona_dir/run.lock"

    # Acquire lock (only start locks — prevents two loops for same persona)
    if ! acquire_lock "$lock_dir"; then
        die "Another loop is already running for this persona (lock: $lock_dir)"
    fi

    # Set up cleanup
    local stop_flag="$persona_dir/stop.flag"
    rm -f "$stop_flag"

    trap 'release_lock "$lock_dir"; rm -f "$stop_flag"' EXIT
    trap 'release_lock "$lock_dir"; rm -f "$stop_flag"; exit 130' INT TERM

    printf '[shelly] Autonomous loop started (interval: %ss)\n' "$tick_interval" >&2

    local tick_count=0
    while true; do
        # Check stop flag
        if [[ -f "$stop_flag" ]]; then
            printf '[shelly] Stop flag detected. Shutting down.\n' >&2
            break
        fi

        tick_count=$((tick_count + 1))
        printf '[tick %d]\n' "$tick_count" >&2

        # Run one think cycle
        cmd_think --model "$model" || true

        # Check max ticks
        if [[ "$max_ticks" -gt 0 && "$tick_count" -ge "$max_ticks" ]]; then
            printf '[shelly] Reached max ticks (%d). Stopping.\n' "$max_ticks" >&2
            break
        fi

        # Sleep between ticks (interruptible)
        sleep "$tick_interval" &
        local sleep_pid=$!
        wait "$sleep_pid" 2>/dev/null || break
    done

    release_lock "$lock_dir"
    rm -f "$stop_flag"
    trap - EXIT INT TERM
    printf '[shelly] Autonomous loop stopped.\n' >&2
}

cmd_stop() {
    ensure_persona
    local persona_dir
    persona_dir=$(resolve_persona)
    local stop_flag="$persona_dir/stop.flag"
    touch "$stop_flag"
    printf '[shelly] Stop flag set. Loop will exit after current tick.\n' >&2
}

cmd_focus() {
    ensure_persona
    local sub="${1:-show}"
    [[ -n "${1:-}" ]] && shift

    case "$sub" in
        set)
            local goal_text="$*"
            [[ -z "$goal_text" ]] && die "Usage: shelly focus set <goal text>"
            MEM_DIR="$SHELLY_MEMORIES_DIR" mem add --type goal "$goal_text"
            printf 'Goal set: %s\n' "$goal_text" >&2
            ;;
        show)
            local goals
            goals=$(get_goals "$SHELLY_MEMORIES_DIR")
            printf 'Current goals:\n%s\n' "$goals"
            ;;
        done)
            local query="$*"
            [[ -z "$query" ]] && die "Usage: shelly focus done <goal query>"
            # Find and remove the matching goal memory
            MEM_DIR="$SHELLY_MEMORIES_DIR" mem forget "$query" 2>/dev/null || \
                die "No goal matching: $query"
            printf 'Goal removed: %s\n' "$query" >&2
            ;;
        *)
            die "Unknown focus subcommand: $sub (try: set, show, done)"
            ;;
    esac
}

cmd_log() {
    ensure_persona
    local n="${1:-20}"
    local persona_dir
    persona_dir=$(resolve_persona)
    local traj_dir="$persona_dir/traj"
    if [[ -f "$traj_dir/root.jsonl" ]]; then
        traj tail "$traj_dir" -n "$n" | jq -r '
            "[" + .type + "] " +
            (if .source then "(" + .source + ") " else "" end) +
            (.content // "(no content)" | split("\n")[0])
        '
    else
        printf '(empty log)\n' >&2
    fi
}

cmd_append() {
    local step_type="human-msg"
    local text=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type) step_type="${2:?--type requires a value}"; shift 2 ;;
            *)
                if [[ -z "$text" ]]; then
                    text="$*"
                    break
                fi
                ;;
        esac
    done

    # Read from stdin if no args
    if [[ -z "$text" && ! -t 0 ]]; then
        text=$(cat)
    fi
    [[ -z "$text" ]] && die "Usage: shelly append [--type TYPE] <text>"

    ensure_persona
    local persona_dir
    persona_dir=$(resolve_persona)
    local traj_dir="$persona_dir/traj"

    printf '{"type":"%s","content":%s}' "$step_type" "$(printf '%s' "$text" | jq -Rsa .)" \
        | traj append "$traj_dir" >/dev/null
    debug "Appended $step_type step to traj"
}

cmd_triage_tps() {
    ensure_persona
    local persona_dir
    persona_dir=$(resolve_persona)
    local traj_dir="$persona_dir/traj"
    local persona_name
    persona_name=$(grep '^name=' "$persona_dir/info.txt" 2>/dev/null | cut -d= -f2-) || true
    [[ -z "$persona_name" ]] && persona_name=$(basename "$persona_dir")
    _dispatch_thought_processes "$persona_dir" "$traj_dir" "$persona_name" "$SHELLY_THINK_MODEL"
}

# ---------------------------------------------------------------------------
# Original subcommands
# ---------------------------------------------------------------------------

cmd_whoami() {
    ensure_persona
    local persona_dir
    persona_dir=$(resolve_persona)
    local persona_name
    persona_name=$(grep '^name=' "$persona_dir/info.txt" 2>/dev/null | cut -d= -f2-) || true
    [[ -z "$persona_name" ]] && persona_name=$(basename "$persona_dir")
    printf '%s\n' "$persona_name"
    if [[ "${1:-}" == "-a" ]]; then
        printf '%s\n' "$persona_dir"
    fi
}

cmd_context() {
    ensure_persona
    local persona_dir
    persona_dir=$(resolve_persona)
    build_shelly_system_prompt "$persona_dir"
    printf '\n'
}

cmd_help() {
    cat <<'EOF'
shelly — Autonomous agent with stream-of-consciousness thought generation

Usage:
  shelly send <message>        Inject a message and run 10 ticks
  shelly start                 Start the autonomous thought loop
  shelly stop                  Stop the autonomous loop
  shelly think [--dry-run]     Run one think cycle (generate + act + TPs)
  shelly log [N]               Show last N steps from the thought stream
  shelly append [--type T] <text>  Inject a step into the stream
  shelly focus set <goal>      Set a goal
  shelly focus show            Show current goals
  shelly focus done <query>    Mark a goal as done

  shelly repl                  Interactive mode (loop + live stream)
  shelly history               Show conversation history
  shelly reset                 Reset current persona
  shelly whoami [-a]           Print current persona name (-a: also print persona dir)
  shelly context               Show assembled system prompt

Docker Envs:
  shelly envs                  List Docker envs for current persona
  shelly envs rm <name>        Destroy a specific env

Personas:
  shelly personas              List all personas
  shelly personas list [-a]    List all personas (-a: show directories)
  shelly personas info         Show detailed info about current persona
  shelly personas new <name>   Create a new persona
  shelly personas switch <name> Switch to a persona (prefix match)
  shelly personas delete <name> Delete a persona

Memory:
  shelly mem add <text>        Add a memory (or pipe via stdin)
  shelly mem search <query>    Search memories (semantic via shellm)
  shelly mem list              List memories (dates + slugs)
  shelly mem dump              Print all memory summaries
  shelly mem forget <name>     Delete a memory by name/prefix
  shelly mem edit <name> <text> Update a memory's body

Skills:
  shelly skills                       List installed skills
  shelly skills <query>               Search installed + remote skills
  shelly skills show <name>           Print a skill's SKILL.md
  shelly skills install <name|src>    Install a skill (name, owner/repo, URL, or path)
  shelly skills remove <name>        Remove an installed skill
  shelly skills init [name]          Scaffold a new skill
  shelly skills promote <name>       Promote a skill to kernel
  shelly skills demote <name>        Demote a kernel skill
  shelly skills kernel               Show kernel skills with token counts
  shelly skills remote               List configured skill remotes
  shelly skills remote add <url|path>    Add a skill remote
  shelly skills remote remove <url|path> Remove a skill remote

Options:
  --model MODEL           Model to use (default: claude-opus-4-6)
  --dir DIR               Override .shelly directory
  -v, --verbose           Verbose/debug mode
  -h, --help              Show this help

Environment:
  SHELLY_DIR              Override .shelly directory
  SHELLY_MODEL            Model to use
  SHELLY_TICK_INTERVAL    Seconds between ticks (default: 30)
  SHELLY_THINK_MODEL      Model for think/TP calls (default: claude-opus-4-7)
  SHELLY_CONTEXT_TAIL     Number of recent steps to include in think context (default: 30)
EOF
    exit 0
}

# ---------------------------------------------------------------------------
# Argument parsing & dispatch
# ---------------------------------------------------------------------------

main() {
    # Parse global flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                cmd_help
                ;;
            -v|--verbose)
                VERBOSE=1
                shift
                ;;
            --model)
                SHELLY_MODEL="${2:?--model requires a value}"
                shift 2
                ;;
            --dir)
                SHELLY_DIR="${2:?--dir requires a path}"
                shift 2
                ;;
            -*)
                die "Unknown option: $1 (try shelly --help)"
                ;;
            *)
                break
                ;;
        esac
    done

    ensure_persona

    local cmd="${1:-}"
    [[ -n "$cmd" ]] && shift

    case "$cmd" in
        send)
            cmd_send "$@"
            ;;
        start)
            cmd_start "$@"
            ;;
        stop)
            cmd_stop
            ;;
        think)
            cmd_think "$@"
            ;;
        focus)
            cmd_focus "$@"
            ;;
        log)
            cmd_log "$@"
            ;;
        append)
            cmd_append "$@"
            ;;
        triage)
            cmd_triage_tps
            ;;
        repl)
            cmd_repl
            ;;
        personas|ls)
            local sub="${1:-}"
            [[ -n "$sub" ]] && shift
            case "$sub" in
                new)
                    [[ $# -eq 0 ]] && die "Usage: shelly personas new <name>"
                    cmd_new "$1"
                    ;;
                switch)
                    [[ $# -eq 0 ]] && die "Usage: shelly personas switch <name>"
                    cmd_switch "$1"
                    ;;
                delete)
                    [[ $# -eq 0 ]] && die "Usage: shelly personas delete <name>"
                    cmd_delete "$1"
                    ;;
                info)
                    cmd_persona_info
                    ;;
                list|"")
                    cmd_personas "$@"
                    ;;
                -a|--all)
                    cmd_personas "$sub" "$@"
                    ;;
                *)
                    die "Unknown personas subcommand: $sub (try: new, list, switch, delete, info)"
                    ;;
            esac
            ;;
        history)
            cmd_history
            ;;
        reset)
            cmd_reset
            ;;
        whoami)
            cmd_whoami "$@"
            ;;
        context)
            cmd_context
            ;;
        envs)
            cmd_envs "$@"
            ;;
        mem)
            MEM_DIR="$SHELLY_MEMORIES_DIR" mem "$@"
            ;;
        skills)
            SKILLSRC="$SHELLY_SKILLS_DIR/.skillsrc" SKILLS_DIR="$SHELLY_SKILLS_DIR" SKILLS_KERNEL_DIR="$SHELLY_KERNEL_DIR" skills "$@"
            ;;
        help)
            cmd_help
            ;;
        "")
            # Default to repl
            cmd_repl
            ;;
        *)
            # Treat unknown command as a message to send
            cmd_send "$cmd $*"
            ;;
    esac
}

main "$@"
