#!/usr/bin/env bash
set -euo pipefail

die() { echo "shellm-docker-broker: error: $*" >&2; exit 1; }

usage() {
    cat <<'EOF'
Usage:
  shellm-docker-broker start --env NAME --workdir DIR --dir DIR --transport socket|filesystem --pid-file FILE --log FILE
  shellm-docker-broker stop --pid-file FILE
  shellm-docker-broker serve-one
  shellm-docker-broker serve-filesystem

This is a host-side broker for shellm's constrained Docker access mode.
EOF
}

log_msg() {
    local log="${SHELLM_BROKER_LOG:-}"
    [[ -n "$log" ]] || return 0
    mkdir -p "$(dirname "$log")"
    printf '%s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$*" >> "$log"
}

json_response() {
    local exit_code="$1"
    local stdout_file="$2"
    local stderr_file="$3"
    jq -n \
        --argjson exit_code "$exit_code" \
        --rawfile stdout "$stdout_file" \
        --rawfile stderr "$stderr_file" \
        '{exit_code:$exit_code,stdout:$stdout,stderr:$stderr}'
}

json_error() {
    local exit_code="$1"
    local message="$2"
    log_msg "reject exit=$exit_code $message"
    jq -n --argjson exit_code "$exit_code" --arg message "$message" \
        '{exit_code:$exit_code,stdout:"",stderr:("shellm-docker: " + $message + "\n")}'
}

valid_image() {
    [[ "$1" != -* && "$1" =~ ^[A-Za-z0-9._/:@-]+$ ]]
}

valid_tag() {
    [[ "$1" != -* && "$1" =~ ^[A-Za-z0-9._/:@-]+$ ]]
}

valid_container_ref() {
    [[ "$1" =~ ^[A-Za-z0-9_.-]+$ ]]
}

valid_env_key() {
    [[ "$1" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]
}

valid_compose_project_name() {
    [[ "$1" =~ ^[a-z0-9][a-z0-9_-]*$ ]]
}

path_under() {
    local path="$1"
    local root="$2"
    [[ "$path" == "$root" || "$path" == "$root"/* ]]
}

symlink_mounts() {
    local workdir="$1"
    local -A mount_dirs=()
    while IFS= read -r -d '' link; do
        local target
        target=$(readlink -f "$link" 2>/dev/null) || continue
        path_under "$target" "$workdir" && continue
        [[ -e "$target" ]] || continue
        local parent
        parent=$(dirname "$target")
        mount_dirs["$parent"]=1
    done < <(find "$workdir" -type l -print0 2>/dev/null)

    # Remove dirs that are subdirs of other dirs in the set
    local -a unique=()
    local dir other
    for dir in "${!mount_dirs[@]}"; do
        local dominated=false
        for other in "${!mount_dirs[@]}"; do
            [[ "$dir" == "$other" ]] && continue
            if path_under "$dir" "$other"; then
                dominated=true
                break
            fi
        done
        $dominated || unique+=("$dir")
    done

    for dir in "${unique[@]}"; do
        printf -- '-v\n%s:%s:ro\n' "$dir" "$dir"
    done
}

safe_cwd() {
    local requested="$1"
    local workdir="$2"
    local resolved
    resolved=$(realpath "$requested" 2>/dev/null || true)
    if [[ -n "$resolved" ]] && path_under "$resolved" "$workdir"; then
        printf '%s\n' "$resolved"
    else
        printf '%s\n' "$workdir"
    fi
}

resolve_under_workdir() {
    local path="$1"
    local base="$2"
    local workdir="$3"
    local candidate resolved
    if [[ "$path" == /* ]]; then
        candidate="$path"
    else
        candidate="$base/$path"
    fi
    resolved=$(realpath "$candidate" 2>/dev/null || true)
    [[ -n "$resolved" ]] || return 1
    path_under "$resolved" "$workdir" || return 1
    printf '%s\n' "$resolved"
}

container_belongs_to_env() {
    local ref="$1"
    local env_name="$2"
    local label
    label=$(docker inspect -f '{{ index .Config.Labels "shellm.broker.env" }}' "$ref" 2>/dev/null || true)
    [[ "$label" == "$env_name" ]]
}

run_capture() {
    local out err rc
    out=$(mktemp)
    err=$(mktemp)
    set +e
    "$@" >"$out" 2>"$err"
    rc=$?
    set -e
    json_response "$rc" "$out" "$err"
    rm -f "$out" "$err"
}

apply_request_env() {
    local request="$1"
    local encoded key value
    while IFS= read -r encoded; do
        key=$(jq -nr --arg encoded "$encoded" '$encoded | @base64d | fromjson | .key')
        value=$(jq -nr --arg encoded "$encoded" '$encoded | @base64d | fromjson | .value')
        valid_env_key "$key" || continue
        case "$key" in
            BASH*|EUID|HOME|OLDPWD|PATH|PPID|PWD|SHELL|SHELLOPTS|UID) continue ;;
            COMPOSE_*|DOCKER_*) continue ;;
        esac
        export "$key=$value"
    done < <(printf '%s' "$request" | jq -r '(.env // {}) | to_entries[] | @base64')
}

run_capture_with_request_env() {
    local request="$1"
    local cwd="$2"
    shift 2
    local out err rc
    out=$(mktemp)
    err=$(mktemp)
    set +e
    (
        cd "$cwd" || exit 1
        apply_request_env "$request"
        "$@"
    ) >"$out" 2>"$err"
    rc=$?
    set -e
    json_response "$rc" "$out" "$err"
    rm -f "$out" "$err"
}

request_args() {
    local request="$1"
    printf '%s' "$request" | jq -r '.args[]?'
}

handle_run() {
    local request="$1"
    local env_name="$SHELLM_BROKER_ENV"
    local workdir="$SHELLM_BROKER_WORKDIR"
    local requested_cwd cwd
    requested_cwd=$(printf '%s' "$request" | jq -r '.cwd // empty')
    cwd=$(safe_cwd "$requested_cwd" "$workdir")

    local -a args=()
    while IFS= read -r arg; do
        args+=("$arg")
    done < <(request_args "$request")
    [[ "${#args[@]}" -ge 1 ]] || { json_error 64 "run requires IMAGE"; return; }

    local image="${args[0]}"
    valid_image "$image" || { json_error 64 "rejected invalid image name: $image"; return; }

    local -a command=()
    local start=1
    [[ "${args[1]:-}" == "--" ]] && start=2
    local i
    for ((i=start; i<${#args[@]}; i++)); do
        command+=("${args[$i]}")
    done

    local cpus="${SHELLM_BROKER_CPUS:-2}"
    local memory="${SHELLM_BROKER_MEMORY:-2g}"
    local pids="${SHELLM_BROKER_PIDS_LIMIT:-512}"

    local -a symlink_vols=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && symlink_vols+=("$line")
    done < <(symlink_mounts "$workdir")

    local -a cmd=(
        docker run --rm
        --label "shellm.broker=1"
        --label "shellm.broker.env=$env_name"
        --security-opt no-new-privileges
        --cpus "$cpus"
        --memory "$memory"
        --pids-limit "$pids"
        -v "$workdir:$workdir"
        "${symlink_vols[@]}"
        -w "$cwd"
        -e "SHELLM_WORKDIR=$workdir"
        "$image"
    )
    if [[ "${#command[@]}" -gt 0 ]]; then
        cmd+=("${command[@]}")
    fi
    log_msg "run image=$image cwd=$cwd argc=${#command[@]}"
    run_capture "${cmd[@]}"
}

handle_build() {
    local request="$1"
    local env_name="$SHELLM_BROKER_ENV"
    local workdir="$SHELLM_BROKER_WORKDIR"
    local requested_cwd cwd
    requested_cwd=$(printf '%s' "$request" | jq -r '.cwd // empty')
    cwd=$(safe_cwd "$requested_cwd" "$workdir")
    local -a args=()
    while IFS= read -r arg; do
        args+=("$arg")
    done < <(request_args "$request")
    [[ "${#args[@]}" -eq 2 ]] || { json_error 64 "build requires DIR TAG"; return; }

    local context="${args[0]}"
    local tag="${args[1]}"
    valid_tag "$tag" || { json_error 64 "rejected invalid tag: $tag"; return; }

    local abs_context
    abs_context=$(resolve_under_workdir "$context" "$cwd" "$workdir" 2>/dev/null || true)
    [[ -n "$abs_context" && -d "$abs_context" ]] || { json_error 64 "build context does not exist: $context"; return; }

    log_msg "build context=$abs_context tag=$tag"
    run_capture docker build \
        --label "shellm.broker=1" \
        --label "shellm.broker.env=$env_name" \
        -t "$tag" \
        "$abs_context"
}

handle_ps() {
    local env_name="$SHELLM_BROKER_ENV"
    log_msg "ps"
    run_capture docker ps --filter "label=shellm.broker.env=$env_name"
}

handle_logs() {
    local request="$1"
    local env_name="$SHELLM_BROKER_ENV"
    local -a args=()
    while IFS= read -r arg; do
        args+=("$arg")
    done < <(request_args "$request")
    [[ "${#args[@]}" -eq 1 ]] || { json_error 64 "logs requires CONTAINER"; return; }
    local ref="${args[0]}"
    valid_container_ref "$ref" || { json_error 64 "rejected invalid container ref"; return; }
    container_belongs_to_env "$ref" "$env_name" || { json_error 65 "container is not managed by this shellm broker"; return; }
    log_msg "logs ref=$ref"
    run_capture docker logs "$ref"
}

handle_rm() {
    local request="$1"
    local env_name="$SHELLM_BROKER_ENV"
    local -a args=()
    while IFS= read -r arg; do
        args+=("$arg")
    done < <(request_args "$request")
    [[ "${#args[@]}" -eq 1 ]] || { json_error 64 "rm requires CONTAINER"; return; }
    local ref="${args[0]}"
    valid_container_ref "$ref" || { json_error 64 "rejected invalid container ref"; return; }
    container_belongs_to_env "$ref" "$env_name" || { json_error 65 "container is not managed by this shellm broker"; return; }
    log_msg "rm ref=$ref"
    run_capture docker rm -f "$ref"
}

handle_info() {
    local request="$1"
    local -a args=()
    while IFS= read -r arg; do
        args+=("$arg")
    done < <(request_args "$request")
    log_msg "info"
    local -a cmd=(docker info)
    if [[ "${#args[@]}" -gt 0 ]]; then
        cmd+=("${args[@]}")
    fi
    run_capture "${cmd[@]}"
}

handle_version() {
    local request="$1"
    local -a args=()
    while IFS= read -r arg; do
        args+=("$arg")
    done < <(request_args "$request")
    log_msg "version argc=${#args[@]}"
    if [[ "${#args[@]}" -eq 1 && ( "${args[0]}" == "-v" || "${args[0]}" == "--version" ) ]]; then
        run_capture docker "${args[0]}"
        return
    fi
    local -a cmd=(docker version)
    if [[ "${#args[@]}" -gt 0 ]]; then
        cmd+=("${args[@]}")
    fi
    run_capture "${cmd[@]}"
}

compose_validate_model() {
    local request="$1"
    local cwd="$2"
    shift 2
    local config err rc
    config=$(mktemp)
    err=$(mktemp)
    rc=0
    (
        cd "$cwd" || exit 1
        apply_request_env "$request"
        docker compose "$@" config --format json
    ) >"$config" 2>"$err" || rc=$?
    if [[ "$rc" -ne 0 ]]; then
        cat "$err" >&2
        rm -f "$config" "$err"
        return "$rc"
    fi

    local request_workdir workdir_alias message
    request_workdir=$(printf '%s' "$request" | jq -r '.workdir // empty')
    workdir_alias=""
    if [[ -n "$request_workdir" ]] && [[ "$(realpath "$request_workdir" 2>/dev/null || true)" == "$SHELLM_BROKER_WORKDIR" ]]; then
        workdir_alias="$request_workdir"
    fi

    message=$(jq -r --arg workdir "$SHELLM_BROKER_WORKDIR" --arg workdir_alias "$workdir_alias" '
        def under_allowed_root($p):
          ($p | startswith($workdir)) or
          (($workdir_alias | length) > 0 and ($p | startswith($workdir_alias)));
        def bad_path($p):
          ($p | type == "string") and
          ($p == "/var/run/docker.sock" or ($p | startswith("/var/run/docker.sock/")) or
           (under_allowed_root($p) | not));
        def build_contexts($b):
          if $b == null then []
          elif ($b | type) == "string" then [$b]
          elif ($b | type) == "object" then [$b.context // empty]
          else [] end;
        def build_dockerfiles($b):
          if ($b | type) == "object" and (($b.dockerfile // "") | startswith("/")) then [$b.dockerfile]
          else [] end;

        .services // {} | to_entries[] as $svc |
        ($svc.value // {}) as $s |
        if ($s.privileged == true) then
          "service \($svc.key) requests privileged mode"
        elif (($s.cap_add // []) | length) > 0 then
          "service \($svc.key) requests cap_add"
        elif (($s.devices // []) | length) > 0 then
          "service \($svc.key) requests devices"
        elif (build_contexts($s.build // null) | map(select(bad_path(.))) | length) > 0 then
          "service \($svc.key) builds from a context outside SHELLM_WORKDIR"
        elif (build_dockerfiles($s.build // null) | map(select(bad_path(.))) | length) > 0 then
          "service \($svc.key) uses a Dockerfile outside SHELLM_WORKDIR"
        elif (($s.security_opt // []) | map(tostring) | any(. == "seccomp=unconfined" or . == "apparmor=unconfined")) then
          "service \($svc.key) disables container security policy"
        elif (($s.network_mode // "") | tostring) == "host" then
          "service \($svc.key) requests host networking"
        elif (($s.pid // "") | tostring) == "host" then
          "service \($svc.key) requests host pid namespace"
        elif (($s.ipc // "") | tostring) == "host" then
          "service \($svc.key) requests host ipc namespace"
        elif (($s.cgroup // "") | tostring) == "host" then
          "service \($svc.key) requests host cgroup namespace"
        elif (($s.volumes // []) | map(select(.type == "bind") | select(bad_path(.source))) | length) > 0 then
          "service \($svc.key) bind-mounts a host path outside SHELLM_WORKDIR"
        elif (($s.volumes // []) | map(select((.source // "") == "/var/run/docker.sock" or (.target // "") == "/var/run/docker.sock")) | length) > 0 then
          "service \($svc.key) tries to mount the Docker socket"
        else
          empty
        end
    ' "$config" | head -1)
    rm -f "$config" "$err"
    [[ -z "$message" ]] || { printf '%s\n' "$message" >&2; return 65; }
    return 0
}

compose_validate_cp_paths() {
    local cwd="$1"
    shift
    shift
    local workdir="$SHELLM_BROKER_WORKDIR"
    local -a operands=()
    local arg next
    while [[ $# -gt 0 ]]; do
        arg="$1"
        shift
        case "$arg" in
            --index)
                [[ $# -gt 0 ]] || { printf '%s\n' "compose cp --index requires a value" >&2; return 64; }
                shift
                ;;
            --archive|--follow-link|--all|-a|-L)
                ;;
            -*)
                printf '%s\n' "unsupported compose cp option: $arg" >&2
                return 64
                ;;
            *)
                operands+=("$arg")
                ;;
        esac
    done
    [[ "${#operands[@]}" -eq 2 ]] || { printf '%s\n' "compose cp requires SRC DEST" >&2; return 64; }

    local operand ref path abs parent
    for operand in "${operands[@]}"; do
        if [[ "$operand" == *:* ]]; then
            ref="${operand%%:*}"
            path="${operand#*:}"
            valid_container_ref "$ref" || { printf '%s\n' "invalid compose cp service: $ref" >&2; return 64; }
            [[ "$path" == /* ]] || { printf '%s\n' "compose cp container paths must be absolute" >&2; return 64; }
        else
            abs=$(resolve_under_workdir "$operand" "$cwd" "$workdir" 2>/dev/null || true)
            if [[ -z "$abs" ]]; then
                parent=$(dirname "$operand")
                abs=$(resolve_under_workdir "$parent" "$cwd" "$workdir" 2>/dev/null || true)
            fi
            [[ -n "$abs" ]] || { printf '%s\n' "compose cp host paths must stay under SHELLM_WORKDIR" >&2; return 64; }
        fi
    done
}

compose_validate_exec() {
    shift
    local arg service=""
    while [[ $# -gt 0 ]]; do
        arg="$1"
        shift
        case "$arg" in
            --privileged)
                printf '%s\n' "compose exec --privileged is not allowed" >&2
                return 65
                ;;
            -w|--workdir|-e|--env|-u|--user|--index)
                [[ $# -gt 0 ]] || { printf '%s\n' "compose exec $arg requires a value" >&2; return 64; }
                shift
                ;;
            -T|--no-TTY|--detach|-d)
                ;;
            -*)
                printf '%s\n' "unsupported compose exec option: $arg" >&2
                return 64
                ;;
            *)
                service="$arg"
                break
                ;;
        esac
    done
    [[ -n "$service" ]] || { printf '%s\n' "compose exec requires SERVICE" >&2; return 64; }
    valid_container_ref "$service" || { printf '%s\n' "invalid compose exec service: $service" >&2; return 64; }
}

handle_compose() {
    local request="$1"
    local workdir="$SHELLM_BROKER_WORKDIR"
    local requested_cwd cwd
    requested_cwd=$(printf '%s' "$request" | jq -r '.cwd // empty')
    cwd=$(safe_cwd "$requested_cwd" "$workdir")

    local -a args=()
    while IFS= read -r arg; do
        args+=("$arg")
    done < <(request_args "$request")
    [[ "${#args[@]}" -ge 1 ]] || { json_error 64 "compose requires a subcommand"; return; }

    local -a global_args=()
    local -a command_args=()
    local project_dir="$cwd"
    local subcommand=""
    local i=0 arg value abs
    while [[ "$i" -lt "${#args[@]}" ]]; do
        arg="${args[$i]}"
        case "$arg" in
            -f|--file)
                i=$((i + 1))
                [[ "$i" -lt "${#args[@]}" ]] || { json_error 64 "$arg requires a value"; return; }
                value="${args[$i]}"
                abs=$(resolve_under_workdir "$value" "$cwd" "$workdir" 2>/dev/null || true)
                [[ -n "$abs" && -f "$abs" ]] || { json_error 64 "compose file must be under SHELLM_WORKDIR: $value"; return; }
                global_args+=("$arg" "$abs")
                ;;
            --project-directory)
                i=$((i + 1))
                [[ "$i" -lt "${#args[@]}" ]] || { json_error 64 "$arg requires a value"; return; }
                value="${args[$i]}"
                abs=$(resolve_under_workdir "$value" "$cwd" "$workdir" 2>/dev/null || true)
                [[ -n "$abs" && -d "$abs" ]] || { json_error 64 "compose project directory must be under SHELLM_WORKDIR: $value"; return; }
                project_dir="$abs"
                global_args+=("$arg" "$abs")
                ;;
            -p|--project-name)
                i=$((i + 1))
                [[ "$i" -lt "${#args[@]}" ]] || { json_error 64 "$arg requires a value"; return; }
                value="${args[$i]}"
                valid_compose_project_name "$value" || { json_error 64 "invalid compose project name: $value"; return; }
                global_args+=("$arg" "$value")
                ;;
            --env-file)
                i=$((i + 1))
                [[ "$i" -lt "${#args[@]}" ]] || { json_error 64 "$arg requires a value"; return; }
                value="${args[$i]}"
                abs=$(resolve_under_workdir "$value" "$cwd" "$workdir" 2>/dev/null || true)
                [[ -n "$abs" && -f "$abs" ]] || { json_error 64 "compose env-file must be under SHELLM_WORKDIR: $value"; return; }
                global_args+=("$arg" "$abs")
                ;;
            --ansi|--progress|--profile)
                i=$((i + 1))
                [[ "$i" -lt "${#args[@]}" ]] || { json_error 64 "$arg requires a value"; return; }
                global_args+=("$arg" "${args[$i]}")
                ;;
            --compatibility|--verbose)
                global_args+=("$arg")
                ;;
            -v|--version)
                subcommand="version"
                command_args=("version")
                break
                ;;
            -*)
                json_error 64 "unsupported compose global option: $arg"
                return
                ;;
            *)
                subcommand="$arg"
                while [[ "$i" -lt "${#args[@]}" ]]; do
                    command_args+=("${args[$i]}")
                    i=$((i + 1))
                done
                break
                ;;
        esac
        i=$((i + 1))
    done

    [[ -n "$subcommand" ]] || { json_error 64 "compose requires a subcommand"; return; }

    case "$subcommand" in
        version)
            log_msg "compose version"
            local -a version_cmd=(docker compose)
            if [[ "${#command_args[@]}" -gt 0 ]]; then
                version_cmd+=("${command_args[@]}")
            fi
            run_capture "${version_cmd[@]}"
            return
            ;;
        build|down|up|exec|cp|stop|config) ;;
        *) json_error 64 "unsupported compose operation: $subcommand"; return ;;
    esac

    case "$subcommand" in
        cp)
            if ! compose_validate_cp_paths "$cwd" "${command_args[@]}"; then
                json_error 64 "rejected compose cp request"
                return
            fi
            ;;
        exec)
            if ! compose_validate_exec "${command_args[@]}"; then
                json_error 64 "rejected compose exec request"
                return
            fi
            ;;
    esac

    if [[ "$subcommand" != "config" ]]; then
        local validation_out validation_err validation_rc
        validation_out=$(mktemp)
        validation_err=$(mktemp)
        set +e
        if [[ "${#global_args[@]}" -gt 0 ]]; then
            compose_validate_model "$request" "$cwd" "${global_args[@]}" >"$validation_out" 2>"$validation_err"
        else
            compose_validate_model "$request" "$cwd" >"$validation_out" 2>"$validation_err"
        fi
        validation_rc=$?
        set -e
        if [[ "$validation_rc" -ne 0 ]]; then
            json_response "$validation_rc" "$validation_out" "$validation_err"
            rm -f "$validation_out" "$validation_err"
            return
        fi
        rm -f "$validation_out" "$validation_err"
    fi

    log_msg "compose project_dir=$project_dir subcommand=$subcommand argc=${#args[@]}"
    local -a cmd=(docker compose)
    if [[ "${#global_args[@]}" -gt 0 ]]; then
        cmd+=("${global_args[@]}")
    fi
    if [[ "${#command_args[@]}" -gt 0 ]]; then
        cmd+=("${command_args[@]}")
    fi
    run_capture_with_request_env "$request" "$cwd" "${cmd[@]}"
}

process_request() {
    local request="$1"
    if ! printf '%s' "$request" | jq -e '.op and (.args | type == "array")' >/dev/null 2>&1; then
        json_error 64 "invalid broker request"
        return
    fi

    local op
    op=$(printf '%s' "$request" | jq -r '.op')
    case "$op" in
        run) handle_run "$request" ;;
        build) handle_build "$request" ;;
        ps) handle_ps ;;
        logs) handle_logs "$request" ;;
        rm) handle_rm "$request" ;;
        info) handle_info "$request" ;;
        version) handle_version "$request" ;;
        compose) handle_compose "$request" ;;
        *) json_error 64 "unsupported operation: $op" ;;
    esac
}

serve_one() {
    local request
    request=$(cat)
    process_request "$request"
}

discard_stale_filesystem_request() {
    local file="$1"
    local res_dir="$2"
    local base response tmp
    base=$(basename "$file")
    response="$res_dir/$base"
    tmp="$response.tmp"
    json_error 70 "discarded stale broker request after broker restart" > "$tmp"
    mv "$tmp" "$response"
    rm -f "$file"
}

process_filesystem_request() {
    local processing="$1"
    local response="$2"
    local tmp="$3"
    if ! "$0" serve-one < "$processing" > "$tmp" 2>>"${SHELLM_BROKER_LOG:-/dev/null}"; then
        json_error 70 "broker request crashed" > "$tmp"
    fi
    mv "$tmp" "$response"
    rm -f "$processing"
}

serve_filesystem() {
    local dir="$SHELLM_BROKER_DIR"
    local req_dir="$dir/requests"
    local res_dir="$dir/responses"
    local processing_dir="$dir/processing"
    mkdir -p "$req_dir" "$res_dir" "$processing_dir"
    rm -f "$res_dir"/*.tmp 2>/dev/null || true
    local stale base
    for stale in "$processing_dir"/*.json; do
        [[ -e "$stale" ]] || continue
        discard_stale_filesystem_request "$stale" "$res_dir"
    done
    for stale in "$req_dir"/*.json; do
        [[ -e "$stale" ]] || continue
        discard_stale_filesystem_request "$stale" "$res_dir"
    done
    log_msg "filesystem broker started env=$SHELLM_BROKER_ENV workdir=$SHELLM_BROKER_WORKDIR"

    while true; do
        local req
        for req in "$req_dir"/*.json; do
            [[ -e "$req" ]] || continue
            local base processing response tmp
            base=$(basename "$req")
            processing="$processing_dir/$base"
            response="$res_dir/$base"
            tmp="$response.tmp"
            mv "$req" "$processing" 2>/dev/null || continue
            process_filesystem_request "$processing" "$response" "$tmp" &
        done
        sleep 0.2
    done
}

stop_pid_file() {
    local pid_file="$1"
    if [[ -f "$pid_file" ]]; then
        local pid session
        pid=$(cat "$pid_file" 2>/dev/null || true)
        case "$pid" in
            tmux:*)
                session="${pid#tmux:}"
                if [[ -n "$session" ]] && command -v tmux >/dev/null 2>&1; then
                    tmux kill-session -t "$session" >/dev/null 2>&1 || true
                fi
                ;;
            *)
                if [[ -n "$pid" ]]; then
                    kill "$pid" >/dev/null 2>&1 || true
                    sleep 0.1
                    kill -9 "$pid" >/dev/null 2>&1 || true
                fi
                ;;
        esac
        rm -f "$pid_file"
    fi
}

start_broker() {
    local env_name="" workdir="" dir="" transport="" pid_file="" log=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --env) env_name="${2:?--env requires a value}"; shift 2 ;;
            --workdir) workdir="${2:?--workdir requires a value}"; shift 2 ;;
            --dir) dir="${2:?--dir requires a value}"; shift 2 ;;
            --transport) transport="${2:?--transport requires a value}"; shift 2 ;;
            --pid-file) pid_file="${2:?--pid-file requires a value}"; shift 2 ;;
            --log) log="${2:?--log requires a value}"; shift 2 ;;
            *) die "unknown start option: $1" ;;
        esac
    done

    [[ -n "$env_name" && -n "$workdir" && -n "$dir" && -n "$transport" && -n "$pid_file" && -n "$log" ]] || die "start requires --env, --workdir, --dir, --transport, --pid-file, and --log"
    workdir=$(realpath "$workdir")
    command -v docker >/dev/null 2>&1 || die "broker mode requires docker on the host"
    docker info >/dev/null 2>&1 || die "broker mode cannot reach the host Docker daemon"

    mkdir -p "$dir" "$(dirname "$pid_file")" "$(dirname "$log")"
    stop_pid_file "$pid_file"

    export SHELLM_BROKER_ENV="$env_name"
    export SHELLM_BROKER_WORKDIR="$workdir"
    export SHELLM_BROKER_DIR="$dir"
    export SHELLM_BROKER_LOG="$log"

    case "$transport" in
        socket)
            command -v socat >/dev/null 2>&1 || die "socket transport requires socat"
            rm -f "$dir/broker.sock"
            nohup socat "UNIX-LISTEN:$dir/broker.sock,fork,unlink-early" "EXEC:$0 serve-one" >>"$log" 2>&1 &
            ;;
        filesystem)
            if command -v tmux >/dev/null 2>&1 && [[ "${SHELLM_BROKER_USE_TMUX:-1}" != "0" ]]; then
                local safe_env session tmux_cmd
                safe_env="${env_name//[^A-Za-z0-9_]/_}"
                session="shellm-broker-$safe_env"
                tmux kill-session -t "$session" >/dev/null 2>&1 || true
                printf -v tmux_cmd 'SHELLM_BROKER_ENV=%q SHELLM_BROKER_WORKDIR=%q SHELLM_BROKER_DIR=%q SHELLM_BROKER_LOG=%q exec %q serve-filesystem >>%q 2>&1' \
                    "$env_name" "$workdir" "$dir" "$log" "$0" "$log"
                tmux new-session -d -s "$session" "$tmux_cmd"
                printf 'tmux:%s\n' "$session" > "$pid_file"
                log_msg "broker started session=$session transport=$transport env=$env_name workdir=$workdir"
                return
            fi

            nohup bash -c '
                broker="$1"
                log="$2"
                child=""
                stop_child() {
                    if [ -n "$child" ]; then
                        kill "$child" >/dev/null 2>&1 || true
                    fi
                    exit 0
                }
                trap stop_child INT TERM
                while true; do
                    "$broker" serve-filesystem &
                    child=$!
                    wait "$child"
                    rc=$?
                    child=""
                    if [ "$rc" -eq 0 ]; then
                        exit 0
                    fi
                    printf "%s filesystem broker exited rc=%s; restarting\n" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$rc" >> "$log"
                    sleep 1
                done
            ' shellm-docker-broker-supervisor "$0" "$log" >>"$log" 2>&1 &
            ;;
        *) die "unknown broker transport: $transport" ;;
    esac

    local pid=$!
    disown "$pid" >/dev/null 2>&1 || true
    printf '%s\n' "$pid" > "$pid_file"
    log_msg "broker started pid=$pid transport=$transport env=$env_name workdir=$workdir"
}

main() {
    [[ $# -gt 0 ]] || { usage >&2; exit 1; }
    case "$1" in
        -h|--help) usage ;;
        start) shift; start_broker "$@" ;;
        stop)
            shift
            [[ "${1:-}" == "--pid-file" ]] || die "stop requires --pid-file"
            stop_pid_file "${2:?--pid-file requires a value}"
            ;;
        serve-one) serve_one ;;
        serve-filesystem) serve_filesystem ;;
        *) die "unknown command: $1" ;;
    esac
}

main "$@"
