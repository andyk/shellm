#!/usr/bin/env bash
set -euo pipefail

# think — Autonomous thinking engine for an activated identity
# Extracted from shelly. Reads env vars set by `identity shell`.

# ---------------------------------------------------------------------------
# Config from environment
# ---------------------------------------------------------------------------

IDENTITY_DIR="${IDENTITY_DIR:-}"
IDENTITY_NAME="${IDENTITY_NAME:-}"
MEM_DIR="${MEM_DIR:-}"
SKILLS_DIR="${SKILLS_DIR:-}"
SKILLS_KERNEL_DIR="${SKILLS_KERNEL_DIR:-}"
TRAJ_DIR="${TRAJ_DIR:-}"
SHELLM_HOME="${SHELLM_HOME:-}"
THINK_MODEL="${THINK_MODEL:-${SHELLM_MODEL:-claude-opus-4-7}}"
THINK_TICK_INTERVAL="${THINK_TICK_INTERVAL:-0}"
THINK_CONTEXT_TAIL="${THINK_CONTEXT_TAIL:-30}"
VERBOSE=0

# Load .env if present (skill-declared vars like OBSIDIAN_VAULT)
if [[ -f ".env" ]]; then
    set -a
    # shellcheck disable=SC1091
    source .env
    set +a
fi

# ---------------------------------------------------------------------------
# Utility functions
# ---------------------------------------------------------------------------

die() { printf 'think: error: %s\n' "$*" >&2; exit 1; }

debug() {
    if [[ "$VERBOSE" -eq 1 ]]; then
        printf '[think debug] %s\n' "$*" >&2
    fi
}

_require_env() {
    [[ -n "$IDENTITY_DIR" ]] || die "IDENTITY_DIR not set. Run: identity shell <name>"
    [[ -n "$TRAJ_DIR" ]] || die "TRAJ_DIR not set. Run: identity shell <name>"
    [[ -n "${TRAJ_ID:-}" ]] || die "TRAJ_ID not set. Run: identity shell <name>"
    [[ -n "$MEM_DIR" ]] || die "MEM_DIR not set. Run: identity shell <name>"

    # Resolve identity name if not set
    if [[ -z "$IDENTITY_NAME" ]]; then
        IDENTITY_NAME=$(grep '^name=' "$IDENTITY_DIR/info.txt" 2>/dev/null | cut -d= -f2-) || true
        [[ -z "$IDENTITY_NAME" ]] && IDENTITY_NAME=$(basename "$IDENTITY_DIR")
    fi

    # Defaults
    [[ -z "$SKILLS_DIR" ]] && SKILLS_DIR="$IDENTITY_DIR/skills"
    [[ -z "$SKILLS_KERNEL_DIR" ]] && SKILLS_KERNEL_DIR="$IDENTITY_DIR/kernel"
    [[ -z "$SHELLM_HOME" ]] && SHELLM_HOME="$IDENTITY_DIR/.shellm"

    mkdir -p "$MEM_DIR" "$SKILLS_DIR" "$SKILLS_KERNEL_DIR" "$TRAJ_DIR"
}

# ---------------------------------------------------------------------------
# Helpers extracted from shelly
# ---------------------------------------------------------------------------

# Extract goals from identity's memories (type: goal in frontmatter)
get_goals() {
    local mem_dir="${1:-$MEM_DIR}"
    [[ -d "$mem_dir" ]] || return 0
    local goals=""
    local f
    for f in "$mem_dir"/*.md; do
        [[ -f "$f" ]] || continue
        local ftype
        ftype=$(awk 'NR==1 && /^---$/{f=1; next} f && /^---$/{exit} f && /^type:/{sub(/^type:[[:space:]]*/, ""); print}' "$f")
        case "$ftype" in
            goal|intention)
                local body
                body=$(awk 'NR==1 && /^---$/{f=1; next} f && /^---$/{f=0; next} !f{print}' "$f" | sed '/./,$!d' | head -3)
                [[ -n "$body" ]] && goals="${goals}- ${body}
"
                ;;
        esac
    done
    if [[ -z "$goals" ]]; then
        printf '%s' "(no goals set)"
    else
        printf '%s' "$goals"
    fi
}

# Load a prompt template, replacing {{goals}} and {{identity_name}}
load_prompt() {
    local prompt_file="$1"
    local identity_name="$2"
    local goals="$3"
    [[ -f "$prompt_file" ]] || return 1
    local content
    content=$(cat "$prompt_file")
    content=$(printf '%s' "$content" | sed "s/{{identity_name}}/$identity_name/g")
    local goals_file
    goals_file=$(mktemp)
    printf '%s' "$goals" > "$goals_file"
    if command -v perl >/dev/null 2>&1; then
        content=$(printf '%s' "$content" | perl -pe "
            BEGIN { open(F, '<', '$goals_file'); local \$/; \$g = <F>; close(F); chomp \$g; }
            s/\\{\\{goals\\}\\}/\$g/g;
        ")
    else
        local before after
        before="${content%%\{\{goals\}\}*}"
        after="${content#*\{\{goals\}\}}"
        if [[ "$before" != "$content" ]]; then
            content="${before}${goals}${after}"
        fi
    fi
    rm -f "$goals_file"
    printf '%s' "$content"
}

# Ensure think prompt exists for the identity (copy from bundled if missing)
ensure_think_prompt() {
    local identity_dir="$1"
    local prompts_dir="$identity_dir/prompts"
    mkdir -p "$prompts_dir"
    if [[ ! -f "$prompts_dir/think.md" ]]; then
        local script_dir
        script_dir="$(cd "$(dirname "$(realpath "$0")")" && pwd)"
        local bundled="$script_dir/../prompts/think.md"
        if [[ ! -f "$bundled" ]]; then
            bundled="$HOME/.shelly-prompts/think.md"
        fi
        if [[ -f "$bundled" ]]; then
            cp "$bundled" "$prompts_dir/think.md"
        else
            die "think prompt not found (checked $script_dir/../prompts/ and ~/.shelly-prompts/)"
        fi
    fi
}

# Discover thought processes: scan bundled + identity TP dirs, merge
discover_thought_processes() {
    local identity_dir="$1"
    local script_dir
    script_dir="$(cd "$(dirname "$(realpath "$0")")" && pwd)"
    local bundled_dir="$script_dir/../thought-processes"
    if [[ ! -d "$bundled_dir" ]]; then
        bundled_dir="$HOME/.shelly-thought-processes"
    fi
    local identity_tp_dir="$identity_dir/thought-processes"

    local _seen="" _results=""
    local f name

    # Identity TPs take precedence
    if [[ -d "$identity_tp_dir" ]]; then
        for f in "$identity_tp_dir"/*.md; do
            [[ -f "$f" ]] || continue
            name=$(basename "$f" .md)
            _seen="${_seen}|${name}|"
            _results="${_results}${name}=${f}
"
        done
    fi

    # Bundled TPs (skip if identity already has override)
    if [[ -d "$bundled_dir" ]]; then
        for f in "$bundled_dir"/*.md; do
            [[ -f "$f" ]] || continue
            name=$(basename "$f" .md)
            case "$_seen" in
                *"|${name}|"*) continue ;;
            esac
            _results="${_results}${name}=${f}
"
        done
    fi

    printf '%s' "$_results"
}

# Collect env vars declared by skills via metadata
collect_skill_vars() {
    local identity_dir="$1"
    local -a var_names=()
    local -a dirs=("$SKILLS_KERNEL_DIR" "$identity_dir/skills")
    local base skill_dir
    for base in "${dirs[@]}"; do
        [[ -d "$base" ]] || continue
        for skill_dir in "$base"/*/; do
            [[ -f "${skill_dir}SKILL.md" ]] || continue
            local frontmatter
            frontmatter=$(awk 'NR==1 && /^---$/{f=1; next} f && /^---$/{exit} f{print}' "${skill_dir}SKILL.md")
            [[ -z "$frontmatter" ]] && continue
            local env_val
            env_val=$(printf '%s\n' "$frontmatter" | awk '/^[[:space:]]+env:/{sub(/.*env:[[:space:]]*/, ""); print; exit}')
            [[ -z "$env_val" ]] && continue
            local v
            while IFS= read -r v; do
                [[ -n "$v" ]] && var_names+=("$v")
            done < <(printf '%s' "$env_val" | jq -r '.[]' 2>/dev/null)
        done
    done
    if [[ ${#var_names[@]} -gt 0 ]]; then
        printf '%s\n' "${var_names[@]}" | sort -u
    fi
}

# mkdir-based POSIX lock
acquire_lock() {
    local lock_dir="$1"
    if mkdir "$lock_dir" 2>/dev/null; then
        printf '%s' "$$" > "$lock_dir/pid"
        return 0
    fi
    if [[ -f "$lock_dir/pid" ]]; then
        local old_pid
        old_pid=$(cat "$lock_dir/pid" 2>/dev/null) || old_pid=""
        if [[ -n "$old_pid" ]] && ! kill -0 "$old_pid" 2>/dev/null; then
            rm -rf "$lock_dir"
            if mkdir "$lock_dir" 2>/dev/null; then
                printf '%s' "$$" > "$lock_dir/pid"
                return 0
            fi
        fi
    fi
    return 1
}

release_lock() {
    local lock_dir="$1"
    rm -rf "$lock_dir"
}

# ---------------------------------------------------------------------------
# Core: one think cycle
# ---------------------------------------------------------------------------

cmd_step() {
    local dry_run=0
    local model="$THINK_MODEL"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run) dry_run=1; shift ;;
            --model)   model="${2:?--model requires a value}"; shift 2 ;;
            *) break ;;
        esac
    done

    _require_env

    local identity_dir="$IDENTITY_DIR"
    local traj_dir="$TRAJ_DIR"
    local identity_name="$IDENTITY_NAME"

    # Ensure think prompt exists
    ensure_think_prompt "$identity_dir"

    # Build goals and load think prompt
    local goals
    goals=$(get_goals "$MEM_DIR")
    local think_prompt
    think_prompt=$(load_prompt "$identity_dir/prompts/think.md" "$identity_name" "$goals")

    # Build recent context
    local recent_context=""
    if traj exists 2>/dev/null; then
        recent_context=$(traj tail -n "$THINK_CONTEXT_TAIL" 2>/dev/null) || recent_context=""
    fi

    local full_message="<context>
$think_prompt
</context>

Recent stream (last $THINK_CONTEXT_TAIL steps):
$recent_context"

    if [[ "$dry_run" -eq 1 ]]; then
        printf '[think dry-run] Would call shellm with think prompt (%d bytes)\n' "${#think_prompt}" >&2
        printf '[think dry-run] Goals:\n%s\n' "$goals" >&2
        printf '[think dry-run] Recent context: %d bytes\n' "${#recent_context}" >&2
        return 0
    fi

    # Resolve absolute paths
    local abs_mem_dir abs_skills_dir abs_kernel_dir abs_traj_dir run_dir identity_tp_dir
    abs_mem_dir=$(cd "$MEM_DIR" 2>/dev/null && pwd) || abs_mem_dir="$MEM_DIR"
    abs_skills_dir=$(cd "$SKILLS_DIR" 2>/dev/null && pwd) || abs_skills_dir="$SKILLS_DIR"
    abs_kernel_dir=$(cd "$SKILLS_KERNEL_DIR" 2>/dev/null && pwd) || abs_kernel_dir="$SKILLS_KERNEL_DIR"
    abs_traj_dir=$(cd "$traj_dir" 2>/dev/null && pwd) || abs_traj_dir="$traj_dir"
    run_dir="$identity_dir/workdir"
    identity_tp_dir="$identity_dir/thought-processes"
    mkdir -p "$run_dir" "$identity_tp_dir"

    # Collect --var flags from skill-declared vars
    local skill_var_flags=()
    while IFS= read -r vname; do
        [[ -z "$vname" ]] && continue
        local vval="${!vname:-}"
        [[ -n "$vval" ]] && skill_var_flags+=(--var "$vname=$vval")
    done < <(collect_skill_vars "$identity_dir")

    export SHELLM_HOME="$SHELLM_HOME"

    # Call shellm with think prompt — fork from root traj
    printf '  thinking...\n' >&2
    local response
    response=$(_SHELLM_PARENT_TRAJ_ID="$TRAJ_ID" \
        SHELLM_NO_BANNER=1 SHELLM_MODEL="$model" \
        shellm --env "$identity_name" --workdir "$run_dir" \
        --var "MEM_DIR=$abs_mem_dir" \
        --var "SKILLS_DIR=$abs_skills_dir" \
        --var "SKILLS_KERNEL_DIR=$abs_kernel_dir" \
        --var "TRAJ_DIR=$abs_traj_dir" \
        --var "TRAJ_ID=$TRAJ_ID" \
        --var "IDENTITY_TP_DIR=$identity_tp_dir" \
        ${skill_var_flags[@]+"${skill_var_flags[@]}"} \
        --bin "$(command -v mem)" \
        --bin "$(command -v traj)" \
        --bin "$(command -v skills)" \
        --bin "$(command -v context)" \
        --bin "$(command -v llm)" \
        --bin "$(command -v shellm)" \
        "$full_message") || true

    [[ -z "$response" ]] && { debug "step: empty response from shellm"; return 1; }

    # Determine step type
    local step_type="thought"
    case "$response" in
        "action: "*|"action:"*)
            step_type="action"
            ;;
    esac

    # Write thought to traj (unless shellm already did)
    local last_content=""
    if traj exists 2>/dev/null; then
        last_content=$(traj last --field content 2>/dev/null) || true
    fi

    if [[ "$last_content" != "$response" ]]; then
        printf '{"type":"%s","content":%s,"source":"think"}' \
            "$step_type" "$(printf '%s' "$response" | jq -Rsa .)" \
            | traj append >/dev/null
    fi

    printf '[%s] %s\n' "$step_type" "$response"

    # If action, execute it
    if [[ "$step_type" == "action" ]]; then
        local action_body="${response#action: }"
        [[ "$action_body" == "$response" ]] && action_body="${response#action:}"
        _do_act "$action_body" "$identity_dir" "$traj_dir" "$identity_name" "$model"
    fi

    # Dispatch thought processes
    _dispatch_thought_processes "$identity_dir" "$traj_dir" "$identity_name" "$model"
}

# ---------------------------------------------------------------------------
# Action execution (fork/act/merge)
# ---------------------------------------------------------------------------

_do_act() {
    local action_body="$1"
    local identity_dir="$2"
    local traj_dir="$3"
    local identity_name="$4"
    local model="$5"

    [[ -z "$action_body" ]] && return 0

    debug "act: executing action: $action_body"

    # Build system prompt via `identity prompt`
    local system_prompt
    system_prompt=$(identity prompt)

    local abs_mem_dir abs_skills_dir abs_kernel_dir abs_traj_dir run_dir identity_tp_dir
    abs_mem_dir=$(cd "$MEM_DIR" 2>/dev/null && pwd) || abs_mem_dir="$MEM_DIR"
    abs_skills_dir=$(cd "$SKILLS_DIR" 2>/dev/null && pwd) || abs_skills_dir="$SKILLS_DIR"
    abs_kernel_dir=$(cd "$SKILLS_KERNEL_DIR" 2>/dev/null && pwd) || abs_kernel_dir="$SKILLS_KERNEL_DIR"
    abs_traj_dir=$(cd "$traj_dir" 2>/dev/null && pwd) || abs_traj_dir="$traj_dir"
    run_dir="$identity_dir/workdir"
    identity_tp_dir="$identity_dir/thought-processes"
    mkdir -p "$identity_tp_dir"

    # Collect skill vars
    local skill_var_flags=()
    while IFS= read -r vname; do
        [[ -z "$vname" ]] && continue
        local vval="${!vname:-}"
        [[ -n "$vval" ]] && skill_var_flags+=(--var "$vname=$vval")
    done < <(collect_skill_vars "$identity_dir")

    local act_prompt="<context>
$system_prompt
</context>

You are executing an action from your thought stream. Do the work described below.
When you are done, if there is a meaningful observation or result to record, write it to your trajectory:
  printf '{\"type\":\"observation\",\"content\":<json-escaped result>}' | traj append
Then set FINAL to signal completion (FINAL content is not important, only traj matters).
If there is nothing meaningful to observe, just set FINAL.

ACTION: $action_body"

    export SHELLM_HOME="$SHELLM_HOME"

    # shellm handles fork/merge via _SHELLM_PARENT_TRAJ_ID
    printf '  executing action...\n' >&2
    local act_response
    act_response=$(_SHELLM_PARENT_TRAJ_ID="$TRAJ_ID" \
        SHELLM_NO_BANNER=1 SHELLM_MODEL="$model" \
        shellm --env "$identity_name" --workdir "$run_dir" \
        --var "MEM_DIR=$abs_mem_dir" \
        --var "SKILLS_DIR=$abs_skills_dir" \
        --var "SKILLS_KERNEL_DIR=$abs_kernel_dir" \
        --var "TRAJ_DIR=$abs_traj_dir" \
        --var "TRAJ_ID=$TRAJ_ID" \
        --var "IDENTITY_TP_DIR=$identity_tp_dir" \
        ${skill_var_flags[@]+"${skill_var_flags[@]}"} \
        --bin "$(command -v mem)" \
        --bin "$(command -v skills)" \
        --bin "$(command -v traj)" \
        --bin "$(command -v context)" \
        --bin "$(command -v llm)" \
        --bin "$(command -v shellm)" \
        --bin "$(command -v chat)" \
        "$act_prompt") || true

    if [[ -n "$act_response" ]]; then
        debug "act: completed (response: ${#act_response} bytes)"
        printf '  [observation] %s\n' "$(printf '%s' "$act_response" | head -1)"
    fi
}

# ---------------------------------------------------------------------------
# Thought process dispatch
# ---------------------------------------------------------------------------

_dispatch_thought_processes() {
    local identity_dir="$1"
    local traj_dir="$2"
    local identity_name="$3"
    local model="$4"

    local tp_list
    tp_list=$(discover_thought_processes "$identity_dir")
    [[ -z "$tp_list" ]] && return 0

    # Build recent thoughts
    local recent_thoughts=""
    if traj exists 2>/dev/null; then
        recent_thoughts=$(traj tail -n 15 2>/dev/null) || recent_thoughts=""
    fi

    local goals
    goals=$(get_goals "$MEM_DIR")

    local abs_mem_dir abs_skills_dir abs_kernel_dir abs_traj_dir run_dir identity_tp_dir
    abs_mem_dir=$(cd "$MEM_DIR" 2>/dev/null && pwd) || abs_mem_dir="$MEM_DIR"
    abs_skills_dir=$(cd "$SKILLS_DIR" 2>/dev/null && pwd) || abs_skills_dir="$SKILLS_DIR"
    abs_kernel_dir=$(cd "$SKILLS_KERNEL_DIR" 2>/dev/null && pwd) || abs_kernel_dir="$SKILLS_KERNEL_DIR"
    abs_traj_dir=$(cd "$traj_dir" 2>/dev/null && pwd) || abs_traj_dir="$traj_dir"
    run_dir="$identity_dir/workdir"
    identity_tp_dir="$identity_dir/thought-processes"
    mkdir -p "$identity_tp_dir"

    # Collect --var flags from skill-declared vars
    local skill_var_flags=()
    while IFS= read -r vname; do
        [[ -z "$vname" ]] && continue
        local vval="${!vname:-}"
        [[ -n "$vval" ]] && skill_var_flags+=(--var "$vname=$vval")
    done < <(collect_skill_vars "$identity_dir")

    export SHELLM_HOME="$SHELLM_HOME"

    local line
    while IFS= read -r line <&3; do
        [[ -z "$line" ]] && continue
        local tp_name="${line%%=*}"
        local tp_file="${line#*=}"
        [[ -f "$tp_file" ]] || continue

        [[ "$tp_name" == "mind-wandering" ]] && continue

        printf '  tp: %s...\n' "$tp_name" >&2

        local tp_prompt
        tp_prompt=$(load_prompt "$tp_file" "$identity_name" "$goals")

        local tp_message="<context>
$tp_prompt
</context>

Recent thoughts from the stream:
$recent_thoughts"

        local tp_response
        tp_response=$(_SHELLM_PARENT_TRAJ_ID="$TRAJ_ID" \
            SHELLM_NO_BANNER=1 SHELLM_MODEL="$model" \
            shellm --env "$identity_name" --workdir "$run_dir" \
            --var "MEM_DIR=$abs_mem_dir" \
            --var "SKILLS_DIR=$abs_skills_dir" \
            --var "SKILLS_KERNEL_DIR=$abs_kernel_dir" \
            --var "TRAJ_DIR=$abs_traj_dir" \
            --var "TRAJ_ID=$TRAJ_ID" \
            --var "IDENTITY_TP_DIR=$identity_tp_dir" \
            ${skill_var_flags[@]+"${skill_var_flags[@]}"} \
            --bin "$(command -v mem)" \
            --bin "$(command -v traj)" \
            --bin "$(command -v llm)" \
            "$tp_message") || true

        if [[ -n "$tp_response" ]]; then
            debug "tp: $tp_name ran (response: ${#tp_response} bytes)"
            printf '  [tp:%s] %s\n' "$tp_name" "$(printf '%s' "$tp_response" | head -1)"
        fi
    done 3<<< "$tp_list"
}

# ---------------------------------------------------------------------------
# Background loop: start / stop / status
# ---------------------------------------------------------------------------

cmd_start() {
    local max_ticks=0
    local model="$THINK_MODEL"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --max-ticks)     max_ticks="${2:?--max-ticks requires a number}"; shift 2 ;;
            --model)         model="${2:?--model requires a value}"; shift 2 ;;
            *) break ;;
        esac
    done

    _require_env

    local identity_dir="$IDENTITY_DIR"
    local lock_dir="$identity_dir/run.lock"
    local log_file="$identity_dir/loop.log"

    # Check if already running
    if [[ -f "$lock_dir/pid" ]]; then
        local old_pid
        old_pid=$(cat "$lock_dir/pid" 2>/dev/null) || true
        if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null; then
            die "Loop is already running (PID $old_pid). Use \`think stop\` first."
        fi
    fi

    # Export env for subprocess
    export IDENTITY_DIR IDENTITY_NAME MEM_DIR SKILLS_DIR SKILLS_KERNEL_DIR
    export TRAJ_DIR TRAJ_ID SHELLM_HOME THINK_MODEL THINK_TICK_INTERVAL THINK_CONTEXT_TAIL

    # Fork the loop into the background
    (
        local stop_flag="$identity_dir/stop.flag"
        rm -f "$stop_flag"
        local tick_interval="$THINK_TICK_INTERVAL"

        trap 'release_lock "$lock_dir"; rm -f "$stop_flag"' EXIT
        trap 'release_lock "$lock_dir"; rm -f "$stop_flag"; exit 130' INT TERM

        local tick_count=0
        while true; do
            [[ -f "$stop_flag" ]] && { printf '[think] Stop flag detected. Shutting down.\n'; break; }

            tick_count=$((tick_count + 1))
            printf '[tick %d]\n' "$tick_count"

            cmd_step --model "$model" || true

            if [[ "$max_ticks" -gt 0 && "$tick_count" -ge "$max_ticks" ]]; then
                printf '[think] Reached max ticks (%d). Stopping.\n' "$max_ticks"
                break
            fi

            # Re-read interval from info.txt (hot-reloadable)
            local _iv
            _iv=$(grep '^interval=' "$identity_dir/info.txt" 2>/dev/null | cut -d= -f2-) || true
            [[ -n "$_iv" ]] && tick_interval="$_iv"

            [[ "$tick_interval" -gt 0 ]] && { sleep "$tick_interval" || break; }
        done

        printf '[think] Autonomous loop stopped.\n'
    ) >> "$log_file" 2>&1 &

    local bg_pid=$!

    mkdir -p "$lock_dir"
    printf '%s' "$bg_pid" > "$lock_dir/pid"

    local traj_count=0
    if traj exists 2>/dev/null; then
        traj_count=$(traj count 2>/dev/null) || traj_count=0
    fi

    local interval_display="${THINK_TICK_INTERVAL}s"
    [[ "$THINK_TICK_INTERVAL" -eq 0 ]] && interval_display="0 (back-to-back)"

    printf 'Identity: %s\n' "$IDENTITY_NAME" >&2
    printf 'Loop:     running (PID %d)\n' "$bg_pid" >&2
    printf 'Interval: %s\n' "$interval_display" >&2
    printf 'History:  %d entries\n' "$traj_count" >&2
    printf 'Logs:     %s\n' "$log_file" >&2
}

cmd_stop() {
    _require_env

    local identity_dir="$IDENTITY_DIR"
    local lock_pid_file="$identity_dir/run.lock/pid"
    local stop_flag="$identity_dir/stop.flag"

    if [[ ! -f "$lock_pid_file" ]]; then
        printf 'No loop is running.\n' >&2
        return 0
    fi

    local pid
    pid=$(cat "$lock_pid_file" 2>/dev/null) || true
    if [[ -z "$pid" ]] || ! kill -0 "$pid" 2>/dev/null; then
        release_lock "$identity_dir/run.lock"
        printf 'No loop is running (cleaned up stale lock).\n' >&2
        return 0
    fi

    touch "$stop_flag"
    local i
    for i in 1 2 3 4 5 6 7 8; do
        kill -0 "$pid" 2>/dev/null || break
        sleep 0.25
    done
    if kill -0 "$pid" 2>/dev/null; then
        kill -TERM "$pid" 2>/dev/null || true
        kill -TERM -- "-$pid" 2>/dev/null || true
        sleep 0.5
        kill -KILL "$pid" 2>/dev/null || true
        kill -KILL -- "-$pid" 2>/dev/null || true
    fi
    release_lock "$identity_dir/run.lock"
    rm -f "$stop_flag"
    printf 'Autonomous loop stopped (PID %d).\n' "$pid" >&2
}

cmd_status() {
    _require_env

    local identity_dir="$IDENTITY_DIR"

    local traj_count=0
    if traj exists 2>/dev/null; then
        traj_count=$(traj count 2>/dev/null) || traj_count=0
    fi

    local loop_state="stopped"
    local lock_pid_file="$identity_dir/run.lock/pid"
    if [[ -f "$lock_pid_file" ]]; then
        local lock_pid
        lock_pid=$(cat "$lock_pid_file" 2>/dev/null) || true
        if [[ -n "$lock_pid" ]] && kill -0 "$lock_pid" 2>/dev/null; then
            loop_state="running (PID $lock_pid)"
        fi
    fi

    printf 'Identity: %s\n' "$IDENTITY_NAME"
    printf 'Loop:     %s\n' "$loop_state"
    printf 'Interval: %ss\n' "$THINK_TICK_INTERVAL"
    printf 'History:  %d entries\n' "$traj_count"
}

cmd_interval() {
    local new_val="${1:-}"
    _require_env

    if [[ -z "$new_val" ]]; then
        printf '%s\n' "$THINK_TICK_INTERVAL"
    else
        [[ "$new_val" =~ ^[0-9]+$ ]] || die "Interval must be a non-negative integer (seconds)"

        local info_file="$IDENTITY_DIR/info.txt"
        THINK_TICK_INTERVAL="$new_val"
        if grep -q '^interval=' "$info_file" 2>/dev/null; then
            sed -i '' "s/^interval=.*/interval=$new_val/" "$info_file"
        else
            printf 'interval=%s\n' "$new_val" >> "$info_file"
        fi

        printf 'Tick interval set to %ss\n' "$THINK_TICK_INTERVAL" >&2
    fi
}

cmd_triage() {
    _require_env
    _dispatch_thought_processes "$IDENTITY_DIR" "$TRAJ_DIR" "$IDENTITY_NAME" "$THINK_MODEL"
}

cmd_tail() {
    _require_env
    traj tail --type reasoning,action,observation,tp-thought "$@"
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
    cat <<'EOF'
think — Autonomous thinking engine

Usage:
  think step [--dry-run] [--model M]    Run one think cycle
  think start [--max-ticks N] [--model M]  Start background loop
  think stop                            Stop background loop
  think status                          Show loop state
  think interval [N]                    Get/set tick interval (seconds)
  think triage                          Run thought processes only
  think tail [traj tail opts]           Stream thinking steps

Options:
  -v, --verbose   Verbose/debug mode
  -h, --help      Show this help

Environment (set by `identity shell`):
  IDENTITY_DIR, IDENTITY_NAME, MEM_DIR, SKILLS_DIR,
  SKILLS_KERNEL_DIR, TRAJ_DIR, TRAJ_ID, SHELLM_HOME,
  THINK_MODEL, THINK_TICK_INTERVAL, THINK_CONTEXT_TAIL
EOF
    exit 0
}

# ---------------------------------------------------------------------------
# Argument parsing & dispatch
# ---------------------------------------------------------------------------

# Parse global flags
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage ;;
        -v|--verbose) VERBOSE=1; shift ;;
        -*) break ;;
        *) break ;;
    esac
done

cmd="${1:-}"
[[ -n "$cmd" ]] && shift

case "$cmd" in
    step)     cmd_step "$@" ;;
    start)    cmd_start "$@" ;;
    stop)     cmd_stop ;;
    status)   cmd_status ;;
    interval) cmd_interval "$@" ;;
    triage)   cmd_triage ;;
    tail)     cmd_tail "$@" ;;
    help)     usage ;;
    "")       usage ;;
    *)        die "Unknown command: $cmd (try think --help)" ;;
esac
