#!/usr/bin/env bash
# deploy/scripts/stop — stop the demo box. Billing drops to ~disk-only;
# identities and everything on disk survive; the tunnel shows down until
# deploy/scripts/start.
#
# Usage: deploy/scripts/stop

source "$(dirname "${BASH_SOURCE[0]}")/lib.sh"

case "${1:-}" in
    -h|--help) sed -n '2,6p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'; exit 0 ;;
esac

require_tools terraform aws
require_state
require_aws

info "Stopping $(instance_id) ($(region)) — disk survives, tunnel goes down"
aws ec2 stop-instances --region "$(region)" --instance-ids "$(instance_id)" \
    --query 'StoppingInstances[0].CurrentState.Name' --output text
info "Bring it back with: deploy/scripts/start"
