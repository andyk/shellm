#!/usr/bin/env bash
set -euo pipefail

# intentions-goals-enforcer/step — Thinker: redirects when stream drifts from goals
# Receives step JSON on stdin. Loads prompt.md, gets recent context, calls shellm.

THINKER_NAME="intentions-goals-enforcer"
SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0")")" && pwd)"

# shellcheck disable=SC1091
source "$SCRIPT_DIR/../_lib/common.sh"

_require_env

THINK_MODEL="${THINK_MODEL:-${SHELLM_MODEL:-claude-opus-4-7}}"

# Load prompt
prompt_file="$SCRIPT_DIR/prompt.md"
[[ -f "$prompt_file" ]] || { printf '%s/step: prompt.md not found\n' "$THINKER_NAME" >&2; exit 1; }

# Build system prompt with identity context
system_prompt=$(_build_system_prompt)

thinker_prompt=$(load_prompt "$prompt_file" "$IDENTITY_NAME")

# Build recent context
recent_thoughts=""
if traj exists 2>/dev/null; then
    recent_thoughts=$(traj tail -n 15 2>/dev/null) || recent_thoughts=""
fi

thinker_message="<context>
$system_prompt

$thinker_prompt
</context>

Recent thoughts from the stream:
$recent_thoughts"

# Resolve paths
run_dir="$IDENTITY_DIR/workdir"
mkdir -p "$run_dir"

shellm_flags=()
while IFS= read -r _flag; do
    [[ -n "$_flag" ]] && shellm_flags+=("$_flag")
done < <(_build_shellm_flags "$IDENTITY_DIR")


printf '  thinker: %s...\n' "$THINKER_NAME" >&2
thinker_response=$(SHELLM_NO_BANNER=1 SHELLM_MODEL="$THINK_MODEL" \
    shellm --traj "$TRAJ_ID" \
    "${shellm_flags[@]}" \
    "$thinker_message") || true

if [[ -n "$thinker_response" ]]; then
    printf '  [thinker:%s] %s\n' "$THINKER_NAME" "$(printf '%s' "$thinker_response" | head -1)"
fi
