#!/usr/bin/env bash
set -euo pipefail

# executive/step — Core thought generator thinker
# Reads recent context, calls llm directly to produce a single thought.
# Receives step JSON on stdin (ignored — this thinker generates new thoughts).

THINKER_NAME="executive"
SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0")")" && pwd)"

# shellcheck disable=SC1091
source "$SCRIPT_DIR/../_lib/common.sh"

_require_env

THINK_MODEL="${THINK_MODEL:-${SHELLM_MODEL:-claude-opus-4-7}}"
THINK_CONTEXT_TAIL="${THINK_CONTEXT_TAIL:-20}"

# Ensure think prompt exists
prompt_file="$SCRIPT_DIR/prompt.md"
if [[ ! -f "$prompt_file" ]]; then
    printf 'executive/step: error: prompt.md not found at %s\n' "$prompt_file" >&2
    exit 1
fi

# Build system prompt with identity context
system_prompt=$(_build_system_prompt)

# Build goals and load thinker-specific prompt
goals=$(get_goals "$MEM_DIR")
think_prompt=$(load_prompt "$prompt_file" "$IDENTITY_NAME" "$goals")

# Build recent context
recent_context=""
if traj exists 2>/dev/null; then
    recent_context=$(traj tail -n "$THINK_CONTEXT_TAIL" 2>/dev/null) || recent_context=""
fi

full_message="<context>
$system_prompt

$think_prompt
</context>

Recent stream (last $THINK_CONTEXT_TAIL steps):
$recent_context"

# Call llm directly — executive thinker produces one thought, no tool use needed
printf '  thinking...\n' >&2
response=$(printf '%s' "$full_message" | \
    llm -m "$THINK_MODEL" \
    -s "Output only a single thought. No explanation, no commands, no preamble." \
    2>/dev/null) || true

# The executive is an infinite loop: it must ALWAYS append something to the
# traj so that trigger_self re-fires.  Empty/duplicate responses are degraded
# but still emit a thought so the dispatcher keeps us alive.
last_content=""
if traj exists 2>/dev/null; then
    last_content=$(traj last --field content 2>/dev/null) || true
fi

if [[ -z "$response" ]]; then
    printf 'executive/step: empty response from llm — emitting placeholder\n' >&2
    response="(executive received an empty response from the LLM; continuing)"
    sleep 1   # brief backoff so transient API failures don't tight-loop
elif [[ "$response" == "$last_content" ]]; then
    response="$response (repeat)"
fi

printf '{"type":"thought","content":%s,"source":"executive"}' \
    "$(printf '%s' "$response" | jq -Rsa .)" \
    | traj append >/dev/null

printf '[thought] %s\n' "$response"
