#!/usr/bin/env bash
set -euo pipefail

# executive/step — Core executive thinker
# Handles two modes based on trigger type:
#   message (to me): Conversational reply + optional actions (merged from turn_taker)
#   anything else:   Generate thought/action in the thinking loop

THINKER_NAME="executive"
SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0")")" && pwd)"

# shellcheck disable=SC1091
source "$SCRIPT_DIR/../_lib/common.sh"

_require_env

THINK_MODEL="${THINK_MODEL:-${SHELLM_MODEL:-claude-opus-4-7}}"
THINK_CONTEXT_TAIL="${THINK_CONTEXT_TAIL:-20}"

# Read the triggering step from stdin
trigger_step=$(cat)
trigger_type=$(printf '%s' "$trigger_step" | jq -r '.type // empty' 2>/dev/null) || true

# Build system prompt with identity context
system_prompt=$(_build_system_prompt)

# Build recent context
recent_context=""
if traj exists 2>/dev/null; then
    recent_context=$(traj tail -n "$THINK_CONTEXT_TAIL" 2>/dev/null) || recent_context=""
fi

# ---------------------------------------------------------------------------
# message mode: conversational reply + optional actions
# ---------------------------------------------------------------------------
if [[ "$trigger_type" == "message" ]]; then
    # Only handle messages addressed to this identity
    msg_to=$(printf '%s' "$trigger_step" | jq -r '.to // empty' 2>/dev/null) || true
    if [[ "$msg_to" != "$IDENTITY_NAME" ]]; then
        # Not addressed to us (e.g., our own outgoing reply) — skip
        exit 0
    fi

    human_message=$(printf '%s' "$trigger_step" | jq -r '.content // empty' 2>/dev/null)
    [[ -z "$human_message" ]] && { printf 'executive/step: no content in message step\n' >&2; exit 1; }

    msg_from=$(printf '%s' "$trigger_step" | jq -r '.from // "human"' 2>/dev/null) || true

    # Load chat prompt
    chat_prompt_file="$SCRIPT_DIR/prompt-chat.md"
    if [[ ! -f "$chat_prompt_file" ]]; then
        printf 'executive/step: error: prompt-chat.md not found at %s\n' "$chat_prompt_file" >&2
        exit 1
    fi

    goals=$(get_goals "$MEM_DIR")
    think_prompt=$(load_prompt "$chat_prompt_file" "$IDENTITY_NAME" "$goals")

    full_message="<context>
$system_prompt

$think_prompt
</context>

Recent conversation (last $THINK_CONTEXT_TAIL steps):
$recent_context

Human's message:
$human_message"

    # Call llm — produce a reply
    printf '  replying...\n' >&2
    response=$(printf '%s' "$full_message" | \
        llm -m "$THINK_MODEL" \
        -s "You are responding to a human message. Output only your reply. No preamble, no meta-commentary." \
        2>/dev/null) || true

    [[ -z "$response" ]] && { printf 'executive/step: empty response from llm\n' >&2; exit 1; }

    # Separate reply text from action lines
    reply=""
    actions=()
    while IFS= read -r line; do
        case "$line" in
            "action: "*|"action:"*)
                actions+=("$line")
                ;;
            *)
                reply="${reply:+$reply
}$line"
                ;;
        esac
    done <<< "$response"

    # Send conversational reply (if any) via chat reply
    if [[ -n "$reply" ]]; then
        printf '%s' "$reply" | chat reply "$msg_from"
        printf '[reply → %s] %s\n' "$msg_from" "$reply"
    fi

    # Write action events to trajectory for the actor to pick up
    for act in "${actions[@]+"${actions[@]}"}"; do
        act_body="${act#action: }"
        [[ "$act_body" == "$act" ]] && act_body="${act#action:}"
        printf '{"type":"action","content":%s,"source":"executive"}' \
            "$(printf '%s' "$act_body" | jq -Rsa .)" \
            | traj append >/dev/null
        printf '[action] %s\n' "$act_body"
    done

    exit 0
fi

# ---------------------------------------------------------------------------
# Default mode: generate thought/action in the thinking loop
# ---------------------------------------------------------------------------

# Ensure think prompt exists
prompt_file="$SCRIPT_DIR/prompt.md"
if [[ ! -f "$prompt_file" ]]; then
    printf 'executive/step: error: prompt.md not found at %s\n' "$prompt_file" >&2
    exit 1
fi

# Build goals and load thinker-specific prompt
goals=$(get_goals "$MEM_DIR")
think_prompt=$(load_prompt "$prompt_file" "$IDENTITY_NAME" "$goals")

full_message="<context>
$system_prompt

$think_prompt
</context>

Recent stream (last $THINK_CONTEXT_TAIL steps):
$recent_context"

# Call llm directly — executive thinker produces one thought, no tool use needed
printf '  thinking...\n' >&2
response=$(printf '%s' "$full_message" | \
    llm -m "$THINK_MODEL" \
    -s "Output only a single thought or action. No explanation, no commands, no preamble." \
    2>/dev/null) || true

[[ -z "$response" ]] && { printf 'executive/step: empty response from shellm\n' >&2; exit 1; }

# Determine step type and strip prefix from content
step_type="thought"
step_content="$response"
case "$response" in
    "action: "*)
        step_type="action"
        step_content="${response#action: }"
        ;;
    "action:"*)
        step_type="action"
        step_content="${response#action:}"
        ;;
esac

# Write to traj
last_content=""
if traj exists 2>/dev/null; then
    last_content=$(traj last --field content 2>/dev/null) || true
fi

if [[ "$last_content" != "$step_content" ]]; then
    printf '{"type":"%s","content":%s,"source":"executive"}' \
        "$step_type" "$(printf '%s' "$step_content" | jq -Rsa .)" \
        | traj append >/dev/null
fi

printf '[%s] %s\n' "$step_type" "$step_content"
