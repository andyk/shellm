#!/usr/bin/env bash
set -euo pipefail

# inner_monologue/step — Core thinking-loop thinker
# Every trigger is a wakeup: rebuild context from the trajectory tail and
# generate the next thought (or action) in the stream of consciousness.
# Incoming messages are handled the same way — the loop sees them in recent
# context; the actor thinker handles the immediate conversational reply.

THINKER_NAME="inner_monologue"
SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0")")" && pwd)"

# shellcheck disable=SC1091
source "$SCRIPT_DIR/../_lib/common.sh"

_require_env

THINK_MODEL="${THINK_MODEL:-glm-5.2}"
THINK_CONTEXT_TAIL="${THINK_CONTEXT_TAIL:-20}"

# Drain the triggering step from stdin (wakeup only — context comes from traj)
cat >/dev/null

# Build system prompt with identity context
system_prompt=$(_build_system_prompt)

# Build recent context (compact: meaningful types only, content truncated)
recent_context=""
if traj exists 2>/dev/null; then
    recent_context=$(_recent_stream "$THINK_CONTEXT_TAIL") || recent_context=""
fi

# Ensure think prompt exists
prompt_file="$SCRIPT_DIR/prompt.md"
if [[ ! -f "$prompt_file" ]]; then
    printf 'inner_monologue/step: error: prompt.md not found at %s\n' "$prompt_file" >&2
    exit 1
fi

# Build goals and load thinker-specific prompt
goals=$(get_goals "$MEM_DIR")
think_prompt=$(load_prompt "$prompt_file" "$IDENTITY_NAME" "$goals")

full_message="<context>
$system_prompt

$think_prompt
</context>

Recent stream (last $THINK_CONTEXT_TAIL steps):
$recent_context"

# Call llm directly — inner_monologue produces one thought, no tool use needed
printf '  thinking...\n' >&2
# llm stderr flows to the thinker log so API errors (rate limits, ...) are visible
response=$(printf '%s' "$full_message" | \
    llm -m "$THINK_MODEL" \
    -s "Output only a single thought or action. No explanation, no commands, no preamble.") || true

# The inner monologue is an infinite loop via trigger_self: it must ALWAYS
# append something to the traj so the dispatcher re-fires.  Empty/duplicate
# responses are degraded but still emit a thought to keep the loop alive.
if [[ -z "$response" ]]; then
    printf 'inner_monologue/step: empty response from llm — emitting placeholder\n' >&2
    response="(inner monologue received an empty response from the LLM; continuing)"
    sleep 1   # brief backoff so transient API failures don't tight-loop
fi

# Determine step type and strip prefix from content
step_type="thought"
step_content="$response"
case "$response" in
    "idle"|"action: idle"|"action:idle")
        step_type="idle"
        step_content="idle"
        ;;
    "action: "*)
        step_type="action"
        step_content="${response#action: }"
        ;;
    "action:"*)
        step_type="action"
        step_content="${response#action:}"
        ;;
esac

# Write to traj — always append (even duplicates) to keep trigger_self alive
last_content=""
if traj exists 2>/dev/null; then
    last_content=$(traj last --field content 2>/dev/null) || true
fi

if [[ "$response" == "$last_content" ]]; then
    step_content="$step_content (repeat)"
fi

printf '{"type":"%s","content":%s,"source":"%s"}' \
    "$step_type" "$(printf '%s' "$step_content" | jq -Rsa .)" "$THINKER_NAME" \
    | traj append >/dev/null

printf '[%s] %s\n' "$step_type" "$step_content"
