#!/usr/bin/env bash
set -euo pipefail

# inner_monologue/step — Core thinking-loop thinker
# Every trigger is a wakeup: rebuild context from the trajectory tail and
# generate the next thought (or action) in the stream of consciousness.
# Incoming messages are handled the same way — the loop sees them in recent
# context; the actor thinker handles the immediate conversational reply.

THINKER_NAME="inner_monologue"
SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0")")" && pwd)"

# shellcheck disable=SC1091
source "$SCRIPT_DIR/../_lib/common.sh"

_require_env

THINK_MODEL="${THINK_MODEL:-${SHELLM_MODEL:-claude-opus-4-7}}"
THINK_CONTEXT_TAIL="${THINK_CONTEXT_TAIL:-20}"

# Capture the triggering step from stdin (context still comes from traj).
# The step_id is stamped as trigger_step on the step we append, so viewers
# can draw the exact dispatch edge.
step_json=$(cat)
trigger_step_id=$(printf '%s' "$step_json" | jq -r '.step_id // empty' 2>/dev/null) || true

# Build system prompt with identity context
system_prompt=$(_build_system_prompt)

# Build recent context (compact: meaningful types only, content truncated)
recent_context=""
if traj exists 2>/dev/null; then
    recent_context=$(_recent_stream "$THINK_CONTEXT_TAIL") || recent_context=""
fi

# Ensure think prompt exists
prompt_file="$SCRIPT_DIR/prompt.md"
if [[ ! -f "$prompt_file" ]]; then
    printf 'inner_monologue/step: error: prompt.md not found at %s\n' "$prompt_file" >&2
    exit 1
fi

# Build goals and load thinker-specific prompt
goals=$(get_goals "$MEM_DIR")
think_prompt=$(load_prompt "$prompt_file" "$IDENTITY_NAME" "$goals")

full_message="<context>
$system_prompt

$think_prompt
</context>

Recent stream (last $THINK_CONTEXT_TAIL steps):
$recent_context"

# Call llm directly — inner_monologue produces one thought, no tool use needed
printf '  thinking...\n' >&2
# llm stderr flows to the thinker log so API errors (rate limits, ...) are visible
response=$(printf '%s' "$full_message" | \
    llm -m "$THINK_MODEL" \
    -s "Output only a single thought or action. No explanation, no commands, no preamble.") || true

# The inner monologue is an infinite loop via trigger_self: appending keeps
# the dispatcher re-firing. Empty responses emit a placeholder to keep the
# loop alive, with exponential backoff so a dead/struggling LLM doesn't spin
# the loop at full speed; after enough consecutive empties the monologue goes
# dormant (no append -> no self-trigger) until the next external step wakes
# it. A non-empty response resets the counter.
empty_count_file="$IDENTITY_DIR/run/inner_monologue.empty_count"
if [[ -z "$response" ]]; then
    empty_count=$(cat "$empty_count_file" 2>/dev/null) || empty_count=0
    empty_count=$((empty_count + 1))
    mkdir -p "$(dirname "$empty_count_file")"
    printf '%s' "$empty_count" > "$empty_count_file"
    if [[ "$empty_count" -ge 10 ]]; then
        printf 'inner_monologue/step: %s consecutive empty responses — going dormant until the next external trigger\n' "$empty_count" >&2
        exit 0
    fi
    printf 'inner_monologue/step: empty response from llm — emitting placeholder (%s consecutive)\n' "$empty_count" >&2
    response="(inner monologue received an empty response from the LLM; continuing)"
    sleep $(( empty_count < 6 ? (1 << empty_count) : 60 ))
else
    rm -f "$empty_count_file"
fi

# Defensive unwrap: the model occasionally mimics the JSON step envelopes it
# sees in the recent stream and emits one as its whole response; recover the
# inner content instead of double-wrapping it (gen-001 proposal 04).
if [[ "$response" == "{"* ]]; then
    unwrapped=$(printf '%s' "$response" | jq -r 'select(type == "object") | .content // empty' 2>/dev/null) || true
    if [[ -n "$unwrapped" ]]; then
        unwrapped_type=$(printf '%s' "$response" | jq -r 'select(type == "object") | .type // empty' 2>/dev/null) || true
        # Preserve an action envelope's intent through the prefix classifier
        if [[ "$unwrapped_type" == "action" && "$unwrapped" != action:* ]]; then
            unwrapped="action: $unwrapped"
        fi
        response="$unwrapped"
    fi
fi

# Determine step type and strip prefix from content
step_type="thought"
step_content="$response"
case "$response" in
    "idle"|"action: idle"|"action:idle")
        step_type="idle"
        step_content="idle"
        ;;
    "action: "*)
        step_type="action"
        step_content="${response#action: }"
        ;;
    "action:"*)
        step_type="action"
        step_content="${response#action:}"
        ;;
esac

# Write to traj — always append (even duplicates) to keep trigger_self alive.
# Duplicates are appended verbatim: _recent_stream collapses repeated steps
# into one line with a repeats count when building thinker context, and a
# mutated suffix would defeat that equality check.
jq -nc \
    --arg type "$step_type" \
    --arg content "$step_content" \
    --arg source "$THINKER_NAME" \
    --arg trigger "$trigger_step_id" \
    '{type:$type, content:$content, source:$source}
     + (if $trigger == "" then {} else {trigger_step: $trigger} end)' \
    | traj append >/dev/null

printf '[%s] %s\n' "$step_type" "$step_content"
