#!/usr/bin/env bash
set -euo pipefail

# actor/step — Action executor thinker
# Reads action body from step JSON on stdin, builds system prompt via
# _build_system_prompt, calls shellm with fork/merge support.

THINKER_NAME="actor"
SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0")")" && pwd)"

# shellcheck disable=SC1091
source "$SCRIPT_DIR/../_lib/common.sh"

_require_env

THINK_MODEL="${THINK_MODEL:-${SHELLM_MODEL:-claude-opus-4-7}}"

# Read step JSON from stdin
step_json=$(cat)
[[ -z "$step_json" ]] && exit 0

# Extract action content
action_body=$(printf '%s' "$step_json" | jq -r '.content // empty' 2>/dev/null) || true
[[ -z "$action_body" ]] && exit 0

# Build system prompt with identity context
system_prompt=$(_build_system_prompt)

# Resolve absolute paths
run_dir="$IDENTITY_DIR/workdir"
mkdir -p "$run_dir"

# Build shellm flags
shellm_flags=()
while IFS= read -r _flag; do
    [[ -n "$_flag" ]] && shellm_flags+=("$_flag")
done < <(_build_shellm_flags "$IDENTITY_DIR")

# Load thinker prompt
prompt_file="$SCRIPT_DIR/prompt.md"
[[ -f "$prompt_file" ]] || { printf 'actor/step: error: prompt.md not found at %s\n' "$prompt_file" >&2; exit 1; }
thinker_prompt=$(cat "$prompt_file")

act_prompt="<context>
$system_prompt

$thinker_prompt
</context>

ACTION: $action_body"


# Fast-path: detect chat reply intent via fast classifier
THINK_FAST_MODEL="${THINK_FAST_MODEL:-gemini-3.5-flash}"

is_reply=$(printf 'Action: %s\n\nIs this action about replying, responding, or sending a message to someone in chat? Answer only YES or NO.' "$action_body" | \
    llm -m "$THINK_FAST_MODEL" -s "Answer only YES or NO." 2>/dev/null) || true

if [[ "$(printf '%s' "$is_reply" | tr '[:lower:]' '[:upper:]')" == *"YES"* ]]; then
    printf '  fast reply...\n' >&2
    reply=$(printf '%s' "$act_prompt" | \
        llm -m "$THINK_FAST_MODEL" \
        -s "Write a short, natural reply. Output ONLY the message text, nothing else." \
        2>/dev/null) || true
    if [[ -n "$reply" ]]; then
        reply_to=$(printf '%s' "$step_json" | jq -r '.to // .recipient // empty' 2>/dev/null) || true
        if [[ -z "$reply_to" ]]; then
            reply_to=$(traj cat "${ROOT_TRAJ_ID:-$TRAJ_ID}" --filter type=message,human-msg --raw 2>/dev/null | \
                jq -sr --arg me "${IDENTITY_NAME:-}" '
                    reverse
                    | map(select(
                        (.type == "message" and (.to // "") == $me and (.from // "") != "")
                        or (.type == "human-msg" and (.from // "") != "")
                    ))
                    | .[0].from // empty
                ' 2>/dev/null) || true
        fi

        if [[ -n "$reply_to" ]] && printf '%s' "$reply" | chat reply "$reply_to"; then
            printf '{"type":"observation","content":%s,"source":"actor"}' \
                "$(printf 'Replied to %s: %s' "$reply_to" "$reply" | jq -Rsa .)" | traj append
            printf '  [reply -> %s] %s\n' "$reply_to" "$(printf '%s' "$reply" | head -1)" >&2
            exit 0
        fi
    fi
fi

# Full shellm agentic loop for non-chat actions (writes to root trajectory)
printf '  executing action...\n' >&2
act_response=$(SHELLM_NO_BANNER=1 SHELLM_MODEL="$THINK_MODEL" \
    shellm --traj "$TRAJ_ID" \
    "${shellm_flags[@]}" \
    "$act_prompt") || true

if [[ -n "$act_response" ]]; then
    printf '  [observation] %s\n' "$(printf '%s' "$act_response" | head -1)"
fi
