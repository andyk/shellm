#!/usr/bin/env bash
set -euo pipefail

# actor/step — Action executor thinker
# Reads action body from step JSON on stdin, builds system prompt via
# _build_system_prompt, calls shellm with fork/merge support.

THINKER_NAME="actor"
SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0")")" && pwd)"

# shellcheck disable=SC1091
source "$SCRIPT_DIR/../_lib/common.sh"

_require_env

THINK_MODEL="${THINK_MODEL:-${SHELLM_MODEL:-claude-opus-4-7}}"

# Read step JSON from stdin
step_json=$(cat)
[[ -z "$step_json" ]] && exit 0

# Extract action content
action_body=$(printf '%s' "$step_json" | jq -r '.content // empty' 2>/dev/null) || true
[[ -z "$action_body" ]] && exit 0

# Build system prompt with identity context
system_prompt=$(_build_system_prompt)

# Resolve absolute paths
run_dir="$IDENTITY_DIR/workdir"
mkdir -p "$run_dir"

# Build shellm flags
shellm_flags=()
while IFS= read -r _flag; do
    [[ -n "$_flag" ]] && shellm_flags+=("$_flag")
done < <(_build_shellm_flags "$IDENTITY_DIR")

# Load thinker prompt
prompt_file="$SCRIPT_DIR/prompt.md"
[[ -f "$prompt_file" ]] || { printf 'actor/step: error: prompt.md not found at %s\n' "$prompt_file" >&2; exit 1; }
thinker_prompt=$(cat "$prompt_file")

act_prompt="<context>
$system_prompt

$thinker_prompt
</context>

ACTION: $action_body"


# shellm handles fork/merge via _SHELLM_PARENT_TRAJ_ID
printf '  executing action...\n' >&2
act_response=$(_SHELLM_PARENT_TRAJ_ID="$TRAJ_ID" \
    SHELLM_NO_BANNER=1 SHELLM_MODEL="$THINK_MODEL" \
    shellm --env "$IDENTITY_NAME" --workdir "$run_dir" \
    "${shellm_flags[@]}" \
    "$act_prompt") || true

if [[ -n "$act_response" ]]; then
    printf '  [observation] %s\n' "$(printf '%s' "$act_response" | head -1)"
fi
