#!/usr/bin/env bash
set -euo pipefail

# shelly — Interactive conversational agent
# A thin CLI wrapper around shellm, mem, and skills that provides
# multi-turn conversation with identity management.

# ---------------------------------------------------------------------------
# Config & defaults
# ---------------------------------------------------------------------------

SHELLY_DIR="${SHELLY_DIR:-.shelly}"
SHELLY_MODEL="${SHELLY_MODEL:-${SHELLM_MODEL:-claude-opus-4-6}}"
SHELLY_MEMORIES_DIR=""
SHELLY_SKILLS_DIR=""
SHELLY_KERNEL_DIR=""
VERBOSE=0

# Source per-repo rc file (flags > env vars > rc file)
if [[ -f ".shellyrc" ]]; then
    _pre_env=$(env | grep '^SHELLY_') || true
    source .shellyrc
    while IFS='=' read -r k v; do
        [[ -n "$k" ]] && export "$k=$v"
    done <<< "$_pre_env"
fi

# ---------------------------------------------------------------------------
# Utility functions
# ---------------------------------------------------------------------------

die() { echo "shelly: error: $*" >&2; exit 1; }

debug() {
    if [[ "$VERBOSE" -eq 1 ]]; then
        printf '[shelly debug] %s\n' "$*" >&2
    fi
}

iso_timestamp() {
    date +%Y-%m-%dT%H:%M:%S
}

json_escape() {
    printf '%s' "$1" | jq -Rsa .
}

# ---------------------------------------------------------------------------
# Identity management
# ---------------------------------------------------------------------------

ensure_identity() {
    mkdir -p "$SHELLY_DIR/identities"
    if [[ ! -L "$SHELLY_DIR/identities/current" ]] || [[ ! -d "$SHELLY_DIR/identities/current" ]]; then
        cmd_new "shelly"
    fi
    # Always resolve memories/skills/kernel to current identity
    local identity_dir
    identity_dir=$(resolve_identity)
    SHELLY_MEMORIES_DIR="$identity_dir/memories"
    SHELLY_SKILLS_DIR="$identity_dir/skills"
    SHELLY_KERNEL_DIR="$identity_dir/kernel"
    mkdir -p "$SHELLY_MEMORIES_DIR" "$SHELLY_SKILLS_DIR" "$SHELLY_KERNEL_DIR"
    ensure_kernel
}

resolve_identity() {
    if [[ ! -L "$SHELLY_DIR/identities/current" ]]; then
        die "No active identity. Run: shelly new <name>"
    fi
    local target
    target=$(readlink "$SHELLY_DIR/identities/current")
    # Handle relative symlinks (current is inside identities/)
    if [[ "$target" != /* ]]; then
        target="$SHELLY_DIR/identities/$target"
    fi
    if [[ ! -d "$target" ]]; then
        die "Current identity directory missing: $target"
    fi
    # Return absolute path (needed for Docker workspace mounts)
    (cd "$target" && pwd)
}

ensure_kernel() {
    mkdir -p "$SHELLY_KERNEL_DIR/mem"
    if [[ ! -f "$SHELLY_KERNEL_DIR/mem/SKILL.md" ]]; then
        cat > "$SHELLY_KERNEL_DIR/mem/SKILL.md" << 'MEMSKILL'
---
name: mem
description: Life context and memory system
---

# mem — Life context system

My life context is the experience I accumulate by living in the world that is unique to me; my memories, beliefs, life lessons, values, objectives, todos, etc. It is what makes me me; my identity. These pieces of my identity, my life context (memories, values, beliefs, tasks, etc.) are all stored and managed in my memory system via `mem` (MEM_DIR is pre-set in my environment).

Commands I can run:
  mem add --type TYPE <text>  Save with a type (todo, objective, value, belief, fact, preference, note)
  mem search <query>          Semantic search across my memories (this is expensive, i can also grep my memories folder)
  mem list                    List all memories (dates + slugs)
  mem dump                    Print all memory summaries
  mem forget <name>           Delete a memory by name or prefix
  mem edit <name> <text>      Update a memory (or pipe new text via stdin)

Each memory/task/etc. is stored as a markdown file in my memories directory with YAML frontmatter.

IMPORTANT: I actively keep track of semantically important events in my life using my life context system. So I quick to create a new mem anytime something important or memorable or suprising happens.

To create a new piece of life context, I use `mem add`. I can see my most recent memories below or I can use `mem search`.
MEMSKILL
        debug "Bootstrapped mem kernel skill"
    fi
}

# ---------------------------------------------------------------------------
# Context assembly
# ---------------------------------------------------------------------------

assemble_context() {
    local identity_dir="$1"
    local context=""

    # 1. Core identity — personality/self-description
    if [[ -f "$identity_dir/system_prompt.txt" ]]; then
        context=$(cat "$identity_dir/system_prompt.txt")
    else
        context='I am shelly, I am an AI with an identity, life context (e.g., memory), and skills. I am concise, smart, ambitious, and empathetic.

## How I work
I am a bash script that wraps shellm, mem, and skills into a conversational agent. My source code is at '"$(realpath "$0")"'. I can read my own code to understand how I work. I run inside shellm, which executes my bash code blocks in a loop until I set FINAL with my answer.

IMPORTANT: When setting FINAL, I MUST use a heredoc to avoid bash interpreting backticks or special characters in my response:
```bash
FINAL=$(cat <<'"'"'ENDOFRESPONSE'"'"'
My response with `backticks` and $pecial characters safely here.
ENDOFRESPONSE
)
```'
    fi

    # 2. Skills CLI knowledge (the "kernel-kernel" — hardcoded, changes in lockstep with CLI)
    context="$context

## My skills system
My skills are learned abilities that let me do specific things well. They are how I grow and become more capable over time. Each skill is a set of instructions I can follow to accomplish a particular type of task — like a recipe or a playbook. I can install new skills from GitHub or create my own, and they persist as part of me just like my memories. Skills are managed via \`skills\` (SKILLS_DIR is pre-set in my environment).

Commands I can run:
  skills                              List all my installed skills
  skills <query>                      Search installed + remote skills (GitHub)
  skills --show <name>                Print a skill's full SKILL.md
  skills --install <owner/repo|path>  Install a skill from GitHub or local path
  skills --remove <name>              Remove an installed skill
  skills --init [name]                Scaffold a new skill
  skills --list-json                  List skills as JSON
  skills --promote <name>             Promote a skill to my kernel (always loaded)
  skills --demote <name>              Demote a kernel skill back to on-demand
  skills --kernel                     Show kernel skills with token counts

My kernel skills are always loaded into my context. Regular skills are on-demand — I load them with \`skills --show <name>\` when needed.
When the user asks me to use a skill, I read it with \`skills --show <name>\` and follow its instructions."

    # 3. Kernel skills — full content from each SKILL.md in kernel/
    local kernel_content=""
    if [[ -d "$SHELLY_KERNEL_DIR" ]]; then
        local skill_dir
        for skill_dir in "$SHELLY_KERNEL_DIR"/*/; do
            [[ -f "${skill_dir}SKILL.md" ]] || continue
            local skill_body
            # Strip YAML frontmatter (between --- markers)
            skill_body=$(sed -n '/^---$/,/^---$/d; p' "${skill_dir}SKILL.md")
            if [[ -n "$skill_body" ]]; then
                kernel_content="${kernel_content}
${skill_body}"
            fi
        done
    fi
    if [[ -n "$kernel_content" ]]; then
        context="$context
$kernel_content"
    fi

    # 4. Memories — mem dump output
    local memories=""
    if command -v mem >/dev/null 2>&1; then
        memories=$(MEM_DIR="$SHELLY_MEMORIES_DIR" mem dump 2>/dev/null) || true
    fi
    if [[ -n "$memories" && "$memories" != "No memories stored." ]]; then
        context="$context

## Memories
$memories"
    fi

    # 5. Available skills — summary list from identity's skills/ dir
    local skills_summary=""
    if [[ -d "$identity_dir/skills" ]]; then
        local skill_dir
        for skill_dir in "$identity_dir/skills"/*/; do
            [[ -f "${skill_dir}SKILL.md" ]] || continue
            local sname sdesc
            sname=$(sed -n '/^---$/,/^---$/{ /^name:/{ s/^name:[[:space:]]*//; s/^["'"'"']\(.*\)["'"'"']$/\1/; p; } }' "${skill_dir}SKILL.md")
            sdesc=$(sed -n '/^---$/,/^---$/{ /^description:/{ s/^description:[[:space:]]*//; s/^["'"'"']\(.*\)["'"'"']$/\1/; p; } }' "${skill_dir}SKILL.md")
            [[ -z "$sname" ]] && sname=$(basename "$skill_dir")
            skills_summary="${skills_summary}  - ${sname}: ${sdesc}
"
        done
    fi
    if [[ -n "$skills_summary" ]]; then
        context="$context

## Available skills (use \`skills --show <name>\` to load)
$skills_summary"
    fi

    # Write assembled context
    printf '%s' "$context" > "$identity_dir/context.txt"
    printf '%s' "$context"
}

# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

cmd_send() {
    local message="$*"

    # Read from stdin if no args and stdin is piped
    if [[ -z "$message" && ! -t 0 ]]; then
        message=$(cat)
    fi
    [[ -z "$message" ]] && die "No message provided. Usage: shelly send <message>"

    ensure_identity
    local identity_dir
    identity_dir=$(resolve_identity)

    local ts
    ts=$(iso_timestamp)

    # Append user message to history
    local user_json
    user_json=$(jq -nc --arg role "user" --arg content "$message" --arg ts "$ts" \
        '{role:$role, content:$content, ts:$ts}')
    printf '%s\n' "$user_json" >> "$identity_dir/history.jsonl"

    # Assemble context (personality, kernel skills, memories, available skills)
    local context
    context=$(assemble_context "$identity_dir")

    # Prepend context to user message so shellm keeps its own system prompt
    local full_message="<context>
$context
</context>

$message"

    # Run shellm in background so Ctrl+C can interrupt it
    local run_dir="$identity_dir/run"
    local response_file
    response_file=$(mktemp)
    local _interrupted=0

    # Resolve absolute paths so mem/skills work from any working directory
    local abs_mem_dir abs_skills_dir abs_kernel_dir
    abs_mem_dir=$(cd "$SHELLY_MEMORIES_DIR" 2>/dev/null && pwd) || abs_mem_dir="$SHELLY_MEMORIES_DIR"
    abs_skills_dir=$(cd "$SHELLY_SKILLS_DIR" 2>/dev/null && pwd) || abs_skills_dir="$SHELLY_SKILLS_DIR"
    abs_kernel_dir=$(cd "$SHELLY_KERNEL_DIR" 2>/dev/null && pwd) || abs_kernel_dir="$SHELLY_KERNEL_DIR"

    local identity_name
    identity_name=$(basename "$(readlink "$SHELLY_DIR/identities/current")")

    if [[ -f "$run_dir/.messages.json" ]]; then
        debug "Resuming identity with --continue"
        SHELLM_NO_BANNER=1 SHELLM_MODEL="$SHELLY_MODEL" \
            MEM_DIR="$abs_mem_dir" SKILLS_DIR="$abs_skills_dir" \
            SHELLY_KERNEL_DIR="$abs_kernel_dir" \
            shellm --workspace "$identity_name" --continue --workdir "$run_dir" "$full_message" > "$response_file" &
    else
        debug "Starting new shellm workspace"
        SHELLM_NO_BANNER=1 SHELLM_MODEL="$SHELLY_MODEL" \
            MEM_DIR="$abs_mem_dir" SKILLS_DIR="$abs_skills_dir" \
            SHELLY_KERNEL_DIR="$abs_kernel_dir" \
            shellm --workspace "$identity_name" --workdir "$run_dir" "$full_message" > "$response_file" &
    fi
    local shellm_pid=$!

    # Trap SIGINT: kill shellm but don't exit shelly
    trap '_interrupted=1; kill $shellm_pid 2>/dev/null || true' INT
    wait "$shellm_pid" 2>/dev/null && true || true
    trap - INT

    if [[ "$_interrupted" -eq 1 ]]; then
        # Wait for shellm to fully exit (cleanup trap, Docker teardown, etc.)
        wait "$shellm_pid" 2>/dev/null || true
        rm -f "$response_file"
        printf '\n(interrupted)\n' >&2
        return 0
    fi

    local response
    response=$(cat "$response_file")
    rm -f "$response_file"

    # Print response
    if [[ -n "$response" ]]; then
        printf '%s\n' "$response"
    fi

    # Append assistant message to history
    local reply_ts
    reply_ts=$(iso_timestamp)
    local abs_run_dir
    abs_run_dir=$(cd "$run_dir" 2>/dev/null && pwd) || abs_run_dir="$run_dir"
    local assistant_json
    assistant_json=$(jq -nc --arg role "assistant" --arg content "${response:-}" \
        --arg ts "$reply_ts" --arg shellm_dir "$abs_run_dir" \
        '{role:$role, content:$content, ts:$ts, shellm_dir:$shellm_dir}')
    printf '%s\n' "$assistant_json" >> "$identity_dir/history.jsonl"
}

cmd_repl() {
    ensure_identity

    printf 'shelly repl (Ctrl+C to interrupt, Ctrl+D to exit)\n' >&2

    # Use shelly_history for readline
    local history_file="$SHELLY_DIR/shelly_history"
    touch "$history_file"

    # Load readline history
    if [[ -f "$history_file" ]]; then
        history -r "$history_file" 2>/dev/null || true
    fi

    while true; do
        local input=""
        local _sigint=0

        # Trap SIGINT at the prompt: clear line, re-prompt
        trap '_sigint=1' INT
        local read_rc=0
        IFS= read -e -r -p "> " input || read_rc=$?
        trap - INT

        if [[ "$_sigint" -eq 1 ]]; then
            printf '\n' >&2
            continue
        fi

        if [[ "$read_rc" -ne 0 ]]; then
            # EOF (Ctrl-D)
            printf '\n' >&2
            break
        fi

        # Save to readline history
        history -s "$input" 2>/dev/null || true
        history -w "$history_file" 2>/dev/null || true

        # Skip empty input
        [[ -z "$input" ]] && continue

        # Handle slash commands
        case "$input" in
            /quit|/exit|/q)
                break
                ;;
            /new\ *)
                local new_name="${input#/new }"
                new_name="${new_name## }"  # trim leading spaces
                if [[ -z "$new_name" ]]; then
                    printf 'Usage: /new <name>\n' >&2
                else
                    cmd_new "$new_name"
                    printf 'Switched to new identity: %s\n' "$new_name" >&2
                fi
                ;;
            /new)
                printf 'Usage: /new <name>\n' >&2
                ;;
            /identities)
                cmd_identities
                ;;
            /switch\ *)
                local switch_name="${input#/switch }"
                cmd_switch "$switch_name"
                ;;
            /history)
                cmd_history
                ;;
            /reset)
                cmd_reset
                printf 'Identity reset.\n' >&2
                ;;
            /compact)
                cmd_compact
                ;;
            /context)
                cmd_context
                ;;
            /kernel)
                cmd_kernel
                ;;
            /mem\ *)
                local mem_args="${input#/mem }"
                eval MEM_DIR=\"\$SHELLY_MEMORIES_DIR\" mem $mem_args
                ;;
            /mem)
                MEM_DIR="$SHELLY_MEMORIES_DIR" mem dump
                ;;
            /skills\ *)
                local skills_args="${input#/skills }"
                eval SKILLS_DIR=\"\$SHELLY_SKILLS_DIR\" SHELLY_KERNEL_DIR=\"\$SHELLY_KERNEL_DIR\" skills $skills_args
                ;;
            /skills)
                SKILLS_DIR="$SHELLY_SKILLS_DIR" SHELLY_KERNEL_DIR="$SHELLY_KERNEL_DIR" skills
                ;;
            /help)
                repl_help
                ;;
            /*)
                printf 'Unknown command: %s (type /help)\n' "$input" >&2
                ;;
            *)
                cmd_send "$input"
                ;;
        esac
    done
}

repl_help() {
    cat >&2 <<'EOF'
Slash commands:
  /new <name>     Create a new identity
  /identities     List all identities
  /switch <name>  Switch to an identity (prefix match)
  /history        Show conversation history
  /reset          Reset current identity
  /compact        Summarize and compact history
  /context        Show assembled system prompt
  /kernel         Show kernel skills with token counts
  /mem add <text>       Add a memory
  /mem search <query>   Search memories
  /mem list             List memories (dates + slugs)
  /mem dump             Print all memory summaries
  /mem forget <name>    Delete a memory
  /mem edit <name> <text> Update a memory
  /skills               List installed skills
  /skills <query>       Search installed + remote skills
  /skills --show <name> Print a skill's SKILL.md
  /skills --install <src> Install a skill
  /skills --remove <name> Remove a skill
  /skills --init [name] Scaffold a new skill
  /skills --promote <name> Promote skill to kernel
  /skills --demote <name>  Demote kernel skill
  /quit           Exit the repl
EOF
}

cmd_new() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: shelly new <name>"

    # Validate name: lowercase alphanumeric + hyphens
    if [[ ! "$name" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
        die "Invalid identity name: '$name' (use lowercase alphanumeric + hyphens)"
    fi

    local identity_dir="$SHELLY_DIR/identities/$name"
    if [[ -d "$identity_dir" ]]; then
        die "Identity '$name' already exists"
    fi

    mkdir -p "$identity_dir"

    # Create meta.txt
    local cwd
    cwd=$(pwd)
    printf 'cwd=%s\nstarted=%s\n' "$cwd" "$(iso_timestamp)" > "$identity_dir/meta.txt"

    # Initialize empty history
    : > "$identity_dir/history.jsonl"

    # Create per-identity dirs
    mkdir -p "$identity_dir/memories" "$identity_dir/skills" "$identity_dir/kernel"

    # Bootstrap kernel (mem SKILL.md)
    SHELLY_KERNEL_DIR="$identity_dir/kernel"
    ensure_kernel

    # Update current symlink
    ln -sfn "$name" "$SHELLY_DIR/identities/current"

    # Re-resolve dirs for the new identity
    SHELLY_MEMORIES_DIR="$identity_dir/memories"
    SHELLY_SKILLS_DIR="$identity_dir/skills"

    debug "Created identity: $name"
    printf '%s\n' "$name" >&2
}

cmd_identities() {
    local identities_dir="$SHELLY_DIR/identities"
    if [[ ! -d "$identities_dir" ]]; then
        echo "No identities." >&2
        return
    fi

    local dirs
    dirs=$(ls -1 "$identities_dir" 2>/dev/null | grep -v '^current$') || true
    if [[ -z "$dirs" ]]; then
        echo "No identities." >&2
        return
    fi

    # Find current identity for marking
    local current_name=""
    if [[ -L "$SHELLY_DIR/identities/current" ]]; then
        local cur_target
        cur_target=$(readlink "$SHELLY_DIR/identities/current")
        current_name=$(basename "$cur_target")
    fi

    local d
    while IFS= read -r d; do
        local marker=" "
        [[ "$d" == "$current_name" ]] && marker="*"

        # Get first user message as preview
        local preview=""
        local hist="$identities_dir/$d/history.jsonl"
        if [[ -f "$hist" ]]; then
            preview=$(head -1 "$hist" 2>/dev/null | jq -r '.content // ""' 2>/dev/null | head -c 60) || true
        fi

        printf '%s %s  %s\n' "$marker" "$d" "$preview"
    done <<< "$dirs"
}

cmd_switch() {
    local target="$1"
    [[ -z "$target" ]] && die "Usage: shelly switch <name>"

    local identities_dir="$SHELLY_DIR/identities"
    [[ ! -d "$identities_dir" ]] && die "No identities found"

    # Try exact match first
    if [[ -d "$identities_dir/$target" ]]; then
        ln -sfn "$target" "$SHELLY_DIR/identities/current"
        printf 'Switched to: %s\n' "$target" >&2
        return
    fi

    # Prefix/substring match
    local matches
    matches=$(ls -1 "$identities_dir" 2>/dev/null | grep -v '^current$' | grep "$target" || true)
    local count
    count=$(printf '%s' "$matches" | grep -c . 2>/dev/null) || count=0

    if [[ "$count" -eq 1 ]]; then
        ln -sfn "$matches" "$SHELLY_DIR/identities/current"
        printf 'Switched to: %s\n' "$matches" >&2
    elif [[ "$count" -gt 1 ]]; then
        die "Ambiguous: '$target' matches multiple identities:
$matches"
    else
        die "No identity matching: $target"
    fi
}

cmd_history() {
    ensure_identity
    local identity_dir
    identity_dir=$(resolve_identity)

    local hist="$identity_dir/history.jsonl"
    if [[ ! -f "$hist" ]] || [[ ! -s "$hist" ]]; then
        echo "(empty history)" >&2
        return
    fi

    while IFS= read -r line; do
        local role content
        role=$(printf '%s' "$line" | jq -r '.role // ""')
        content=$(printf '%s' "$line" | jq -r '.content // ""')

        if [[ "$role" == "user" ]]; then
            printf '> %s\n\n' "$content"
        elif [[ "$role" == "assistant" ]]; then
            printf '%s\n\n' "$content"
        fi
    done < "$hist"
}

cmd_reset() {
    ensure_identity
    local identity_dir
    identity_dir=$(resolve_identity)
    local identity_name
    identity_name=$(basename "$identity_dir")

    # Destroy the Docker workspace for this identity
    local ws_dir="$HOME/.shellm/workspaces/$identity_name"
    if [[ -d "$ws_dir" ]]; then
        if [[ -f "$ws_dir/container_id" ]]; then
            local cid
            cid=$(cat "$ws_dir/container_id" 2>/dev/null || true)
            [[ -n "$cid" ]] && docker rm -f "$cid" >/dev/null 2>&1 || true
        fi
        rm -rf "$ws_dir"
    fi

    # Truncate history
    : > "$identity_dir/history.jsonl"

    # Remove shellm workdir
    rm -rf "$identity_dir/run"

    debug "Cleared identity: $identity_dir"
}

cmd_compact() {
    ensure_identity
    local identity_dir
    identity_dir=$(resolve_identity)

    local hist="$identity_dir/history.jsonl"
    if [[ ! -f "$hist" ]] || [[ ! -s "$hist" ]]; then
        echo "Nothing to compact." >&2
        return
    fi

    # Build conversation text from history
    local conversation=""
    while IFS= read -r line; do
        local role content
        role=$(printf '%s' "$line" | jq -r '.role // ""')
        content=$(printf '%s' "$line" | jq -r '.content // ""')
        if [[ "$role" == "user" ]]; then
            conversation="${conversation}User: ${content}
"
        elif [[ "$role" == "assistant" ]]; then
            conversation="${conversation}Assistant: ${content}
"
        fi
    done < "$hist"

    # Summarize using llm
    printf 'Compacting history...\n' >&2
    local summary
    summary=$(llm -m "$SHELLY_MODEL" \
        -s "You produce concise conversation summaries. Capture key facts, decisions, and context." \
        "Summarize this conversation concisely. Output a brief summary paragraph.

${conversation}") || {
        die "Failed to compact history"
    }

    # Replace history with summary
    local ts
    ts=$(iso_timestamp)
    printf '' > "$hist"
    local sys_json
    sys_json=$(jq -nc --arg role "assistant" --arg content "[Compacted] $summary" --arg ts "$ts" \
        '{role:$role, content:$content, ts:$ts}')
    printf '%s\n' "$sys_json" > "$hist"

    # Destroy the Docker workspace for this identity
    local identity_name
    identity_name=$(basename "$identity_dir")
    local ws_dir="$HOME/.shellm/workspaces/$identity_name"
    if [[ -d "$ws_dir" ]]; then
        if [[ -f "$ws_dir/container_id" ]]; then
            local cid
            cid=$(cat "$ws_dir/container_id" 2>/dev/null || true)
            [[ -n "$cid" ]] && docker rm -f "$cid" >/dev/null 2>&1 || true
        fi
        rm -rf "$ws_dir"
    fi

    # Remove old shellm workdir (will be recreated on next send)
    rm -rf "$identity_dir/run"

    printf 'History compacted.\n' >&2
}

cmd_context() {
    ensure_identity
    local identity_dir
    identity_dir=$(resolve_identity)
    assemble_context "$identity_dir" >/dev/null
    cat "$identity_dir/context.txt"
    printf '\n'
}

cmd_kernel() {
    ensure_identity
    local abs_kernel_dir
    abs_kernel_dir=$(cd "$SHELLY_KERNEL_DIR" 2>/dev/null && pwd) || abs_kernel_dir="$SHELLY_KERNEL_DIR"
    SHELLY_KERNEL_DIR="$abs_kernel_dir" SKILLS_DIR="$SHELLY_SKILLS_DIR" skills --kernel
}

